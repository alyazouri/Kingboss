    recordFPS: function(fps) {
        this.totalFPSSamples++;
        this.sumFPS += fps;
        if (fps >= CFG.TARGET_FPS) this.fpsPeaks++;
        if (fps < CFG.MINIMUM_FPS) this.fpsDrops++;
    },

    recordMode: function(mode) {
        if (!this.modeStats[mode]) {
            this.modeStats[mode] = {
                count:     0,
                firstSeen: now(),
                lastSeen:  0,
                totalPing: 0,
                avgPing:   0,
                fpsAvg:    0
            };
        }
        var s = this.modeStats[mode];
        s.count++;
        s.lastSeen = now();

        if (this.currentMode !== mode) {
            if (this.modeHistory.length >= 20) this.modeHistory.shift();
            this.modeHistory.push({ mode: mode, time: now() });
            this.currentMode = mode;
        }
    },

    recordSocial: function(type) {
        if (type === "FRIEND") this.friendDiscoveries++;
        if (type === "CREW")   this.crewSearches++;
        if (type === "LOBBY")  this.lobbyJoins++;
        this.socialAPIcalls++;
    },

    recordPing: function(ping, mode) {
        this.totalPingTime += ping;
        if (ping < this.bestPing)  this.bestPing  = ping;
        if (ping > this.worstPing) this.worstPing = ping;

        var fps = FPS_ENGINE.pingToFPS(ping);
        this.recordFPS(fps);

        if (mode && this.modeStats[mode]) {
            var s = this.modeStats[mode];
            s.totalPing += ping;
            s.avgPing    = Math.round(s.totalPing / s.count);
        }
    },

    updateGameState: function(state) {
        if (state && state !== this.gameState) {
            this.gameState = state;
        }
    },

    updateTimeContext: function() {
        var date = new Date();
        var h    = date.getHou
rs = (h >= 16 || h <= 2);
