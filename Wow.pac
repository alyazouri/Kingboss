    },

    recordAnomaly: function() {
        this.anomalies++;
        this.lastAnomaly = now();
    },

    recordRecovery: function() {
        this.recoveries++;
    },

    getReport: function() {
        return {
            version:            CFG.VERSION,
            sessionId:          this.sessionId,
            duration:           this.age(),
            requests:           this.requests,
            pubgRequests:       this.pubgRequests,
            socialRequests:     this.socialRequests,
            fpsRequests:        this.fpsRequests,
            jordanRatio:        this.jordanRatio(),
            jordanTarget:       CFG.JORDAN_PLAYER_TARGET,
            avgPing:            this.avgPing(),
            bestPing:           this.bestPing,
