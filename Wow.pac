//  SECTION 3: FPS MONITOR — Real-Time
 ════════════════════════════════════════════════════════

var FPS_MONITOR = {
    frameHistory:       [],
    jitterHistory:      [],
    maxFrameHistory:    200,
    maxJitterHistory:   50,
    currentFPS:         0,
    avgFPS:             0,
    minFPS:             999,
    maxFPS:             0,
    droppedFrames:      0,
    totalFrames:        0,
    peakFPS:            0,
    stabilityScore:     100,
    lastRecordTime:     0,

    // Record a network-correlated frame
    record: function(latencyMs, mode) {
        var fps       = FPS_ENGINE.pingToFPS(latencyMs);
        var frameTime = 1000 / fps;
        var ts        = now();

        var entry = {
            time:      ts,
            latency:   latencyMs,
            fps:       fps,
            frameTime: frameTime,
            mode:      mode,
            dropped:   fps < CFG.MINIMUM_FPS
terHistory
        };

        if (entry.dropped) this.droppedFrames++;
        this.totalFrames++;

        if (fps > this.peakFPS)  this.peakFPS = fps;
        if (fps < this.minFPS)   this.minFPS  = fps;
        if (fps > this.maxFPS)   this.maxFPS  = fps;

        this.currentFPS = fps;

        if (this.frameHistory.length >= this.maxFrameHistory) {
            this.frameHistory.shift();
        }
        this.frameHistory.push(entry);

        // Calculate rolling avg
        var sum   = 0;
        var count = this.frameHistory.length;
        for (var i = 0; i < count; i++) {
            sum += this.frameHistory[i].fps;
        }
        this.avgFPS = count > 0 ? Math.round(sum / count) : 0;

        // Record jitter
        if (this.lastRecordTime > 0) {
            var jitter = Math.abs(latencyMs - (this.jitterHistory.length > 0
                ? this.ji
t[this.jitterHistory.length - 1].latency
                : latencyMs));

            if (this.jitterHistory.length >= this.maxJitterHistory) {
                this.jitterHistory.shift();
            }
            this.jitterHistory.push({ latency: latencyMs, jitter: jitter, time: ts });
        }
        this.lastRecordTime = ts;

        // Update stability score
        this.stabilityScore = this.calcStabilityScore();

        return fps;
    },

    // Calculate jitter
    getJitter: function() {
        var len = this.jitterHistory.length;
        if (len < 2) return 0;
        var sum = 0;
        for (var i = 0; i < len; i++) {
            sum += this.jitterHistory[i].jitter;
        }
        return Math.round((sum / len) * 10) / 10;
