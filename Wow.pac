        JITTER_MAX: 2.0
    },

    // QoS levels (6 levels)
    QOS: {
        GAME_REALTIME: { priority: 7, dscp: 46, tos: 0x18, name: "EF"   },
        GAME_CRITICAL: { priority: 6, dscp: 34, tos: 0x10, name: "AF41" },
        SOCIAL_HIGH:   { priority: 5, dscp: 26, tos: 0x08, name: "AF31" },
        SOCIAL_NORMAL: { priority: 4, dscp: 18, tos: 0x08, name: "AF21" },
        VOICE:         { priority: 3, dscp: 10, tos: 0x04, name: "AF11" },
        BACKGROUND:    { priority: 1, dscp: 8,  tos: 0x00, name: "CS1"  }
    },

    // Connection pools
    POOLS: {
        GAME:   { size: 20, keepalive: 10000, timeout: 3000  },
 && m.gameState === "IN_GAME") {
            return this.QOS.GA
        SOCIAL: { size: 15, keepalive: 15000, timeout: 5000  },
        AUTH:   { size: 5,  keepalive: 30000, timeout: 10000 },
        CDN:    { size: 2,  keepalive: 60000, timeout: 30000 }
    },

    // Convert ping to estimated FPS
    pingToFPS: function(pingMs) {
        if (pingMs <= 3)  return 144;
        if (pingMs <= 5)  return 120;
        if (pingMs <= 8)  return 90;
        if (pingMs <= 12) return 75;
        if (pingMs <= 18) return 60;
        if (pingMs <= 30) return 45;
        if (pingMs <= 50) return 30;
        return 15;
    },

    // Get QoS for mode
    getQoS: function(mode) {
        var m = MODES[mode];
        if (!m) return this.QOS.SOCIAL_NORMAL;

        if (m.fpsOptimize
dME_REALTIME;
        }
        if (m.priority >= 10 && m.gameState === "IN_GAME") {
            return this.QOS.GAME_CRITICAL;
        }
        if (m.socialPriority) {
            return this.QOS.SOCIAL_HIGH;
        }
        if (mode === "CHAT_VOICE") {
            return this.QOS.VOICE;
        }
        if (m.priority <= 2) {
            return this.QOS.BACKGROUND;
        }
        return this.QOS.SOCIAL_NORMAL;
    },

    // Get burst size for mode
    getBurst: function(mode) {
        var m = MODES[mode];
        if (!m) return 4;
        if (m.fpsOptimized  && CFG.HYPER_BURST_MODE)  return 32;
        if (m.ultraBurst    && CFG.ULTRA_BURST_MODE)   return 16;
        if (m.requiresBurst && CFG.BURST_MODE)         return 8;
        return 2;
    },

    // Get protocol for mode
Frame Analysis
// ═══════════════
    getProtocol: function(mode) {
        var m = MODES[mode];
        if (!m) return "TCP";
        if (m.fpsOptimized && m.gameState === "IN_GAME") return "UDP";
        if (mode === "CHAT_VOICE") return "UDP";
        return "TCP";
    },

    // Get recommended FPS from current ping
    getRecommendedFPS: function() {
        var ping = PING_ENGINE.avg(3);
        return this.pingToFPS(ping);
    },

    // Is 144fps achievable?
    is144Achievable: function() {
        return PING_ENGINE.avg(3) <= this.FPS_MAP["144"].maxPing;
    },

    // Is 120fps achievable?
    is120Achievable: function() {
        return PING_ENGINE.avg(3) <= this.FPS_MAP["120"].maxPing;
    }
};


