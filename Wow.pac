            successCount: 0,
            failCount:    0
        },
        UMNIAH: {
            active:       true,
            latency:      999,
            jitter:       999,
            loss:         0,
            bandwidth:    800,
            score:        0,
            healthy:      false,
            lastCheck:    0,
            successCount: 0,
            failCount:    0
        },
        JT: {
            active:       true,
            latency:      999,
            jitter:       999,
            loss:         0,
            bandwidth: 
   600,
            score:        0,
            healthy:      false,
            lastCheck:    0,
            successCount: 0,
            failCount:    0
        }
    },

    primaryCarrier:   "ORANGE",
    secondaryCarrier: "ZAIN",
    tertiaryCarrier:  "UMNIAH",

    // Score a path
    scorePath: function(latency, jitter, loss, bandwidth) {
        var score = 2000;
        if (latency <= 3)       score -= 0;
        else if (latency <= 6)  score -= 100;
        else if (latency <= 10) score -= 300;
        else if (latency <= 15) score -= 600;
        else if (latency <= 20) score -= 900;
        else                    score -= 1500;

        score -= jitter    * 30;
        score -= loss      * 100;
        score += bandwidth * 0.1;

        return Math.max(0, score);
    },

    // Update path metrics
    update: function(carrier, latency, jitter, loss) {
        var p = this.paths[carrier];
        if (!p) return;

        p.latency    = latency;
        p.jitter     = jitter  || 0;
        p.loss       = loss    || 0;
        p.lastCheck  = now();
        p.score      = this.scorePath(latency, p.jitter, p.loss, p.bandwidth);
        p.healthy    = (latency < 20 && p.jitter < 10 && p.loss < 5);

        if (p.healthy) p.successCount++;
        else           p.failCount++;

        this.reselect();
    },

    // Reselect best carriers
    reselect: function() {
        var scored = [];
        for (var carrier in this.paths) {
            var p = this.paths[carrier];
            if (p.active) {
                scored.push({ carrier: carrier, score: p.score });
            }
        }
        scored.sort(function(a, b) { return b.score - a.score; });

        this.primaryCarrier   = scored[0] ? scored[0].carrier : "ORANGE";
        this.secondaryCarrier = scored[1] ? scored[1].carrier : "ZAIN";
        this.tertiaryCarrier  = scored[2] ? scored[2].carrier : "UMNIAH";
    },

    // Get best proxy name for a mode
    getBest: function(mode, needFPS, needSocial) {
        var c = this.primaryCarrier;
        var m = MODES[mode];

        if (needFPS || (m && m.fpsOptimized)) {
            if (c === "ORANGE") return "FPS_ORANGE_1";
            if (c === "ZAIN")   return "FPS_ZAIN_1";
            return "ORANGE_ULTRA_1";
        }

        if (needSocial || (m && m.socialPriority)) {
            if (c === "ORANGE") return "SOCIAL_ORANGE_1";
            if (c === "ZAIN")   return "SOCIAL_ZAIN_1";
   
         return "ORANGE_ULTRA_1";
        }

        if (c === "ORANGE") return "ORANGE_ULTRA_1";
        if (c === "ZAIN")   return "ZAIN_ULTRA_1";
        if (c === "UMNIAH") return "UMNIAH_ULTRA_1";
        return "ORANGE_ULTRA_1";
    },

    // Get backup proxy name
    getBackup: function(mode, needFPS, needSocial) {
        var c = this.secondaryCarrier;
        var m = MODES[mode];

        if (needFPS || (m && m.fpsOptimized)) {
            if (c === "ZAIN")   return "FPS_ZAIN_1";
            if (c === "ORANGE") return "FPS_ORANGE_1";
            return "ZAIN_ULTRA_1";
        }

        if (needSocial || (m && m.socialPriority)) {
            if (c === "ZAIN")   return "SOCIAL_ZAIN_1";
            if (c === "ORANGE") return "SOCIAL_ORANGE_1";
            return "ZAIN_ULTRA_1";
        }

        if (c === "ZAIN")   return "ZAIN_ULTRA_1";
        if (c === "ORANGE") return "ORANGE_ULTRA_1";
        if (c === "UMNIAH") return "UMNIAH_ULTRA_1";
        return "ZAIN_ULTRA_1";
    },

    // Status report
    getStatus: function() {
        return {
            primary:   this.primaryCarrier,
            secondary: this.secondaryCarrier,
            tertiary:  this.tertiaryCarrier,
            paths:     this.paths
t    = FPS
        };
    }
};


