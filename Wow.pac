        var dropRate = this.totalFrames > 0
            ? (this.droppedFrames / this.totalFrames) * 100
            : 0;

        score -= jitter  * 8;
        score -= dropRate * 3;

        if (this.avgFPS >= 144) score += 10;
        else if (this.avgFPS >= 120) score += 5;
        else if (this.avgFPS < 60) score -= 20;

        return Math.max(0, Math.min(100, Math.round(score)));
    },

    // Get frame stability label
    getStability: function() {
