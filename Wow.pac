//  SECTION 7: PACKET OPTIMIZER
// ═══════════════════════════════════════════════════════════════════════

var PACKET_OPT = {
    stats: {
        sent:         0,
        prioritized:  0,
        dropped:      0,
        udpSent:      0,
        tcpSent:      0,
        avgQueueMs:   0,
        totalQueueMs: 0
    },

    // Get priority level
    getPriority: function(mode) {
        var m = MODES[mode];
        if (!m) return "NORMAL";
        if (m.fpsOptimized && m.gameState === "IN_GAME") return "GAME_REALTIME";
        if (m.priority >= 10 && m.gameState === "IN_GAME") return "GAME_CRITICAL";
        if (m.socialPriority && m.priority >= 10)  return "SOCIAL_HIGH";
        if (m.socialPriority)                       return "SOCIAL_NORMAL";
        if (mode === "CHAT_VOICE")                  return "VOICE";
        return "BACKGROUND";
    },

    // Process request
    process: function(host, mode, port) {
        var t0 = now();
        this.stats.sent++;

        var priority = this.getPriority(mode);
        var qos      = FPS_ENGINE.getQoS(mode);
        var protocol = FPS_ENGINE.getProtocol(mode);
        var bur
s_ENGINE.getBurst(mode);

        if (protocol === "UDP") this.stats.udpSent++;
        else                    this.stats.tcpSent++;

        this.stats.prioritized++;

        var queueMs = now() - t0;
        this.stats.totalQueueMs += queueMs;
        this.stats.avgQueueMs    = Math.round(
            this.stats.totalQueueMs / this.stats.sent
        );

        return {
            priority:   priority,
            qos:        qos,
            protocol:   protocol,
            burst:      burst,
            tcpNoDelay: CFG.FPS_TCP_NODELAY,
            quickAck:   CFG.FPS_QUICKACK,
            queueMs:    queueMs
        };
    }
};


