// ═══════════════════════════════════════════════════════════════════════

var PING_ENGINE = {
    history:     [],
    maxHistory:  60,
    modeStats:   {},
    regionStats: {},

    socialStats: { count: 0, total: 0, min: 999, max: 0, avg: 0 },
    fpsStats:    { count: 0, total: 0, min: 999, max: 0, avg: 0 },

    // Ping forecast (simple linear regression)
    forecast: {
        samples:  [],
        maxSamples: 10,

        add: function(ping) {
            if (this.samples.length >= this.maxSamples) this.samples.shift();
            this.samples.push({ ping: ping, time: now() });
        },

        predict: function() {
            var len = this.samples.length;
            if (len < 3) return null;

            var sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
            var t0 = this.samples[0].time;

            for (var i = 0; i < len; i++) {
                var x = (this.samples[i].time - t0) / 1000;
                var y = this.samples[i].ping;
                sumX  += x;
                sumY  += y;
                sumXY += x * y;
                sumX2 += x * x;
            }

            var denom = len * sumX2 - sumX * sumX;
            if (denom === 0) return this.samples[len - 1].ping;

            var slope     = (len * sumXY - sumX * sumY) / denom;
            var intercept = (sumY - slope * sumX) / len;
            var nextX     = ((now() - t0) / 1000) + 5;

            return Math.max(1, Math.round(intercept + slope * nextX));
        }
    },

    record: function(ms, mode, host, region) {
        var est = Math.max(2, Math.round(ms * 0.35 + 1.5));

        var m       = MODES[mode];
        var isSocial = m && m.socialPriority;
        var isFPS    = m && m.fpsOptimized;

        var entry = {
            raw:       ms,
            estimated: est,
            mode:      mode,
            host:      host,
            region:    region,
            isSocial:  isSocial,
            isFPS:     isFPS,
 
 this.maxHistory) this.history.shift();
        this.history.push(entry);

        this.forecast.add(est);

        // Social stats
        if (isSocial) {
            this.socialStats.count++;
            this.socialStats.total += est;
            this.socialStats.min    = Math.min(this.socialStats.min, est);
            this.socialStats.max    = Math.max(this.socialStats.max, est);
            this.socialStats.avg    = Math.round(
                this.socialStats.total / this.socialStats.count
            );
        }

        // FPS stats
        if (isFPS) {
            this.fpsStats.count++;
            this.fpsStats.total += est;
            this.fpsStats.min    = Math.min(this.fpsStats.min, est);
            this.fpsStats.max    = Math.max(this.fpsStats.max, est);
            this.fpsStats.avg    = Math.round(
                this.fpsStats.total / this.fpsStats.count
            );

            FPS_MONITOR.record(est, mode);
        }

        // Mode stats
        if (!this.modeStats[mode]) {
            this.modeStats[mode] = {
                count: 0, total: 0, min: 999,
                max: 0, avg: 0, recent: []
            };
        }
        var ms2 = this.modeStats[mode];
        ms2.count++;
        ms2.total += est;
        ms2.min    = Math.min(ms2.min, est);
        ms2.max    = Math.max(ms2.max, est);
        ms2.avg    = Math.round(ms2.total / ms2.count);
        if (ms2.recent.length >= 8) ms2.recent.shift();
        ms2.recent.push(est);

        // Region stats
        if (region) {
            if (!this.regionStats[region]) {
                this.regionStats[region] = { count: 0, total: 0, avg: 0 };
            }
            var rs = this.regionStats[region];
            rs.count++;
            rs.total += est;
            rs.avg    = Math.round(rs.total / rs.count);
        }

        SESSION.recordPing(est, mode);

        return est;
    },

    current: function() {
        var len = this.history.length;
        return len > 0 ? this.history[len - 1].estimated : 999;
ty: fu
    },

    avg: function(samples) {
        samples = samples || 5;
        var len = this.history.length;
        if (len === 0) return 999;
        var start = Math.max(0, len - samples);
        var sum = 0; var count = 0;
        for (var i = start; i < len; i++) {
            sum += this.history[i].estimated;
            count++;
        }
        return count > 0 ? Math.round(sum / count) : 999;
    },

    best: function() {
        if (this.history.length === 0) return 999;
        var best = 999;
        for (var i = 0; i < this.history.length; i++) {
            if (this.history[i].estimated < best) {
                best = this.history[i].estimated;
            }
        }
        return best;
    },

    worst: function() {
        if (this.history.length === 0) return 0;
        var worst = 0;
        for (var i = 0; i < this.history.length; i++) {
            if (this.history[i].estimated > worst) {
                worst = this.history[i].estimated;
            }
        }
        return worst;
    },

    trend: function() {
        var len = this.history.length;
        if (len < 8) return "STABLE";
        var recent = this.avg(3);
        var older  = this.avg(10);
        var ratio  = older > 0 ? recent / older : 1;
        if (ratio < 0.65)  return "FAST_IMPROVING";
        if (ratio < 0.80)  return "IMPROVING";
        if (ratio > 1.60)  return "FAST_DEGRADING";
        if (ratio > 1.30)  return "DEGRADING";
        return "STABLE";
    },

    predicted: function() {
        return this.forecast.predict();
    },

    variance: function() {
        var len = this.history.length;
        if (len < 3) return 0;
        var avg = this.avg();
        var sumSq = 0;
        var start = Math.max(0, len - 12);
        var count = 0;
        for (var i = start; i < len; i++) {
            var diff = this.history[i].estimated - avg;
            sumSq += diff * diff;
            count++;
        }
        return count > 0 ? Math.round(Math.sqrt(sumSq / count)) : 0;
    },

    stabil
inction() {
        var v = this.variance();
        if (v <= 1)  return "ULTRA_STABLE";
        if (v <= 3)  return "VERY_STABLE";
        if (v <= 6)  return "STABLE";
        if (v <= 12) return "MODERATE";
        return "UNSTABLE";
    },

    quality: function(mode) {
        var m = MODES[mode];
        if (!m) return "UNKNOWN";
        var c = this.avg(3);
        var t = m.targetPing;
        var x = m.maxPing;
        if (c <= t)          return "ULTRA";
        if (c <= t * 1.2)    return "EXCELLENT";
        if (c <= t * 1.5)    return "VERY_GOOD";
        if (c <= x)          return "GOOD";
        if (c <= x * 1.2)    return "ACCEPTABLE";
        return "POOR";
    },

    isHealthy: function(mode) {
        var m = MODES[mode];
        if (!m) return true;
        return this.avg(3) <= m.maxPing * 1.1;
    },

    needsOptimization: function() {
        var avg = this.avg(3);
        var t   = this.trend();
        return avg > CFG.MAX_ACCEPTABLE_PING ||
               t === "DEGRADING" || t === "FAST_DEGRADING";
    },

    isCritical: function() {
        return this.avg(2) > CFG.CRITICAL_PING;
    },

    isEmergency: function() {
        return this.avg(2) > CFG.EMERGENCY_PING;
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 14: DEEP ML ENGINE — Neural Route Prediction
// ═══════════════════════════════════════════════════════════════════════

var ML_ENGINE = {
    patterns:       {},
    socialPatterns: {},
    fpsPatterns:    {},
    jordanPatterns: {},
    learningData:   [],
    anomalyData:    [],
    selfWeights:    {
        ping:       0.30,
        region:     0.25,
        carrier:    0.20,
        fps:        0.15,
        social:     0.10
    },

    // Record successful route
    recordSuccess: function(mode, route, ping, region, isSocial, isFPS) {
        var key = mode + "::" + (region || "UNKNOWN");

        if (!this.patterns[key]) {
            this.patterns[key] = {
                routes:       {},
                totalSamples: 0,
, bestPing: 999, samples: 0
       
                bestRoute:    null,
                bestPing:     999,
                lastUpdate:   now()
            };
        }

        var p = this.patterns[key];

        if (!p.routes[route]) {
            p.routes[route] = {
                uses:      0,
                totalPing: 0,
                avgPing:   0,
                minPing:   999,
                wins:      0
            };
        }

        var r = p.routes[route];
        r.uses++;
        r.totalPing += ping;
        r.avgPing    = Math.round(r.totalPing / r.uses);
        r.minPing    = Math.min(r.minPing, ping);

        var m = MODES[mode];
        if (ping <= (m ? m.targetPing : 10)) r.wins++;

        p.totalSamples++;
        p.lastUpdate = now();

        if (r.avgPing < p.bestPing && r.uses >= CFG.ML_MIN_SAMPLES) {
            p.bestPing  = r.avgPing;
            p.bestRoute = route;
        }

        // Social pattern
        if (isSocial) {
            if (!this.socialPatterns[mode]) {
                this.socialPatterns[mode] = {
                    bestRoute: null, bestPing: 999, samples: 0
                };
            }
            var sp = this.socialPatterns[mode];
            sp.samples++;
            if (ping < sp.bestPing) {
                sp.bestPing  = ping;
                sp.bestRoute = route;
            }
        }

        // FPS pattern
        if (isFPS) {
            var estimatedFPS = FPS_ENGINE.pingToFPS(ping);
            if (!this.fpsPatterns[mode]) {
                this.fpsPatterns[mode] = {
                    bestRoute: null, bestPing: 999,
                    bestFPS: 0, samples: 0
                };
            }
            var fp = this.fpsPatterns[mode];
            fp.samples++;
            if (ping < fp.bestPing) {
                fp.bestPing  = ping;
                fp.bestFPS   = estimatedFPS;
                fp.bestRoute = route;
            }
        }

        // Jordan pattern
        if (!this.jordanPatterns[mode]) {
            this.jordanPatterns[mode] = {
                bestRoute: nul
l     };
        }
        var jp = this.jordanPatterns[mode];
        jp.samples++;
        if (ping < jp.bestPing) {
            jp.bestPing  = ping;
            jp.bestRoute = route;
        }

        // Learning data
        if (this.learningData.length >= CFG.ML_MAX_SAMPLES) {
            this.learningData.shift();
        }
        this.learningData.push({
            mode:     mode,
            route:    route,
            ping:     ping,
            region:   region,
            isSocial: isSocial || false,
            isFPS:    isFPS    || false,
            time:     now(),
            success:  ping <= (MODES[mode] ? MODES[mode].maxPing : 20)
        });

        // Self-optimize weights
        this.optimizeWeights();
    },

    // Predict best route
    predict: function(mode, region, isSocial, isFPS) {
        if (!CFG.ENABLE_ML) return null;

        // FPS pattern (highest priority for FPS modes)
        if (isFPS && this.fpsPatterns[mode]) {
            var fp = this.fpsPatterns[mode];
            if (fp.samples >= CFG.ML_MIN_SAMPLES) return fp.bestRoute;
        }

        // Social pattern
        if (isSocial && this.socialPatterns[mode]) {
            var sp = this.socialPatterns[mode];
            if (sp.samples >= CFG.ML_MIN_SAMPLES) return sp.bestRoute;
        }

        // Jordan pattern
        if (this.jordanPatterns[mode]) {
            var jp = this.jordanPatterns[mode];
            if (jp.samples >= CFG.ML_MIN_SAMPLES) return jp.bestRoute;
        }

        // General pattern
        var key = mode + "::" + (region || "UNKNOWN");
        var p   = this.patterns[key];
        if (p && p.totalSamples >= CFG.ML_MIN_SAMPLES) {
            return p.bestRoute;
        }

        return null;
    },

    // Get confidence level (0-100)
    confidence: function(mode, region) {
        var key = mode + "::" + (region || "UNKNOWN");
        var p   = this.patterns[key];
        if (!p) return 0;
        var s = p.totalSamples;
        if (s >= 50)  return 100;
        if (s >= 30)  return 95;
        if (s >= 20)  return 85;
        if (s >= 10)  return 70;
═══════════════════════════════
        if (s >= 5)   return 50;
        return 20;
    },

    // Detect anomaly in recent pings
    detectAnomaly: function() {
        if (!CFG.ENABLE_ANOMALY_DETECTION) return false;
        var avg      = PING_ENGINE.avg(5);
        var variance = PING_ENGINE.variance();
        var trend    = PING_ENGINE.trend();

        var isAnomaly = (
            PING_ENGINE.isEmergency() ||
            variance > 20 ||
            trend === "FAST_DEGRADING"
        );

        if (isAnomaly) {
            SESSION.recordAnomaly();
            if (this.anomalyData.length >= 20) this.anomalyData.shift();
            this.anomalyData.push({
                avg: avg, variance: variance,
                trend: trend, time: now()
            });
        }

        return isAnomaly;
    },

    // Self-optimize scoring weights
    optimizeWeights: function() {
        if (!CFG.ENABLE_SELF_OPTIMIZATION) return;
        if (this.learningData.length < 20) return;

        var recent = this.learningData.slice(-20);
        var successRate = 0;
        for (var i = 0; i < recent.length; i++) {
            if (recent[i].success) successRate++;
        }
        successRate /= recent.length;

        var lr = CFG.ML_LEARNING_RATE;

        if (successRate > 0.9) {
            this.selfWeights.ping    = Math.min(0.40, this.selfWeights.ping + lr * 0.01);
            this.selfWeights.region  = Math.min(0.35, this.selfWeights.region + lr * 0.01);
        } else if (successRate < 0.7) {
            this.selfWeights.ping    = Math.max(0.20, this.selfWeights.ping - lr * 0.01);
            this.selfWeights.fps     = Math.min(0.25, this.selfWeights.fps + lr * 0.01);
        }

        // Normalize
        var total = 0;
        for (var k in this.selfWeights) { total += this.selfWeights[k]; }
        for (var k2 in this.selfWeights) {
            this.selfWeights[k2] = Math.round((this.selfWeights[k2] / total) * 100) / 100;
        }
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 15: DNS CACHE — FPS + Social Priority
// ═══════════════════════════════════════
═
var DNS_CACHE  = {};
var DNS_QUEUE  = [];
var DNS_NEG    = {};  // Negative cache (failed lookups)

var DNS_STATS = {
    hits:          0,
    misses:        0,
    negHits:       0,
    totalTime:     0,
    avgTime:       0,
    socialHits:    0,
    fpsHits:       0,
    cacheEvictions: 0
};

var DNS_PREFETCH_LIST = [
    "social.pubgmobile.com",
    "friend.pubgmobile.com",
    "lobby.pubgmobile.com",
    "matchmaking.pubgmobile.com",
    "gamesvr.pubgmobile.com",
    "battle.pubgmobile.com",
    "auth.pubgmobile.com"
];

function fastDNS(host) {
    var h        = host.toLowerCase();
    var isSocial = containsAny(h, SOCIAL_KEYS);
    var isFPS    = containsAny(h, FPS_KEYS);

    // Negative cache check
    if (CFG.DNS_NEGATIVE_CACHE && DNS_NEG[host]) {
        var negAge = now() - DNS_NEG[host];
        if (negAge < 60000) {
            DNS_STATS.negHits++;
            return { ip: null, dt: 0, mode: "CLASSIC",
                     region: { region: "UNKNOWN", confidence: 0 },
                     quality: "UNACCEPTABLE", ok: false,
                     socialEndpoint: false, fpsEndpoint: false, t: now() };
        }
        delete DNS_NEG[host];
    }

    // Cache hit
    var cached = DNS_CACHE[host];
    if (cached) {
        var age    = now() - cached.t;
        var ttl    = (isFPS || isSocial)
                     ? CFG.DNS_CACHE_TTL * 0.8
                     : CFG.DNS_CACHE_TTL;
        if (age < ttl) {
            DNS_STATS.hits++;
            if (isSocial) DNS_STATS.socialHits++;
            if (isFPS)    DNS_STATS.fpsHits++;
            cached.hitCount = (cached.hitCount || 0) + 1;
            cached.lastHit  = now();
            return cached;
        }
    }

    // Cache miss — resolve
    DNS_STATS.misses++;
    var t0 = now();
    var ip = dnsResolve(host);
    var dt = now() - t0;

    DNS_STATS.totalTime += dt;
    DNS_STATS.avgTime    = Math.round(DNS_STATS.totalTime / DNS_STATS.misses);

    // Negative caching
    if (!ip) {
        DNS_NEG[host] = now();
        return { ip: null, dt: dt, mode: "CLASSIC",
                 region: { region: "UNKNOWN", confidence: 0 },
                 quality: "UNACCEPTABLE", ok: false,
{
    for (var name in PROXY) {
        var p = PROXY[name];
        HE
                 socialEndpoint: false, fpsEndpoint: false, t: now() };
    }

    var mode    = detectMode(host);
    var region  = detectRegion(host, ip);
    var quality = assessServerQuality(ip, host, mode);

    var result = {
        ip:             ip,
        dt:             dt,
        mode:           mode,
        region:         region,
        quality:        quality,
        socialEndpoint: isSocial,
        fpsEndpoint:    isFPS,
        ok:             true,
        t:              now(),
        hitCount:       0,
        lastHit:        now()
    };

    // Cache eviction — keep FPS and Social entries longer
    if (DNS_QUEUE.length >= CFG.DNS_CACHE_MAX) {
        var evicted = false;
        for (var i = 0; i < DNS_QUEUE.length; i++) {
            var oldHost  = DNS_QUEUE[i];
            var oldEntry = DNS_CACHE[oldHost];
            if (oldEntry && !oldEntry.socialEndpoint && !oldEntry.fpsEndpoint) {
                DNS_QUEUE.splice(i, 1);
                delete DNS_CACHE[oldHost];
                DNS_STATS.cacheEvictions++;
                evicted = true;
                break;
            }
        }
        if (!evicted) {
            var oldest = DNS_QUEUE.shift();
            delete DNS_CACHE[oldest];
            DNS_STATS.cacheEvictions++;
        }
    }

    DNS_CACHE[host] = result;
    DNS_QUEUE.push(host);

    PING_ENGINE.record(dt, mode, host, region.region);

    if (isSocial) SESSION.socialRequests++;
    if (isFPS)    SESSION.fpsRequests++;

    // Update multipath with new data
    if (ip && GUARD.isJordan(ip)) {
        var c = getCarrier(ip);
        MULTIPATH.update(c, PING_ENGINE.avg(3), PING_ENGINE.variance(), 0);
    }

    return result;
}

function prefetchDNS() {
    if (!CFG.DNS_PREFETCH) return;
    for (var i = 0; i < DNS_PREFETCH_LIST.length; i++) {
        var h = DNS_PREFETCH_LIST[i];
        if (!DNS_CACHE[h]) {
            try { fastDNS(h); } catch(e) {}
        }
    }
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 16: PROXY HEALTH MONITOR
// ═══════════════════════════════════════════════════════════════════════

var HEALTH = {};

function initHealth()
 ALTH[name] = {
            uses:        0,
            successes:   0,
            failures:    0,
            lastUse:     0,
            lastSuccess: 0,
            load:        0,
            status:      "READY",
            avgPing:     (p && p.targetPing) ? p.targetPing : 10,
            recentPings: [],
            uptime:      100,
            score:       100,
            socialUses:  0,
            fpsUses:     0,
            lobbyUses:   0,
            streakGood:  0,
            streakBad:   0
        };
    }
}

function updateHealth(name, success, ping, isSocial, isFPS, isLobby) {
    if (!HEALTH[name]) return;
    var h = HEALTH[name];
    var p = PROXY[name];

    h.uses++;
    h.lastUse = now();

    if (isSocial) h.socialUses++;
    if (isFPS)    h.fpsUses++;
    if (isLobby)  h.lobbyUses++;

    if (success) {
        h.successes++;
        h.lastSuccess = now();
        h.streakGood++;
        h.streakBad   = 0;
    } else {
        h.failures++;
        h.streakBad++;
        h.streakGood  = 0;
    }

    if (ping) {
        if (h.recentPings.length >= 12) h.recentPings.shift();
        h.recentPings.push(ping);
        var sum = 0;
        for (var i = 0; i < h.recentPings.length; i++) sum += h.recentPings[i];
        h.avgPing = Math.round(sum / h.recentPings.length);
    }

    if (p && p.capacity) {
        h.load = Math.min(100, Math.round((h.uses / p.capacity) * 100));
    }

    h.uptime = h.uses > 0 ? Math.round((h.successes / h.uses) * 100) : 100;
    h.score  = calcHealthScore(h, p);

    if      (h.score >= 95) h.status = "SUPREME";
    else if (h.score >= 85) h.status = "EXCELLENT";
    else if (h.score >= 72) h.status = "GOOD";
    else if (h.score >= 55) h.status = "FAIR";
    else if (h.score >= 35) h.status = "DEGRADED";
    else if (h.score >= 15) h.status = "POOR";
    else                    h.status = "CRITICAL";
}

function calcHealthScore(health, proxy) {
    var score = 100;

    // Uptime
    score -= (100 - health.uptime) * 0.5;

    // Load
    if      (health.load > 95) score -= 25;
    else if (health.load > 85) score -= 15;
    else if (health.load > 70) score -= 8;
    else if (health.load > 55) score -= 3;

    // Ping vs target
    if (proxy && proxy.targetPing && health.avgPing) {
  }

    candidates.sort(function(a, b) { return b.sco
        var ratio = health.avgPing / proxy.targetPing;
        if      (ratio <= 0.9) score += 10;
        else if (ratio <= 1.1) score += 5;
        else if (ratio <= 1.4) score -= 10;
        else if (ratio <= 1.8) score -= 22;
        else                   score -= 35;
    }

    // Streak bonuses/penalties
    score += Math.min(15, health.streakGood * 1.5);
    score -= Math.min(20, health.streakBad  * 5);

    // Feature bonuses
    if (proxy) {
        if (proxy.fpsOptimized    && health.fpsUses    > 5) score += 8;
        if (proxy.socialOptimized && health.socialUses > 5) score += 8;
        if (proxy.hyperBurst)                               score += 5;
    }

    return Math.max(0, Math.min(100, Math.round(score)));
}

function getHealth(name) {
    return HEALTH[name] || {
        status: "UNKNOWN", load: 100, score: 0,
        avgPing: 999, streakGood: 0, streakBad: 0
    };
}

// Get best proxies with multi-criteria filtering
function getBestProxies(tier, carrier, count, opts) {
    opts = opts || {};
    var candidates = [];

    for (var name in PROXY) {
        var p = PROXY[name];
        var h = HEALTH[name];

        if (!p || !h) continue;

        // Tier filter
        if (tier !== undefined && p.tier !== tier) continue;

        // Carrier filter
        if (opts.carrier && p.carrier !== opts.carrier) continue;
        if (carrier      && p.carrier !== carrier)      continue;

        // Status filter
        if (h.status === "CRITICAL") continue;
        if (h.status === "POOR" && !opts.allowPoor) continue;

        // Feature filters
        if (opts.socialOptimized && !p.socialOptimized) continue;
        if (opts.fpsOptimized    && !p.fpsOptimized)    continue;
        if (opts.lobbyDedicated  && !p.lobbyDedicated)  continue;
        if (opts.fpsDedicated    && !p.fpsDedicated)    continue;
        if (opts.socialDedicated && !p.socialDedicated) continue;

        // Burst filters
        if (opts.hyperBurst  && !p.hyperBurst)  continue;
        if (opts.ultraBurst  && !p.ultraBurst)  continue;
        if (opts.burstCapable && !p.burstCapable) continue;

        candidates.push({
            name:  name,
            proxy: p,
            health: h,
            score: calcProxyScore(p, h, opts)
        });
 
 re - a.score; });

    count = count || candidates.length;
    var results = [];
    for (var i = 0; i < Math.min(count, candidates.length); i++) {
        results.push(candidates[i].name);
    }

    return results;
}

function calcProxyScore(proxy, health, opts) {
    var score = 0;

    score += (proxy.priority  / 100) * 45;
    score += (health.score    / 100) * 30;

    if (proxy.targetPing && health.avgPing) {
        var ratio = health.avgPing / proxy.targetPing;
        if      (ratio <= 0.9) score += 22;
        else if (ratio <= 1.1) score += 18;
        else if (ratio <= 1.3) score += 12;
        else if (ratio <= 1.6) score += 5;
        else                   score -= 10;
    }

    if      (health.load <= 40) score += 10;
    else if (health.load <= 60) score += 7;
    else if (health.load <= 75) score += 4;
    else if (health.load <= 90) score += 1;

    // Feature bonuses
    if (opts.fpsOptimized    && proxy.fpsOptimized)    score += 30;
    if (opts.fpsDedicated    && proxy.fpsDedicated)    score += 25;
    if (opts.socialOptimized && proxy.socialOptimized) score += 25;
    if (opts.socialDedicated && proxy.socialDedicated) score += 20;
    if (opts.lobbyDedicated  && proxy.lobbyDedicated)  score += 20;
    if (opts.hyperBurst      && proxy.hyperBurst)      score += 15;
    if (opts.ultraBurst      && proxy.ultraBurst)      score += 10;
    if (opts.udpPriority     && proxy.udpPriority)     score += 12;
    if (opts.earlyData       && proxy.earlyData)       score += 8;

    // Streak bonus
    score += Math.min(10, health.streakGood * 2);

    return Math.round(score);
}

initHealth();


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 17: GUARD SYSTEM — Triple Jordan Verification
// ═══════════════════════════════════════════════════════════════════════

var GUARD = {
    trustedHosts:  {},
    blockedHosts:  {},
    trustedIPs:    {},

    // Primary Jordan check (IP range)
    isJordanIP: function(ip) {
        if (!ip || !isIPv4(ip)) return false;
        return inRanges(ip, JO_NETS);
    },

    // Secondary Jordan check (carrier)
    isJordanCarrier: function(ip) {
        var c = getCarrier(ip);
        return (c === "ORANGE" || c === "ZAIN" ||
                c === "UMNIAH" || c === "JT");
    },

    // Triple verification
             return false;
 
    isJordan: function(ip) {
        if (!ip || !isIPv4(ip)) return false;
        if (this.trustedIPs[ip]) return true;

        var primary   = this.isJordanIP(ip);
        var secondary = this.isJordanCarrier(ip);

        if (primary && secondary) {
            this.trustedIPs[ip] = true;
            return true;
        }

        return primary;
    },

    // Get Jordan city
    getJordanCity: function(ip) {
        if (!this.isJordan(ip)) return null;
        for (var city in JO_CITIES) {
            if (inRanges(ip, JO_CITIES[city])) return city;
        }
        return "JORDAN_OTHER";
    },

    // Check destination
    checkDestination: function(ip, host, mode) {
        if (!ip) return true;

        if (ip.indexOf(":") !== -1) {
            if (CFG.JORDAN_ONLY_MODE || CFG.BLOCK_INTERNATIONAL) {
                this.block(host, "IPv6 blocked");
                return false;
            }
        }

        if (this.trustedHosts[host]) return true;
        if (this.blockedHosts[host]) return false;

        if (this.isJordan(ip)) {
            var city    = this.getJordanCity(ip);
            var carrier = getCarrier(ip);

            this.trustedHosts[host] = {
                ip: ip, city: city,
                carrier: carrier, since: now()
            };

            SESSION.jordanHits++;
            SESSION.jordanPlayersFound++;
            JORDAN_POOL.recordJordanPlayer(ip);

            var m = MODES[mode];
            if (m && m.socialPriority) {
                if (mode === "FRIEND_DISCOVERY") SESSION.recordSocial("FRIEND");
                if (mode === "CREW_RECRUITMENT") SESSION.recordSocial("CREW");
                if (mode === "LOBBY" || mode === "MATCHMAKING") {
                    SESSION.recordSocial("LOBBY");
                }
            }

            return true;
        }

        // Non-Jordan handling
        SESSION.foreignHits++;
        JORDAN_POOL.recordForeignPlayer();

        var mv = MODES[mode];

        if (mv) {
            if ((mv.socialPriority && CFG.FORCE_JORDAN_SOCIAL) ||
                (mv.fpsOptimized   && CFG.FORCE_JORDAN_FPS)    ||
                (mv.lobbyDedicated && CFG.FORCE_JORDAN_LOBBY)  ||
                (mv.priority >= 10 && CFG.FORCE_JORDAN_MATCHMAKING)) {
                this.block(host, "Requires Jordan IP: " + mode);
  
            }
        }

        if (CFG.JORDAN_ONLY_MODE)    { this.block(host, "Jordan-only"); return false; }
        if (CFG.BLOCK_INTERNATIONAL) { this.block(host, "Intl blocked"); return false; }

        return true;
    },

    block: function(host, reason) {
        this.blockedHosts[host] = { reason: reason, time: now() };
        SESSION.blockedHits++;
    },

    // Build proxy chain
    buildChain: function(names, mode, opts) {
        var chain = [];
        var used  = {};
        opts = opts || {};

        var m       = MODES[mode];
        var isFPS   = m && m.fpsOptimized;
        var isSocial = m && m.socialPriority;
        var isLobby  = m && m.lobbyDedicated;

        for (var i = 0; i < names.length && chain.length < CFG.MAX_PROXY_CHAIN; i++) {
            var name = names[i];
            if (!name || used[name] || !PROXY[name]) continue;

            var p = PROXY[name];
            var h = getHealth(name);

            if (h.status === "CRITICAL") continue;
            if (opts.hyperBurst  && !p.hyperBurst)      continue;
            if (opts.ultraBurst  && !p.ultraBurst)      continue;
            if (opts.fpsOpt      && !p.fpsOptimized)    continue;
            if (opts.socialOpt   && !p.socialOptimized) continue;
            if (opts.lobbyOpt    && !p.lobbyDedicated)  continue;
            if (opts.fpsDed      && !p.fpsDedicated)    continue;
            if (opts.socialDed   && !p.socialDedicated) continue;
            if (opts.maxTier !== undefined && p.tier > opts.maxTier) continue;

            chain.push("PROXY " + p.ip + ":" + p.port);
            used[name] = true;

            updateHealth(name, true, p.targetPing, isSocial, isFPS, isLobby);
        }

        if (chain.length === 0) {
            return CFG.FAIL_CLOSED ? BLOOD.BLK : BLOOD.DIR;
        }

        var result = chain.join("; ");
        result += CFG.FAIL_CLOSED ? ("; " + BLOOD.BLK) : "; DIRECT";

        return result;
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 18: STICKY ROUTING — Quantum Adaptive
// ═══════════════════════════════════════════════════════════════════════

var STICKY = {};
var STICKY_STATS = {
    sets:      0,
    hits:      0,
    misses:    0,
    evictions: 0,
    extends:   0
};

function stickyGet(key) {
    var e = STICKY[key];
    if (!e) { STICKY_STATS.misses++; return null; }

    var age    = now() - e.created;
    var maxAge = e.ttl || CFG.STICKY_TTL;

    if (age > maxAge) {
        delete STICKY[key];
        STICKY_STATS.evictions++;
        STICKY_STATS.misses++;
        return null;
    }

    e.hits    = (e.hits || 0) + 1;
    e.lastHit = now();
    STICKY_STATS.hits++;

    return e.value;
}

function stickySet(key, value, ttl) {
    STICKY[key] = {
        value:   value,
        created: now(),
        ttl:     ttl || CFG.STICKY_TTL,
        hits:    0,
        lastHit: now()
    };
    STICKY_STATS.sets++;
}

function stickyClear(key)   { delete STICKY[key]; }

function stickyExtend(key, extra) {
    if (STICKY[key]) {
        STICKY[key].ttl += (extra || CFG.STICKY_EXTEND_ON_GOOD);
        STICKY_STATS.extends++;
    }
}

function stickyRefresh(key) {
    if (STICKY[key]) STICKY[key].created = now();
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 19: REGION + MODE DETECTION
// ═══════════════════════════════════════════════════════════════════════

function detectRegion(host, ip) {
    var h = host ? host.toLowerCase() : "";

    // IP-based (most reliable)
    if (ip && GUARD.isJordan(ip)) {
        var city = GUARD.getJordanCity(ip);
        return {
            region:     "JORDAN",
            city:       city,
            confidence: 100,
            carrier:    getCarrier(ip)
        };
    }

    // DNS-based Jordan patterns
    var jordanPatterns = [
        ".jo", "jordan", "amman", "irbid", "zarqa",
        "aqaba", "me-jo", "mena-jo", "jo1", "jo2",
        "jo.", "jordn", "jo_"
    ];
    for (var i = 0; i < jordanPatterns.length; i++) {
        if (h.indexOf(jordanPatterns[i]) !== -1) {
            return { region: "JORDAN", confidence: 80 };
        }
    }

    // MENA patterns
    var menaPatterns = [
        "me.", "mena", "mideast", "middleeast",
        "gulf", "arab", "sa.", "ae.", "kw.", "eg."
    ];
    for (var j = 0; j < menaPatterns.length; j++) {
        if (h.indexOf(menaPatterns[j]) !== -1) {
            return { region: "MENA", confidence: 60 };
        }
    }

    return { region: "UNKNOWN", confidence: 0 };
}

function detectMode(host) {
    var h = host ? host.toLowerCase() : "";

    for (var i = 0; i < MODE_PRIORITY.length; i++) {
        var modeName = MODE_PRIORITY[i];
        var mode     = MODES[modeName];
        if (!mode || !mode.si
g) continue;

        for (var j = 0; j < mode.sig.length; j++) {
            if (h.indexOf(mode.sig[j]) !== -1) {
                return modeName;
            }
        }
    }

    return "CLASSIC";
}

function assessServerQuality(ip, host, mode) {
    var score = 50;

    if (ip && GUARD.isJordan(ip)) {
        score += 50;
        var city = GUARD.getJordanCity(ip);
        if      (city === "AMMAN_CORE")  score += 20;
        else if (city === "AMMAN_METRO") score += 15;
        else if (city === "AMMAN_CITY")  score += 12;
        else                             score += 8;

        var carrier = getCarrier(ip);
        if      (carrier === "ORANGE") score += 10;
        else if (carrier === "ZAIN")   score += 9;
        else if (carrier === "UMNIAH") score += 8;
    }

    var region = detectRegion(host, ip);
    if (region.region === "JORDAN") {
        score += region.confidence * 0.2;
    }

    var m = MODES[mode];
    if (m && (m.socialPriority || m.fpsOptimized) && !GUARD.isJordan(ip)) {
        score -= 70;
    }

    score = Math.max(0, Math.min(100, score));

    if      (score >= 92) return "SUPREME";
    if      (score >= 80) return "EXCELLENT";
    if      (score >= 65) return "GOOD";
    if      (score >= 50) return "FAIR";
    if      (score >= 30) return "POOR";
    return "UNACCEPTABLE";
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 20: CONNECTION PROFILER
// ═══════════════════════════════════════════════════════════════════════

var CONNECTION = {
    _lastProfile:     null,
    _lastProfileTime: 0,

    profile: function() {
        var ts = now();
        if (ts - this._lastProfileTime < 3000 && this._lastProfile) {
            return this._lastProfile;
        }

        var avg  = PING_ENGINE.avg(5);
        var best = PING_ENGINE.best();
        var fps  = FPS_ENGINE.getRecommendedFPS();

        var type;
        var quality;

        if      (avg <= 3  && best <= 2)  { type = "5G_QUANTUM";    quality = "ABSOLUTE";  }
        else if (avg <= 5  && best <= 3)  { type = "5G_ULTRA";      quality = "SUPREME";   }
        else if (avg <= 7  && best <= 5)  { type = "5G_PREMIUM";    quality = "EXCELLENT"; }
        else if (avg <= 10 && best <= 7)  { type = "5G_GOOD";       quality = "VERY_GOOD"; }
        else if (avg <= 15)               { type = "4G_EXCELLENT";  quality = "GOOD";      }
 if (p && w && n) return 40;
        if (p && w)      return 30;
        if (p)           re
        else if (avg <= 25)               { type = "4G_GOOD";       quality = "FAIR";      }
        else if (avg <= 40)               { type = "4G_WEAK";       quality = "POOR";      }
        else                              { type = "WEAK";          quality = "CRITICAL";  }

        SESSION.networkQuality = quality;

        var result = {
            type:         type,
            quality:      quality,
            avgPing:      avg,
            bestPing:     best,
            recommendFPS: fps,
            is144fps:     FPS_ENGINE.is144Achievable(),
            is120fps:     FPS_ENGINE.is120Achievable(),
            tier:         this.getTier(type)
        };

        this._lastProfile    = result;
        this._lastProfileTime = ts;

        return result;
    },

    getTier: function(type) {
        if (type === "5G_QUANTUM" || type === "5G_ULTRA") return 0;
        if (type === "5G_PREMIUM" || type === "5G_GOOD")  return 0;
        if (type === "4G_EXCELLENT")                       return 1;
        return 2;
    },

    boost: function() {
        var p = this.profile();
        if (p.type === "5G_QUANTUM")   return 90;
        if (p.type === "5G_ULTRA")     return 75;
        if (p.type === "5G_PREMIUM")   return 60;
        if (p.type === "5G_GOOD")      return 48;
        if (p.type === "4G_EXCELLENT") return 35;
        if (p.type === "4G_GOOD")      return 18;
        if (p.type === "4G_WEAK")      return 0;
        return -40;
    },

    getCongestion: function() {
        var v = PING_ENGINE.variance();
        if (v > 20)  { SESSION.congestionLevel = 4; return "CRITICAL"; }
        if (v > 12)  { SESSION.congestionLevel = 3; return "HIGH";     }
        if (v > 7)   { SESSION.congestionLevel = 2; return "MEDIUM";   }
        if (v > 3)   { SESSION.congestionLevel = 1; return "LOW";      }
        SESSION.congestionLevel = 0;
        return "NONE";
    }
};

var TIME_MANAGER = {
    isPeak: function() {
        var h = (new Date()).getHours();
        return (h >= 16 || h <= 2);
    },
    isWeekend: function() {
        var d = (new Date()).getDay();
        return (d === 5 || d === 6);
    },
    isLateNight: function() {
        var h = (new Date()).getHours();
        return (h >= 22 || h <= 4);
    },
    getBonus: function() {
        var p = this.isPeak();
        var w = this.isWeekend();
        var n = this.isLateNight();
      
 turn 20;
        if (w)           return 15;
        return 0;
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 21: CARRIER UTILITIES
// ═══════════════════════════════════════════════════════════════════════

function getCarrier(ip) {
    if (!ip || !isIPv4(ip)) return "UNKNOWN";

    if (isInNet(ip, "46.185.128.0", "255.255.128.0") ||
        isInNet(ip, "94.127.208.0",  "255.255.240.0") ||
        isInNet(ip, "149.200.136.0", "255.255.252.0")) return "ORANGE";

    if (isInNet(ip, "79.173.192.0",  "255.255.192.0") ||
        isInNet(ip, "109.237.192.0", "255.255.192.0") ||
        isInNet(ip, "176.28.0.0",    "255.254.0.0")   ||
        isInNet(ip, "176.29.0.0",    "255.255.0.0"))   return "ZAIN";

    if (isInNet(ip, "82.212.0.0",    "255.255.0.0")   ||
        isInNet(ip, "212.35.64.0",   "255.255.192.0")) return "UMNIAH";

    if (isInNet(ip, "188.247.0.0",   "255.255.0.0")   ||
        isInNet(ip, "94.230.0.0",    "255.255.0.0"))   return "JT";

    return "OTHER";
}

function getCarrierBonus(carrier) {
    if (carrier === "ORANGE") return 50;
    if (carrier === "ZAIN")   return 45;
    if (carrier === "UMNIAH") return 40;
    if (carrier === "JT")     return 30;
    return 0;
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 22: SUPREME AI SCORING ENGINE — 25 Factors
// ═══════════════════════════════════════════════════════════════════════

function calculateScore(ip, host, port, dns, mode) {
    var score = 0;
    var m     = MODES[mode];
    var mw    = ML_ENGINE.selfWeights;

    // ─── FACTOR 1: Mode Priority Tier (0-80) ────────────────────────
    if (m) {
        score += m.priority * 6;
        if (m.fpsOptimized)    score += 30;
        if (m.socialPriority)  score += 28;
        if (m.lobbyDedicated)  score += 25;
        if (m.hyperBurst)      score += 10;
    } else {
        score += 30;
    }

    // ─── FACTOR 2: DNS Latency (0-60) ───────────────────────────────
    var dt = dns.dt;
    if      (dt <= 1)  score += 60;
    else if (dt <= 3)  score += 55;
    else if (dt <= 5)  score += 48;
    else if (dt <= 10) score += 38;
    else if (dt <= 20) score += 25;
    else if (dt <= 40) score += 12;
    else if (dt <= 80) score += 3;
    else               score -= 30;

    // ─── FACTOR 3: Current Ping Health (0-50) ───────────────────────
    var quality = PING_ENGINE.quality(mode);
    if      (quality === "ULTRA")      score += 50;
    else if (quality === "EXCELLENT")  score += 42;
ore += 14;

    // ─── FACTOR 9: Ping Trend (-65 to
    else if (quality === "VERY_GOOD")  score += 32;
    else if (quality === "GOOD")       score += 20;
    else if (quality === "ACCEPTABLE") score += 8;
    else                               score -= 40;

    // ─── FACTOR 4: 🇯🇴 JORDAN IP — MEGA ABSOLUTE BONUS (0-400) ─────
    if (ip && GUARD.isJordan(ip)) {
        score += 200;  // Base mega bonus

        // Carrier bonus
        var carrier = getCarrier(ip);
        score += getCarrierBonus(carrier);

        // City micro-routing bonus
        var city = GUARD.getJordanCity(ip);
        if      (city === "AMMAN_CORE")  score += 50;
        else if (city === "AMMAN_METRO") score += 40;
        else if (city === "AMMAN_CITY")  score += 32;
        else if (city === "IRBID" ||
                 city === "ZARQA")       score += 25;
        else if (city === "AQABA")       score += 20;
        else                             score += 12;

        // Mode + Jordan combos
        if (m && m.priority >= 9)    score += 40;
        if (m && m.socialPriority)   score += 60;
        if (m && m.fpsOptimized)     score += 55;
        if (m && m.lobbyDedicated)   score += 50;

        // Peak time Jordan bonus
        if (TIME_MANAGER.isPeak())   score += 25;
        if (TIME_MANAGER.isWeekend()) score += 15;

        score *= (mw.region || 1);
    }

    // ─── FACTOR 5: Host/DNS Pattern (0-120) ─────────────────────────
    var region = detectRegion(host, ip);
    if (region.region === "JORDAN") {
        score += 80 + (region.confidence * 0.4);
    } else if (region.region === "MENA") {
        score += 30;
    } else {
        score -= 80;
    }

    // ─── FACTOR 6: Connection Quality Boost (0-90) ──────────────────
    score += CONNECTION.boost();

    // ─── FACTOR 7: Ping Stability (0-40 / -45) ──────────────────────
    var stability = PING_ENGINE.stability();
    if      (stability === "ULTRA_STABLE") score += 40;
    else if (stability === "VERY_STABLE")  score += 30;
    else if (stability === "STABLE")       score += 20;
    else if (stability === "MODERATE")     score += 8;
    else                                   score -= 45;

    // ─── FACTOR 8: Port Analysis (0-25) ─────────────────────────────
    if      (port === 443)                    score += 18;
    else if (port >= 10000 && port <= 10200)  score += 25;
    else if (port >= 7000  && port <= 7200)   score += 20;
    else if (port === 80)                     score += 12;
    else if (port === 8080)                   score += 14;
    else if (port === 3128)                   s
c +45) ──────────────────────────
    var trend = PING_ENGINE.trend();
    if      (trend === "FAST_IMPROVING") score += 45;
    else if (trend === "IMPROVING")      score += 30;
    else if (trend === "STABLE")         score += 5;
    else if (trend === "DEGRADING")      score -= 40;
    else if (trend === "FAST_DEGRADING") score -= 65;

    // ─── FACTOR 10: Emergency State (-100 / -60) ─────────────────────
    if (PING_ENGINE.isEmergency())        score -= 100;
    else if (PING_ENGINE.isCritical())    score -= 60;
    else if (PING_ENGINE.needsOptimization()) score -= 30;

    // ─── FACTOR 11: Mode Jordan Bonus/Foreign Penalty ────────────────
    if (m) {
        if (ip && GUARD.isJordan(ip)) score += (m.jordanBonus  || 0);
        else                           score += (m.foreignPenalty || 0);
    }

    // ─── FACTOR 12: Time Context Bonus (0-40) ────────────────────────
    score += TIME_MANAGER.getBonus();

    // ─── FACTOR 13: Server Quality Assessment (0-40) ─────────────────
    var sq = dns.quality;
    if      (sq === "SUPREME")    score += 40;
    else if (sq === "EXCELLENT")  score += 30;
    else if (sq === "GOOD")       score += 20;
    else if (sq === "FAIR")       score += 8;
    else if (sq === "POOR")       score -= 15;
    else                          score -= 30;

    // ─── FACTOR 14: ML Prediction Confidence (0-55) ──────────────────
    if (CFG.ENABLE_ML) {
        var conf = ML_ENGINE.confidence(mode, region.region);
        if      (conf >= 95) score += 55;
        else if (conf >= 85) score += 45;
        else if (conf >= 70) score += 32;
        else if (conf >= 50) score += 18;
        else if (conf >= 20) score += 8;
    }

    // ─── FACTOR 15: Network Congestion (-60) ─────────────────────────
    var cong = CONNECTION.getCongestion();
    if      (cong === "CRITICAL") score -= 60;
    else if (cong === "HIGH")     score -= 40;
    else if (cong === "MEDIUM")   score -= 20;
    else if (cong === "LOW")      score -= 8;

    // ─── FACTOR 16: Social Endpoint Mega Bonus (0-80) ────────────────
    if (dns.socialEndpoint && CFG.ENABLE_FRIEND_DISCOVERY) {
        score += 60;
        if (ip && GUARD.isJordan(ip)) score += 20;
    }

    // ─── FACTOR 17: FPS Endpoint Mega Bonus (0-90) ───────────────────
    if (dns.fpsEndpoint && CFG.ENABLE_FPS_ENGINE) {
        score += 70;
        if (ip && GUARD.isJordan(ip)) score += 20;
    }

    // ─── FACTOR 18: Adaptive QoS Profile Bonus (0-50) ────────────────
    score += ADAPTIVE_QOS.getBonus();

    // ─── FACTOR 19: Jordan Pool Strategy Bonus (0-150) ───────────────
= m.fpsOptimized    || false;
    var isSoci
    score += JORDAN_POOL.getStrategyBonus();

    // ─── FACTOR 20: FPS Monitor Stability Bonus (0-30 / -30) ─────────
    var fpsStab = FPS_MONITOR.getStability();
    if      (fpsStab === "ULTRA_STABLE") score += 30;
    else if (fpsStab === "VERY_STABLE")  score += 22;
    else if (fpsStab === "STABLE")       score += 12;
    else if (fpsStab === "MODERATE")     score += 3;
    else if (fpsStab === "UNSTABLE")     score -= 20;
    else if (fpsStab === "CRITICAL")     score -= 30;

    // ─── FACTOR 21: Ping Forecast Adjustment (-40 to +25) ────────────
    if (CFG.ENABLE_PING_FORECASTING) {
        var predicted = PING_ENGINE.predicted();
        if (predicted !== null && m) {
            if (predicted < m.targetPing)      score += 25;
            else if (predicted < m.maxPing)    score += 10;
            else if (predicted > m.maxPing * 1.5) score -= 40;
        }
    }

    // ─── FACTOR 22: ML Anomaly Penalty (-50) ─────────────────────────
    if (CFG.ENABLE_ANOMALY_DETECTION && ML_ENGINE.detectAnomaly()) {
        score -= 50;
    }

    // ─── FACTOR 23: Visibility Boost Multiplier ──────────────────────
    if (m && m.visibilityBoost) {
        score = Math.round(score * (1 + (m.visibilityBoost * 0.04)));
    }

    // ─── FACTOR 24: Session Warm Bonus (0-20) ────────────────────────
    if (SESSION.isWarm()) {
        var successRate = SESSION.pubgRequests > 0
            ? Math.round(SESSION.jordanHits / SESSION.pubgRequests * 100)
            : 0;
        if (successRate >= 90) score += 20;
        else if (successRate >= 75) score += 10;
    }

    // ─── FACTOR 25: Peak Jordan Player Pool Multiplier ───────────────
    if (JORDAN_POOL.isPeakTime()) {
        var mult = JORDAN_POOL.getPeakMultiplier();
        if (ip && GUARD.isJordan(ip)) {
            score = Math.round(score * (1 + (mult - 1) * 0.3));
        }
    }

    // ─── Normalize to 0-100 ──────────────────────────────────────────
    if (score < 0)   return 0;
    if (score > 700) return 100;
    return Math.round((score / 700) * 100);
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 23: SUPREME ROUTING ENGINE — Full Strategy Set
// ═══════════════════════════════════════════════════════════════════════

function selectRoute(mode, score, ip, port, host, dns) {
    var m       = MODES[mode];
    if (!m)   m = MODES["CLASSIC"];

    var strategy  = m.strategy   || "GAME_STANDARD";
    var region    = dns.region   || { region: "UNKNOWN" };
    var carrier   = getCarrier(ip);
    var connProf  = CONNECTION.profile();
    var isFPS    
 al  = m.socialPriority  || false;
    var isLobby   = m.lobbyDedicated  || false;

    // Update game state
    if (m.gameState) SESSION.updateGameState(m.gameState);

    // ─── Security Gate ────────────────────────────────────────────────
    if (!GUARD.checkDestination(ip, host, mode)) return BLOOD.BLK;

    // ─── Jordan Pool Counter ──────────────────────────────────────────
    JORDAN_POOL._totalCount++;

    // ─── Anomaly Detection + Emergency Reroute ────────────────────────
    if (PING_ENGINE.isEmergency() || ML_ENGINE.detectAnomaly()) {
        stickyClear(mode);
        SESSION.recordAnomaly();

        var emergProxies = isFPS
            ? ["FPS_ORANGE_1", "FPS_ZAIN_1", "FPS_UMNIAH_1"]
            : isSocial
                ? ["SOCIAL_ORANGE_1", "SOCIAL_ZAIN_1", "SOCIAL_UMNIAH_1"]
                : isLobby
                    ? ["LOBBY_ORANGE_1", "LOBBY_ZAIN_1"]
                    : ["ORANGE_ULTRA_1", "ZAIN_ULTRA_1", "UMNIAH_ULTRA_1"];

        var emergency = GUARD.buildChain(emergProxies, mode, {
            hyperBurst: true, maxTier: 0
        });

        stickySet(mode, emergency, m.stickyDuration || CFG.STICKY_TTL);
        ML_ENGINE.recordSuccess(
            mode, emergency, PING_ENGINE.current(),
            region.region, isSocial, isFPS
        );
        SESSION.recordRecovery();
        return emergency;
    }

    // ─── ML Neural Prediction ─────────────────────────────────────────
    if (CFG.ENABLE_ML && SESSION.isWarm()) {
        var predicted  = ML_ENGINE.predict(mode, region.region, isSocial, isFPS);
        var confidence = ML_ENGINE.confidence(mode, region.region);

        if (predicted && confidence >= CFG.ML_CONFIDENCE_THRESHOLD) {
            if (PING_ENGINE.isHealthy(mode) && !PING_ENGINE.needsOptimization()) {
                return predicted;
            }
        }
    }

    // ─── Sticky Route Check ───────────────────────────────────────────
    if (m.sticky && SESSION.isWarm()) {
        var sticky = stickyGet(mode);
        if (sticky && PING_ENGINE.isHealthy(mode) &&
            !PING_ENGINE.needsOptimization()) {

            var pingQ = PING_ENGINE.quality(mode);
            if (pingQ === "ULTRA" || pingQ === "EXCELLENT") {
                stickyExtend(mode, CFG.STICKY_EXTEND_ON_GOOD);
            }
            return sticky;
        }
    }

    var route = null;

    // ═══════════════════════════════════════════════════════════════════
    //  ROUTING STRATEGIES
    // ═══════════════════════════════════════════════════════════════════

    // ─── FPS_ABSOLUTE — Ranked / TDM / In-Game FPS ───────────────────
    if (strategy === "FPS_ABSOLUTE") {
 GUARD.isJordan(ip))) {
            var lobbyCarrier = (carri
        var bestFPS   = MULTIPATH.getBest(mode, true, false);
        var backupFPS = MULTIPATH.getBackup(mode, true, false);

        if (score >= 95 && ip && GUARD.isJordan(ip)) {
            route = GUARD.buildChain(
                [bestFPS, backupFPS,
                 "FPS_ORANGE_1", "FPS_ZAIN_1", "FPS_UMNIAH_1"],
                mode,
                { hyperBurst: true, fpsOpt: true, maxTier: 0 }
            );
        } else if (score >= 85 || (ip && GUARD.isJordan(ip))) {
            route = GUARD.buildChain(
                getBestProxies(0, carrier, 3, {
                    fpsOptimized: true, hyperBurst: true
                }),
                mode,
                { hyperBurst: true, fpsOpt: true, maxTier: 0 }
            );
        } else if (score >= 70) {
            route = GUARD.buildChain(
                getBestProxies(0, null, 3, { fpsOptimized: true }),
                mode,
                { ultraBurst: true, fpsOpt: true, maxTier: 0 }
            );
        } else {
            route = GUARD.buildChain(
                ["FPS_ORANGE_1", "FPS_ZAIN_1", "ORANGE_ULTRA_1"],
                mode,
                { hyperBurst: true, fpsOpt: true, maxTier: 0 }
            );
        }
    }

    // ─── SOCIAL_ABSOLUTE — Friend Discovery / Crew ───────────────────
    else if (strategy === "SOCIAL_ABSOLUTE") {
        var bestSocial = MULTIPATH.getBest(mode, false, true);
        var backupSocial = MULTIPATH.getBackup(mode, false, true);

        if (score >= 95 &&
            ip && GUARD.isJordan(ip) &&
            GUARD.getJordanCity(ip) === "AMMAN_CORE") {
            route = GUARD.buildChain(
                ["SOCIAL_ORANGE_1", "SOCIAL_ZAIN_1", "SOCIAL_UMNIAH_1"],
                mode,
                {
                    hyperBurst: true, socialOpt: true,
                    socialDed: true, maxTier: 0
                }
            );
        } else if (score >= 85 || (ip && GUARD.isJordan(ip))) {
            route = GUARD.buildChain(
                getBestProxies(0, carrier, 2, {
                    socialOptimized: true, hyperBurst: true
                }),
                mode,
                { hyperBurst: true, socialOpt: true, maxTier: 0 }
            );
        } else {
            route = GUARD.buildChain(
                ["SOCIAL_ORANGE_1", "SOCIAL_ZAIN_1",
                 "ORANGE_ULTRA_1",  "ZAIN_ULTRA_1"],
                mode,
                { hyperBurst: true, socialOpt: true, maxTier: 0 }
            );
        }
    }

    // ─── LOBBY_ABSOLUTE — Matchmaking / Lobby ────────────────────────
    else if (strategy === "LOBBY_ABSOLUTE") {
        if (score >= 90 || (ip &
&er === "ORANGE" || score >= 95)
                               ? "ORANGE" : carrier;
            route = GUARD.buildChain(
                getBestProxies(0, lobbyCarrier, 2, {
                    socialOptimized: true, hyperBurst: true
                }),
                mode,
                { hyperBurst: true, socialOpt: true, maxTier: 0 }
            );
        } else {
            route = GUARD.buildChain(
                ["LOBBY_ORANGE_1", "LOBBY_ZAIN_1",
                 "ORANGE_ULTRA_1", "ZAIN_ULTRA_1"],
                mode,
                { hyperBurst: true, maxTier: 0 }
            );
        }
    }

    // ─── SOCIAL_FPS_CRITICAL — Clan War ──────────────────────────────
    else if (strategy === "SOCIAL_FPS_CRITICAL") {
        if (score >= 90 || (ip && GUARD.isJordan(ip))) {
            route = GUARD.buildChain(
                getBestProxies(0, carrier, 2, {
                    fpsOptimized: true, socialOptimized: true,
                    ultraBurst: true
                }),
                mode,
                { ultraBurst: true, fpsOpt: true, socialOpt: true, maxTier: 0 }
            );
        } else {
            route = GUARD.buildChain(
                ["ORANGE_ULTRA_1", "ZAIN_ULTRA_1",
                 "FPS_ORANGE_1",   "FPS_ZAIN_1"],
                mode,
                { ultraBurst: true, maxTier: 0 }
            );
        }
    }

    // ─── FPS_CRITICAL — Classic / Metro / Event ──────────────────────
    else if (strategy === "FPS_CRITICAL") {
        if (score >= 85 || (ip && GUARD.isJordan(ip))) {
            route = GUARD.buildChain(
                getBestProxies(0, carrier, 2, {
                    fpsOptimized: true, ultraBurst: true
                }),
                mode,
                { ultraBurst: true, fpsOpt: true, maxTier: 0 }
            );
        } else {
            route = GUARD.buildChain(
                getBestProxies(0, null, 2, { fpsOptimized: true }),
                mode,
                { ultraBurst: true, fpsOpt: true, maxTier: 0 }
            );
        }
    }

    // ─── SOCIAL_CRITICAL — Profiles / Presence ───────────────────────
    else if (strategy === "SOCIAL_CRITICAL") {
        route = GUARD.buildChain(
            getBestProxies(0, null, 2, {
                socialOptimized: true, ultraBurst: true
            }),
            mode,
            { ultraBurst: true, socialOpt: true, maxTier: 0 }
        );
    }

    // ─── SOCIAL_STANDARD — Chat / Voice ──────────────────────────────
    else if (strategy === "SOCIAL_STANDARD") {
        route = GUARD.buildChain(
            getBestProxies(0, carrier, 2, { socialOptimized: true }),
            mode,
            { maxTier: 1 }
        );
    }

    // ─── SECURE_ABSOLUTE — Auth / Login ──────────────────────────────
",  "255.240.0.0") ||
            isInNet(host
    else if (strategy === "SECURE_ABSOLUTE") {
        route = GUARD.buildChain(
            ["ORANGE_ULTRA_1", "ORANGE_PLAT_1",
             "ZAIN_ULTRA_1",   "ZAIN_PLAT_1"],
            mode,
            { maxTier: 0 }
        );
    }

    // ─── GAME_STANDARD — Arcade ──────────────────────────────────────
    else if (strategy === "GAME_STANDARD") {
        route = GUARD.buildChain(
            getBestProxies(1, carrier, 2, {}),
            mode,
            { maxTier: 1 }
        );
    }

    // ─── CDN ──────────────────────────────────────────────────────────
    else if (strategy === "CDN") {
        return BLOOD.DIR;
    }

    // ─── SAFE / Default ───────────────────────────────────────────────
    else {
        route = GUARD.buildChain(
            getBestProxies(0, null, 2, {}),
            mode,
            { maxTier: 1 }
        );
    }

    // ─── Fallback ─────────────────────────────────────────────────────
    if (!route || route === BLOOD.BLK) {
        var fallbackList = isFPS
            ? ["FPS_ORANGE_1", "FPS_ZAIN_1", "ORANGE_ULTRA_1"]
            : isSocial
                ? ["SOCIAL_ORANGE_1", "SOCIAL_ZAIN_1", "ORANGE_ULTRA_1"]
                : ["ORANGE_ULTRA_1", "ZAIN_ULTRA_1", "UMNIAH_ULTRA_1"];

        route = GUARD.buildChain(fallbackList, mode, { maxTier: 0 });
    }

    // ─── Save to Sticky & ML ──────────────────────────────────────────
    if (m.sticky && route) {
        stickySet(mode, route, m.stickyDuration || CFG.STICKY_TTL);
    }

    if (CFG.ENABLE_ML && route) {
        ML_ENGINE.recordSuccess(
            mode, route, PING_ENGINE.current(),
            region.region, isSocial, isFPS
        );
    }

    return route;
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 24: MAIN PAC ENTRY POINT
// ═══════════════════════════════════════════════════════════════════════

function FindProxyForURL(url, host) {
    SESSION.requests++;
    SESSION.updateTimeContext();

    // ─── Startup Initialization ───────────────────────────────────────
    if (SESSION.requests === 1) {
        prefetchDNS();
        ADAPTIVE_QOS.select();
        MULTIPATH.reselect();
    }

    // ─── Periodic Updates (every 15 requests) ────────────────────────
    if (SESSION.requests % 15 === 0) {
        ADAPTIVE_QOS.select();
        MULTIPATH.reselect();
        ML_ENGINE.optimizeWeights();
    }

    // ─── Null host guard ──────────────────────────────────────────────
    if (!host) return BLOOD.DIR;

    var h = host.toLowerCase();

    // ─── Localhost / Private Networks ────────────────────────────────
    if (isPlainHostName(host)) return BLOOD.DIR;

    if (isIPv4(host)) {
        if (isInNet(host, "10.0.0.0",    "255.0.0.0")   ||
            isInNet(host, "172.16.0.
0, "192.168.0.0", "255.255.0.0") ||
            isInNet(host, "127.0.0.0",   "255.0.0.0")   ||
            isInNet(host, "169.254.0.0", "255.255.0.0")) {
            return BLOOD.DIR;
        }
    }

    // ─── Direct non-PUBG domains ──────────────────────────────────────
    if (containsAny(h, DIRECT_KEYS) && !containsAny(h, PUBG_KEYS)) {
        SESSION.directHits++;
        return BLOOD.DIR;
    }

    // ─── Non-PUBG traffic ────────────────────────────────────────────
    if (!containsAny(h, PUBG_KEYS)) {
        SESSION.directHits++;
        return BLOOD.DIR;
    }

    // ─── PUBG Traffic — Supreme Processing ───────────────────────────
    SESSION.pubgRequests++;

    // DNS resolution with cache
    var dns  = fastDNS(host);
    var ip   = dns.ip;
    var mode = dns.mode;
    var port = getPort(url);

    SESSION.recordMode(mode);

    // ─── IPv6 blocking ────────────────────────────────────────────────
    if (ip && ip.indexOf(":") !== -1) {
        if (CFG.JORDAN_ONLY_MODE || CFG.BLOCK_INTERNATIONAL) {
            SESSION.blockedHits++;
            return BLOOD.BLK;
        }
    }

    // ─── Null IP handling ────────────────────────────────────────────
    if (!ip) {
        if (CFG.FAIL_CLOSED) return BLOOD.BLK;
        return BLOOD.DIR;
    }

    // ─── Packet optimization ─────────────────────────────────────────
    var pktInfo = PACKET_OPT.process(host, mode, port);

    // ─── 25-Factor AI Score ───────────────────────────────────────────
    var score = calculateScore(ip, h, port, dns, mode);

    // ─── Supreme Route Selection ──────────────────────────────────────
    var route = selectRoute(mode, score, ip, port, h, dns);

    return route;
}


// ═══════════════════════════════════════════════════════════════════════
//  SECTION 25: UTILITIES
// ═══════════════════════════════════════════════════════════════════════

function now() {
    return (new Date()).getTime();
}

function isIPv4(str) {
    if (!str || str.indexOf(":") !== -1) return false;
    var parts = str.split(".");
    if (parts.length !== 4) return false;
    for (var i = 0; i < 4; i++) {
        var n = parseInt(parts[i], 10);
        if (isNaN(n) || n < 0 || n > 255) return false;
    }
    return true;
}

function maskFromCIDR(cidr) {
    var c = String(cidr);
    var masks = {
        "8":  "255.0.0.0",
        "10": "255.192.0.0",  "11": "255.224.0.0",
        "12": "255.240.0.0",  "13": "255.248.0.0",
        "14": "255.252.0.0",  "15": "255.254.0.0",
        "16": "255.255.0.0",  "17": "255.255.128.0",
        "18": "255.255.192.0", "19": "255.255.224.0",
        "20": "255.255.240.0", "21": "255.255.248.0",
        "22": "255.255.252.0"
    };
    return masks[c] || "255.255.0.0";
}

function inRanges(ip, ranges) {
    if (!ip || !isIPv4(ip)) return false;
    for (var i = 0; i < ranges.length; i++) {
ssRpt.jordanRatio >= CFG.JORDAN_PLAYER_TARGET,
            strategy:      poolR
        if (isInNet(ip, ranges[i][0], maskFromCIDR(ranges[i][1]))) return true;
    }
    return false;
}

function containsAny(str, keywords) {
    if (!str || !keywords) return false;
    for (var i = 0; i < keywords.length; i++) {
        if (str.indexOf(keywords[i]) !== -1) return true;
    }
    return false;
}

function getPort(url) {
    if (!url) return 443;
    var match = url.match(/^[a-zA-Z]+:\/\/[^\/:]+:(\d+)/);
    if (match) return parseInt(match[1], 10);
    if (url.indexOf("https://") === 0) return 443;
    if (url.indexOf("http://")  === 0) return 80;
    return 443;
}


