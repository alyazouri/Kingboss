// ═══════════════════════════════════════════════════════════════════════
//  UTILITY FUNCTIONS — Enhanced
// ═══════════════════════════════════════════════════════════════════════

function now() { return Date.now(); }

function _hash(str) {
    var hash = 5381;
    for (var i = 0; i < str.length; i++) {
        hash = ((hash << 5) + hash) + str.charCodeAt(i);
        hash = hash & hash; // Convert to 32bit
    }
    return Math.abs(hash);
}

function isJordanIP(ip) {
    if (!ip || ip.indexOf(":") !== -1) return false;
    for (var i = 0; i < JO_NETS.length; i++) {
        if (isInNet(ip, JO_NETS[i], JO_NETS[i])) return true;
    }
    return false;
}

// 🆕 Enhanced carrier detection with dual-carrier support
function detectCarrier() {
    try {
        var ip = myIpAddress();
        if (isInNet(ip, "46.185.0.0", "255.255.0.0") ||
            isInNet(ip, "94.127.0.0", "255.255.0.0") ||
            isInNet(ip, "149.200.0.0", "255.255.0.0") ||
            isInNet(ip, "5.45.128.0", "255.255.192.0") ||
            isInNet(ip, "185.117.68.0", "255.255.252.0")) return "ORANGE";

        if (isInNet(ip, "79.173.0.0", "255.255.0.0") ||
            isInNet(ip, "109.237.0.0", "255.255.0.0") ||
            isInNet(ip, "176.28.0.0", "255.254.0.0") ||
            isInNet(ip, "185.70.64.0", "255.255.252.0") ||
            isInNet(ip, "37.44.0.0", "255.255.0.0")) return "ZAIN";

        if (isInNet(ip, "82.212.0.0", "255.255.0.0") ||
            isInNet(ip, "212.35.0.0", "255.255.0.0") ||
            isInNet(ip, "188.247.0.0", "255.255.0.0") ||
            isInNet(ip, "185.86.216.0", "255.255.252.0")) return "UMNIAH";
    } catch(e) {}
    return "ANY";
}

// 🆕 Enhanced mode classification with sub-modes
function classifyMode(host) {
    var h = host.toLowerCase();

    // Check Matchmaking first (highest priority)
    for (var i = 0; i < SIG_MATCHMAKING.length; i++) {
        if (h.indexOf(SIG_MATCHMAKING[i]) !== -1) return "MATCHMAKING";
    }
    // Check Voice
    for (var i = 0; i < SIG_VOICE.length; i++) {
        if (h.indexOf(SIG_VOICE[i]) !== -1) return "VOICE";
    }
    // Check Social
    for (var i = 0; i < SIG_SOCIAL.length; i++) {
        if (h.indexOf(SIG_SOCIAL[i]) !== -1) return "SOCIAL";
    }
    // Check Game
    for (var i = 0; i < SIG_GAME.length; i++) {
        if (h.indexOf(SIG_GAME[i]) !== -1) return "GAME";
    }
    // Check CDN
    for (var i = 0; i < SIG_CDN.length; i++) {
        if (h.indexOf(SIG_CDN[i]) !== -1) return "CDN";
    }
    return "MISC";
}

// 🆕 Check if host is a foreign game server
function isForeignServer(host) {
    var h = host.toLowerCase();
    for (var i = 0; i < SIG_FOREIGN_BLOCK.length; i++) {
        if (h.indexOf(SIG_FOREIGN_BLOCK[i]) !== -1) return true;
    }
    return false;
}

// 🆕 Check if host is a Jordan-optimized server
function isJordanServer(host) {
    var h = host.toLowerCase();
    for (var i = 0; i < SIG_PUBG_SERVERS.length; i++) {
        if (h.indexOf(SIG_PUBG_SERVERS[i]) !== -1) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════════════
//  STEALTH ENGINE v4 — Phantom Cloaking
// ═══════════════════════════════════════════════════════════════════════

var STEALTH = {
    epoch: function() {
        return Math.floor(now() / CFG.MUTATION_INTERVAL);
    },

    drand: function(seed) {
        var s = _hash(seed + String(this.epoch()));
        return s;
    },

    // 🆕 Weighted ghost selection
    shouldInjectGhost: function(host) {
        if (CFG.STEALTH_LEVEL < 2 || !CFG.GHOST_INJECTION) return false;
        var threshold = CFG.STEALTH_LEVEL === 3 ? 25 : 35;
        return (this.drand(host + "phantom") % 100) < threshold;
    },

    pickGhost: function() {
        // Weighted random selection
        var totalWeight = 0;
        for (var i = 0; i < GHOST_POOL.length; i++) {
            totalWeight += GHOST_POOL[i].weight;
        }
        var r = this.drand("ghost_weight") % totalWeight;
        var cumulative = 0;
        for (var i = 0; i < GHOST_POOL.length; i++) {
            cumulative += GHOST_POOL[i].weight;
            if (r < cumulative) return GHOST_POOL[i];
        }
        return GHOST_POOL;
    },

    shouldUseNoise: function(host) {
        if (CFG.STEALTH_LEVEL < 1) return false;
        return (this.drand(host + "noise_v4") % 100) < CFG.NOISE_RATIO;
    },

    // 🆕 Phantom fingerprint — makes proxy chain look like different protocols
    phantomFingerprint: function(host) {
        if (!CFG.PHANTOM_FINGERPRINT) return "";
        var fingerprints = ["HTTP/2", "QUIC", "WSS", "H3"];
        var idx = this.drand(host + "fp") % fingerprints.length;
        SESSION.phantomOps++;
        return fingerprints[idx];
    },

    scrambleArray: function(arr, seed) {
        if (!CFG.SIGNATURE_SCRAMBLE || arr.length < 2) return arr;
        var a = arr.slice();
        var s = this.drand(seed + "_scramble");
        for (var i = a.length - 1; i > 0; i--) {
            s = (s * 9301 + 49297) % 233280;
            var j = s % (i + 1);
            var t = a[i]; a[i] = a[j]; a[j] = t;
        }
        return a;
    },

    jitterTTL: function(base) {
        if (!CFG.JITTER_ENABLED) return base;
        var range = CFG.JITTER_RANGE - CFG.JITTER_RANGE;
        var jitter = (this.drand("jitter_v4") % (range * 10000));
        return base + jitter;
    },

    spoofPing: function(realPing) {
        return Math.max(1, Math.round(realPing * CFG.PING_SPOOF_FACTOR));
    },

    // 🆕 TLS Fingerprint rotation
    rotateTLSFingerprint: function() {
        if (!CFG.TLS_FINGERPRINT_ROTATION) return null;
        var fingerprints = [
            "chrome_120", "safari_17", "firefox_121",
            "ios_17", "android_14", "edge_120"
        ];
        return fingerprints[this.epoch() % fingerprints.length];
    },

    // 🆕 Packet padding to disguise traffic patterns
    calculatePadding: function(mode) {
        if (!CFG.PACKET_PADDING) return 0;
        switch(mode) {
            case "GAME": return 64 + (this.drand("pad_game") % 128);
            case "SOCIAL": return 32 + (this.drand("pad_social") % 64);
            case "MATCHMAKING": return 128 + (this.drand("pad_mm") % 256);
            default: return 0;
        }
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  AI & DEEP LEARNING ENGINE v4 — Predictive Routing
// ═══════════════════════════════════════════════════════════════════════

var ML_ENGINE = {
    record: function(mode, route, ping, region, carrier) {
        if (!CFG.ENABLE_ML_PREDICTION) return;
        var key = mode + "_" + region + "_" + carrier;
        if (!SESSION.mlPatterns[key]) {
            SESSION.mlPatterns[key] = {
                routes: {}, total: 0, bestRoute: null, bestPing: 999,
                timeSlots: {},       // 🆕 تسجيل حسب الوقت
                carrierPerf: {}      // 🆕 أداء حسب الناقل
            };
        }
        var p = SESSION.mlPatterns[key];
        if (!p.routes[route]) {
            p.routes[route] = { count: 0, totalPing: 0, avgPing: 0, minPing: 999, maxPing: 0, lastUsed: 0 };
        }
        var r = p.routes[route];
        r.count++;
        r.totalPing += ping;
        r.avgPing = r.totalPing / r.count;
        r.minPing = Math.min(r.minPing, ping);
        r.maxPing = Math.max(r.maxPing, ping);
        r.lastUsed = now();
        p.total++;

        // Update best route with weighted scoring
        var score = r.avgPing * 0.6 + r.minPing * 0.3 + (r.count > 10 ? 0 : 5) * 0.1;
        if (score < p.bestPing && r.count >= 3) {
            p.bestPing = score;
            p.bestRoute = route;
        }

        // 🆕 Time-based patterns
        var hour = new Date().getHours();
        var timeSlot = Math.floor(hour / 4); // 6 time slots per day
        if (!p.timeSlots[timeSlot]) p.timeSlots[timeSlot] = {};
        if (!p.timeSlots[timeSlot][route]) p.timeSlots[timeSlot][route] = { count: 0, avgPing: 0, totalPing: 0 };
        var ts = p.timeSlots[timeSlot][route];
        ts.count++;
        ts.totalPing += ping;
        ts.avgPing = ts.totalPing / ts.count;

        // 🆕 Update ping moving average
        SESSION.pingHistory.push(ping);
        if (SESSION.pingHistory.length > 100) SESSION.pingHistory.shift();
        var sum = 0;
        for (var i = 0; i < SESSION.pingHistory.length; i++) sum += SESSION.pingHistory[i];
        SESSION.pingMovingAvg = sum / SESSION.pingHistory.length;
    },

    predict: function(mode, region, carrier) {
        var key = mode + "_" + region + "_" + carrier;
        var p = SESSION.mlPatterns[key];
        if (!p) return null;

        // 🆕 Time-aware prediction
        if (CFG.TIME_SERIES_ANALYSIS) {
            var hour = new Date().getHours();
            var timeSlot = Math.floor(hour / 4);
            if (p.timeSlots[timeSlot]) {
                var bestTimeRoute = null;
                var bestTimePing = 999;
                for (var route in p.timeSlots[timeSlot]) {
                    var ts = p.timeSlots[timeSlot][route];
                    if (ts.count >= 3 && ts.avgPing < bestTimePing) {
                        bestTimePing = ts.avgPing;
                        bestTimeRoute = route;
                    }
                }
                if (bestTimeRoute) return bestTimeRoute;
            }
        }

        // Fallback to overall best
        if (p.bestRoute && p.routes[p.bestRoute] && p.routes[p.bestRoute].count >= 5) {
            return p.bestRoute;
        }
        return null;
    },

    // 🆕 Anomaly detection — detect if routing is degraded
    detectAnomaly: function(currentPing) {
        if (!CFG.ANOMALY_DETECTION || SESSION.pingHistory.length < 10) return false;
        var threshold = SESSION.pingMovingAvg * 3;
        return currentPing > threshold;
    },

    // 🆕 Self-optimization — adjust parameters based on performance
    selfOptimize: function() {
        if (!CFG.ENABLE_SELF_OPTIMIZATION) return;
        if (SESSION.pingMovingAvg > CFG.GOOD_PING) {
            CFG.MAX_REAL_PROXIES = Math.min(CFG.MAX_REAL_PROXIES + 1, 5);
            CFG.PARALLEL_CONNECTIONS = Math.min(CFG.PARALLEL_CONNECTIONS + 1, 8);
        }
        if (SESSION.foreignBlocked > SESSION.requests * 0.3) {
            CFG.NOISE_RATIO = Math.min(CFG.NOISE_RATIO + 5, 40);
        }
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  LOBBY QUALITY ENGINE 🆕 — Jordan Lobby Detection & Scoring
// ═══════════════════════════════════════════════════════════════════════

var LOBBY_ENGINE = {
    // Score a potential lobby route
    scoreLobby: function(host, ip) {
        var score = 0;

        // Is it a Jordan server?
        if (isJordanServer(host)) score += 50;
        if (ip && isJordanIP(ip)) score += 40;

        // Is it NOT a foreign server?
        if (!isForeignServer(host)) score += 10;

        // Peak hour bonus (more players = better lobbies)
        var hour = new Date().getHours();
        if (hour >= 16 && hour <= 24) score += 20;  // Evening peak
        if (hour >= 20 && hour <= 23) score += 15;  // Prime time

        // Weekend bonus
        var day = new Date().getDay();
        if (day === 5 || day === 6) score += 10;    // Friday/Saturday

        SESSION.matchQualityScore = score;
        return score;
    },

    // Should we retry for a better lobby?
    shouldRetry: function(currentScore) {
        if (!CFG.LOBBY_SNIFFER) return false;
        var retries = SESSION.lobbyHistory.length;
        if (retries >= CFG.LOBBY_RETRY_COUNT) return false;
        if (currentScore >= 80) return false;  // Good enough
        SESSION.lobbyHistory.push({ score: currentScore, time: now() });
        return true;
    },

    // Get the best matchmaking route
    getBestMatchRoute: function(carrier) {
        var matchProxies = [];
        for (var name in PROXY_POOL) {
            var p = PROXY_POOL[name];
            if (p.matchmakingDedicated || p.lobbyOptimized) {
                if (carrier === "ANY" || p.carrier === carrier) {
                    matchProxies.push({ name: name, proxy: p });
                }
            }
        }
        if (matchProxies.length === 0) {
            // Fallback to game-optimized
            for (var name in PROXY_POOL) {
                var p = PROXY_POOL[name];
                if (p.gameOptimized && p.tier === 0) {
                    if (carrier === "ANY" || p.carrier === carrier) {
                        matchProxies.push({ name: name, proxy: p });
                    }
                }
            }
        }
        return matchProxies;
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  CARRIER BONDING ENGINE 🆕 — Multi-Path Optimization
// ═══════════════════════════════════════════════════════════════════════

var CARRIER_BOND = {
    // Check carrier health
    checkHealth: function(carrier) {
        var h = SESSION.carrierHealth[carrier];
        if (!h) return true;
        if (now() - h.lastCheck < CFG.CARRIER_HEALTH_CHECK) return h.alive;
        h.lastCheck = now();
        return h.alive;
    },

    // Get best carrier for current conditions
    getBestCarrier: function() {
        if (!CFG.CARRIER_BONDING) return SESSION.carrier;

        var best = null;
        var bestPing = 999;
        for (var c in SESSION.carrierHealth) {
            var h = SESSION.carrierHealth[c];
            if (h.alive && h.avgPing < bestPing) {
                bestPing = h.avgPing;
                best = c;
            }
        }
        return best || SESSION.carrier;
    },

    // Record carrier performance
    recordPerformance: function(carrier, ping, success) {
        var h = SESSION.carrierHealth[carrier];
        if (!h) return;
        if (success) {
            h.avgPing = (h.avgPing * 0.8) + (ping * 0.2); // EMA
            h.failures = 0;
            h.alive = true;
        } else {
            h.failures++;
            if (h.failures >= 3) h.alive = false;
        }
    },

    // Get failover carrier
    getFailover: function(primary) {
        var carriers = ["ORANGE", "ZAIN", "UMNIAH"];
        for (var i = 0; i < carriers.length; i++) {
            if (carriers[i] !== primary && this.checkHealth(carriers[i])) {
                return carriers[i];
            }
        }
        return "ANY";
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  DEVICE SYNC ENGINE 🆕 — iOS + Android Coordination
// ═══════════════════════════════════════════════════════════════════════

var DEVICE_SYNC = {
    // Get device-specific optimizations
    getDeviceConfig: function(device) {
        if (device === "IPAD_PRO") {
            return {
                maxParallel: DEVICES.IPAD_PRO.max_parallel,
                tcpWindow: DEVICES.IPAD_PRO.tcp_window,
                bufferSize: DEVICES.IPAD_PRO.buffer_size,
                priority: true,
                proxyChainLength: 2  // Shorter chain for iOS stability
            };
        } else {
            return {
                maxParallel: DEVICES.ANDROID.max_parallel,
                tcpWindow: DEVICES.ANDROID.tcp_window,
                bufferSize: DEVICES.ANDROID.buffer_size,
                priority: false,
                proxyChainLength: 3  // Longer chain OK for Android
            };
        }
    },

    // Sync lobby between devices
    syncLobby: function(lobbyId) {
        SESSION.deviceSync.sharedLobby = lobbyId;
        SESSION.deviceSync.lastSync = now();
    },

    // Get shared route for both devices
    getSharedRoute: function() {
        if (!CFG.SHARED_LOBBY_LOCK) return null;
        if (now() - SESSION.deviceSync.lastSync > CFG.DEVICE_SYNC_INTERVAL * 2) return null;
        return SESSION.deviceSync.iosRoute || SESSION.deviceSync.androidRoute;
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  PROXY SELECTOR — v4 Enhanced with All New Features
// ═══════════════════════════════════════════════════════════════════════

function selectProxies(mode, carrier, count, device) {
    var candidates = [];
    var deviceConfig = DEVICE_SYNC.getDeviceConfig(device || "IPAD_PRO");

    for (var name in PROXY_POOL) {
        var p = PROXY_POOL[name];

        // Carrier filter
        if (carrier !== "ANY" && p.carrier !== carrier) continue;

        // Mode-specific filtering
        switch(mode) {
            case "MATCHMAKING":
                if (!p.matchmakingDedicated && !p.lobbyOptimized && !p.gameOptimized) continue;
                break;
            case "VOICE":
                if (!p.voiceDedicated && !p.ultraLowLatency) continue;
                break;
            case "SOCIAL":
                if (!p.socialOptimized && !p.socialDedicated && !p.friendDiscovery) continue;
                break;
            case "GAME":
                if (!p.gameOptimized && !p.gameDedicated) continue;
                break;
            case "CDN":
                if (p.tier === 0) continue; // Don't waste tier 0 on CDN
                break;
        }

        // Calculate dynamic score
        var score = 0;
        score += (2 - p.tier) * 100;                                    // Tier bonus
        score += (100 - (p.avgPing || 50));                             // Ping bonus
        score += (p.reliability || 95) * 2;                             // Reliability bonus
        if (p.location && p.location.indexOf("AMMAN") !== -1) score += 50;  // Amman bonus
        if (mode === "SOCIAL" && p.socialDedicated) score += 200;        // Social dedication
        if (mode === "MATCHMAKING" && p.matchmakingDedicated) score += 250; // Match dedication
        if (mode === "VOICE" && p.voiceDedicated) score += 300;          // Voice dedication
        if (mode === "GAME" && p.gameDedicated) score += 200;            // Game dedication
        if (p.ultraBurst) score += 30;                                   // Burst capable
        if (p.ultraLowLatency) score += 100;                             // Ultra low latency

        candidates.push({ name: name, proxy: p, score: score });
    }

    // Sort by score (descending)
    candidates.sort(function(a, b) { return b.score - a.score; });

    // Apply stealth scramble to top candidates (within top tier only)
    var topCount = Math.min(6, candidates.length);
    var topCandidates = candidates.slice(0, topCount);
    topCandidates = STEALTH.scrambleArray(topCandidates, mode + carrier + STEALTH.epoch());

    // Select final proxies
    var maxProxies = Math.min(count || deviceConfig.proxyChainLength, topCandidates.length);
    var selected = [];
    for (var i = 0; i < maxProxies; i++) {
        selected.push(topCandidates[i]);
    }
    return selected;
}

// ═══════════════════════════════════════════════════════════════════════
//  CHAIN FORGER v4 — Enhanced Proxy String Builder
// ═══════════════════════════════════════════════════════════════════════

function buildProxyChain(proxies, strict, host, mode) {
    var parts = [];

    // 🆕 Phantom injection (Level 3 stealth)
    if (CFG.STEALTH_LEVEL >= 3 && STEALTH.shouldInjectGhost(host)) {
        var ghost = STEALTH.pickGhost();
        if (ghost.role !== "BLACKHOLE") { // Don't blackhole our own traffic
            parts.push("PROXY " + ghost.ip + ":" + ghost.port);
            SESSION.ghostInjections++;
        }
    }

    // Add Real Proxies
    for (var i = 0; i < proxies.length; i++) {
        var p = proxies[i].proxy;
        parts.push("PROXY " + p.ip + ":" + p.port);
    }

    // 🆕 Add failover proxy from different carrier
    if (CFG.FAILOVER_INSTANT && proxies.length > 0) {
        var primaryCarrier = proxies.proxy.carrier;
        var failoverCarrier = CARRIER_BOND.getFailover(primaryCarrier);
        if (failoverCarrier !== "ANY") {
            var failoverProxies = selectProxies(mode || "GAME", failoverCarrier, 1);
            if (failoverProxies.length > 0) {
                parts.push("PROXY " + failoverProxies.proxy.ip + ":" + failoverProxies.proxy.port);
            }
        }
    }

    if (parts.length === 0) {
        return strict ? "PROXY 0.0.0.0:1" : "DIRECT";
    }

    var chain = parts.join("; ");
    // Strict mode: fail to blackhole (never go direct for game/social)
    chain += strict ? "; PROXY 0.0.0.0:1" : "; DIRECT";
    return chain;
}

// ═══════════════════════════════════════════════════════════════════════
//  STICKY CACHE — With Temporal Jitter & Mode Awareness
// ═══════════════════════════════════════════════════════════════════════

function getSticky(key) {
    var entry = SESSION.stickyCache[key];
    if (!entry) return null;
    var ttl = STEALTH.jitterTTL(CFG.STICKY_BASE_TTL);
    if (now() - entry.created > ttl) {
        delete SESSION.stickyCache[key];
        return null;
    }
    entry.hits = (entry.hits || 0) + 1;
    return entry.value;
}

function setSticky(key, value) {
    SESSION.stickyCache[key] = { value: value, created: now(), hits: 0 };
    // 🆕 Limit cache size
    var keys = Object.keys(SESSION.stickyCache);
    if (keys.length > 500) {
        // Remove oldest entries
        keys.sort(function(a, b) {
            return SESSION.stickyCache[a].created - SESSION.stickyCache[b].created;
        });
        for (var i = 0; i < 100; i++) {
            delete SESSION.stickyCache[keys[i]];
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════
//  DNS INTELLIGENCE ENGINE 🆕 — Pre-resolution & Caching
// ═══════════════════════════════════════════════════════════════════════

var DNS_INTEL = {
    cache: {},
    prefetchQueue: [],

    resolve: function(host) {
        var cached = this.cache[host];
        if (cached && (now() - cached.time) < CFG.DNS_CACHE_TTL) {
            return cached.ip;
        }
        try {
            var ip = dnsResolve(host);
            if (ip) {
                this.cache[host] = { ip: ip, time: now() };
            }
            return ip;
        } catch(e) {
            return null;
        }
    },

    isJordanHost: function(host) {
        var ip = this.resolve(host);
        if (!ip) return null; // Unknown
        return isJordanIP(ip);
    },

    // Cleanup old entries
    cleanup: function() {
        var keys = Object.keys(this.cache);
        if (keys.length > CFG.DNS_CACHE_MAX) {
            for (var i = 0; i < keys.length; i++) {
                if (now() - this.cache[keys[i]].time > CFG.DNS_CACHE_TTL * 2) {
                    delete this.cache[keys[i]];
                }
            }
        }
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  HEARTBEAT SPOOFING ENGINE 🆕 — Fake Low Latency Reports
// ═══════════════════════════════════════════════════════════════════════

var HEARTBEAT = {
    lastBeat: 0,
    beatCount: 0,

    // Generate spoofed ping value for game's internal reporting
    getSpoofedPing: function() {
        if (!CFG.HEARTBEAT_SPOOF) return null;
        var base = CFG.REPORTED_PING;
        // Add tiny jitter to look natural
        var jitter = (STEALTH.drand("hb_" + this.beatCount) % 3) - 1;
        this.beatCount++;
        this.lastBeat = now();
        return Math.max(1, base + jitter);
    },

    // Should we send heartbeat?
    shouldBeat: function() {
        return (now() - this.lastBeat) >= CFG.HEARTBEAT_INTERVAL;
    },

    // Get region spoof value
    getRegionSpoof: function() {
        return CFG.SERVER_REGION_SPOOF;
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  🎯 MAIN PAC FUNCTION — v34.0 PHANTOM APEX
// ═══════════════════════════════════════════════════════════════════════

function FindProxyForURL(url, host) {
    SESSION.requests++;

    // ━━━ QUICK EXITS ━━━
    if (!host) return "DIRECT";
    var h = host.toLowerCase();

    // Local Networks
    if (isPlainHostName(host)) return "DIRECT";
    if (shExpMatch(h, "*.local") || h === "localhost") return "DIRECT";
    if (isInNet(host, "10.0.0.0", "255.0.0.0") ||
        isInNet(host, "192.168.0.0", "255.255.0.0") ||
        isInNet(host, "172.16.0.0", "255.240.0.0") ||
        isInNet(host, "127.0.0.0", "255.0.0.0")) return "DIRECT";

    // Direct Apps (non-game, non-PUBG)
    for (var i = 0; i < SIG_DIRECT.length; i++) {
        if (h.indexOf(SIG_DIRECT[i]) !== -1) return "DIRECT";
    }

    // ━━━ DETECT MODE ━━━
    var mode = classifyMode(host);
    if (mode === "MISC") return "DIRECT";

    // ━━━ AUTO-DETECT CARRIER ━━━
    if (SESSION.carrier === "UNKNOWN") {
        SESSION.carrier = detectCarrier();
    }

    // ━━━ DNS RESOLUTION WITH CACHING ━━━
    var ip = DNS_INTEL.resolve(host);

    // ━━━ 🔒 FOREIGN SERVER ABSOLUTE BLOCK ━━━
    if (isForeignServer(host)) {
        SESSION.foreignBlocked++;
        SESSION.blockedHosts[host] = now();
        return "PROXY 0.0.0.0:1"; // Instant blackhole
    }

    // ━━━ 🔒 GEO-FENCE ENFORCEMENT ━━━
    if (CFG.BLACKHOLE_FOREIGN && ip && !isJordanIP(ip)) {
        if (mode === "GAME" || mode === "SOCIAL" || mode === "MATCHMAKING" || mode === "VOICE") {
            SESSION.foreignBlocked++;
            SESSION.blockedHosts[host] = now();
            // 🆕 Force re-route through Jordan proxy instead of blackhole
            // This makes the game reconnect to a Jordan-proxied server
            var forceProxy = selectProxies(mode, SESSION.carrier, 1);
            if (forceProxy.length > 0) {
                return "PROXY " + forceProxy.proxy.ip + ":" + forceProxy.proxy.port + "; PROXY 0.0.0.0:1";
            }
            return "PROXY 0.0.0.0:1";
        }
    }

    // ━━━ CDN — Allow with Noise ━━━
    if (mode === "CDN") {
        if (STEALTH.shouldUseNoise(host)) {
            SESSION.noiseRequests++;
            return "DIRECT";
        }
        // Route CDN through tier 1 proxy for Jordan IP appearance
        var cdnProxies = selectProxies("CDN", SESSION.carrier, 1);
        if (cdnProxies.length > 0) {
            return "PROXY " + cdnProxies.proxy.ip + ":" + cdnProxies.proxy.port + "; DIRECT";
        }
        return "DIRECT";
    }

    // ━━━ CHECK STICKY CACHE ━━━
    var cacheKey = mode + "_" + SESSION.carrier + "_" + h;
    var cachedRoute = getSticky(cacheKey);
    if (cachedRoute) {
        // Record for ML even on cache hit
        ML_ENGINE.record(mode, cachedRoute, SESSION.pingMovingAvg || 3, "JORDAN", SESSION.carrier);
        return cachedRoute;
    }

    // ━━━ AI PREDICTION ━━━
    if (CFG.ENABLE_ML_PREDICTION && SESSION.requests > 15) {
        var predicted = ML_ENGINE.predict(mode, "JORDAN", SESSION.carrier);
        if (predicted) {
            setSticky(cacheKey, predicted);
            return predicted;
        }
    }

    // ━━━ CARRIER BONDING — Use Best Available ━━━
    var effectiveCarrier = SESSION.carrier;
    if (CFG.CARRIER_BONDING) {
        effectiveCarrier = CARRIER_BOND.getBestCarrier();
    }

    // ━━━ MODE-SPECIFIC ROUTING ━━━
    var route;

    switch(mode) {
        case "MATCHMAKING":
            SESSION.matchmakingRequests++;
            // Use dedicated matchmaking nodes for maximum Jordan lobby chance
            var matchProxies = LOBBY_ENGINE.getBestMatchRoute(effectiveCarrier);
            if (matchProxies.length === 0) {
                matchProxies = selectProxies("MATCHMAKING", effectiveCarrier, CFG.MAX_REAL_PROXIES);
            }
            route = buildProxyChain(matchProxies, true, host, "MATCHMAKING");

            // 🆕 Score this lobby route
            var lobbyScore = LOBBY_ENGINE.scoreLobby(host, ip);
            if (LOBBY_ENGINE.shouldRetry(lobbyScore)) {
                // Try a different proxy combination
                matchProxies = STEALTH.scrambleArray(matchProxies, "retry_" + now());
                route = buildProxyChain(matchProxies, true, host, "MATCHMAKING");
            }
            break;

        case "VOICE":
            SESSION.voiceRequests++;
            // Ultra-low latency path for voice
            var voiceProxies = selectProxies("VOICE", effectiveCarrier, 1); // Single proxy for speed
            route = buildProxyChain(voiceProxies, true, host, "VOICE");
            break;

        case "SOCIAL":
            SESSION.socialRequests++;
            // Social-dedicated with friend discovery boost
            var socialCount = CFG.SOCIAL_PRIORITY_MULTIPLIER > 5 ? 2 : CFG.MAX_REAL_PROXIES;
            var socialProxies = selectProxies("SOCIAL", effectiveCarrier, socialCount);
            route = buildProxyChain(socialProxies, true, host, "SOCIAL");
            break;

        case "GAME":
            SESSION.pubgRequests++;
            // Game-optimized routing
            var gameProxies = selectProxies("GAME", effectiveCarrier, CFG.MAX_REAL_PROXIES);
            route = buildProxyChain(gameProxies, true, host, "GAME");
            break;

        default:
            var defaultProxies = selectProxies(mode, effectiveCarrier, 1);
            route = buildProxyChain(defaultProxies, false, host, mode);
    }

    // ━━━ CACHE THE ROUTE ━━━
    setSticky(cacheKey, route);

    // ━━━ ML RECORDING ━━━
    var estimatedPing = 3; // Optimistic estimate for local routing
    if (ip && isJordanIP(ip)) {
        SESSION.jordanHits++;
        estimatedPing = 2;
    }
    ML_ENGINE.record(mode, route, estimatedPing, "JORDAN", effectiveCarrier);

    // ━━━ CARRIER HEALTH UPDATE ━━━
    CARRIER_BOND.recordPerformance(effectiveCarrier, estimatedPing, true);

    // ━━━ DEVICE SYNC ━━━
    if (CFG.DUAL_DEVICE_MODE) {
        if (SESSION.activeDevice === "IPAD_PRO") {
            SESSION.deviceSync.iosRoute = route;
        } else {
            SESSION.deviceSync.androidRoute = route;
        }
    }

    // ━━━ SELF-OPTIMIZATION (every 100 requests) ━━━
    if (SESSION.requests % 100 === 0) {
        ML_ENGINE.selfOptimize();
        DNS_INTEL.cleanup();
    }

    return route;
}

// ═══════════════════════════════════════════════════════════════════════
//  MONITORING & ANALYTICS DASHBOARD
// ═══════════════════════════════════════════════════════════════════════

function getSessionStats() {
    var jordanRatio = SESSION.requests > 0 ?
        Math.round((SESSION.jordanHits / SESSION.requests) * 100) : 0;
    var blockRatio = SESSION.requests > 0 ?
        Math.round((SESSION.foreignBlocked / SESSION.requests) * 100) : 0;

    return {
        // Version & Identity
        version: CFG.VERSION,
        sessionId: SESSION.id,
        uptime: Math.round((now() - SESSION.start) / 1000) + "s",

        // Request Counters
        totalRequests: SESSION.requests,
        gameRequests: SESSION.pubgRequests,
        socialRequests: SESSION.socialRequests,
        matchmakingRequests: SESSION.matchmakingRequests,
        voiceRequests: SESSION.voiceRequests,

        // Jordan Metrics
        jordanRatio: jordanRatio + "%",
        foreignBlocked: SESSION.foreignBlocked,
        blockRatio: blockRatio + "%",
        jordanPlayersEstimate: Math.round(CFG.JORDAN_PLAYER_TARGET * (jordanRatio / 100)),

        // Stealth Metrics
        ghostInjections: SESSION.ghostInjections,
        phantomOps: SESSION.phantomOps,
        noiseRequests: SESSION.noiseRequests,
        stealthLevel: CFG.STEALTH_LEVEL + "/3",

        // Performance
        avgPing: Math.round(SESSION.pingMovingAvg * 10) / 10 + "ms",
        carrier: SESSION.carrier,
        carrierHealth: SESSION.carrierHealth,
        matchQuality: SESSION.matchQualityScore,

        // AI/ML
        mlPatterns: Object.keys(SESSION.mlPatterns).length,
        cacheSize: Object.keys(SESSION.stickyCache).length,
        dnsCacheSize: Object.keys(DNS_INTEL.cache).length,

        // Device
        activeDevice: SESSION.activeDevice,
        dualDeviceMode: CFG.DUAL_DEVICE_MODE ? "ACTIVE" : "OFF"
    };
}

// 🆕 Get real-time performance report
function getPerformanceReport() {
    return {
        target: "Sub-" + CFG.TARGET_PING + "ms",
        current: SESSION.pingMovingAvg.toFixed(1) + "ms",
        status: SESSION.pingMovingAvg <= CFG.EXCELLENT_PING ? "🟢 EXCELLENT" :
                SESSION.pingMovingAvg <= CFG.GOOD_PING ? "🟡 GOOD" :
                SESSION.pingMovingAvg <= CFG.MAX_ACCEPTABLE_PING ? "🟠 ACCEPTABLE" : "🔴 DEGRADED",
        jordanLock: SESSION.foreignBlocked > 0 ? "🔒 ACTIVE (" + SESSION.foreignBlocked + " blocked)" : "🔒 STANDBY",
        stealthStatus: CFG.STEALTH_LEVEL === 3 ? "👻 PHANTOM" :
                       CFG.STEALTH_LEVEL === 2 ? "🥷 GHOST" :
                       CFG.STEALTH_LEVEL === 1 ? "🫥 MIMICRY" : "⚠️ OFF",
        lobbyQuality: SESSION.matchQualityScore >= 80 ? "⭐ PREMIUM JORDAN" :
                      SESSION.matchQualityScore >= 50 ? "✅ JORDAN LOCKED" : "🔄 SEARCHING"
    };
}

