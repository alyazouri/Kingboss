/* ═══════════════════════════════════════════════════════════════════
   ██  الدوال المساعدة (HELPER FUNCTIONS)
   ═══════════════════════════════════════════════════════════════════ */

/* ───────────────────────────────────────────────────────────────────
   isJordanianIP(ip)
   تتحقق: هل الـ IP ضمن أي نطاق من JORDAN_IPV4_RANGES؟
   ─────────────────────────────────────────────────────────────────── */
function isJordanianIP(ip) {
    var i;
    for (i = 0; i < JORDAN_IPV4_RANGES.length; i = i + 1) {
        if (isInNet(ip, JORDAN_IPV4_RANGES[i][0], JORDAN_IPV4_RANGES[i][1])) {
            return true;
        }
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isForeignThreat(ip)
   تتحقق: هل الـ IP ضمن FOREIGN_BLACKLIST_RANGES؟
   تستثني النطاقات الأردنية والخوادم المعروفة صراحةً.
   ─────────────────────────────────────────────────────────────────── */
function isForeignThreat(ip) {
    /* استثناء صريح: Match Server */
    if (ip === GAME_MATCH_SERVER) {
        return false;
    }
    /* استثناء صريح: Lobby Server */
    if (ip === GAME_LOBBY_SERVER) {
        return false;
    }
    /* استثناء: أي نطاق أردني */
    if (isJordanianIP(ip)) {
        return false;
    }
    /* فحص النطاقات المعادية */
    var i;
    for (i = 0; i < FOREIGN_BLACKLIST_RANGES.length; i = i + 1) {
        if (isInNet(ip, FOREIGN_BLACKLIST_RANGES[i][0], FOREIGN_BLACKLIST_RANGES[i][1])) {
            return true;
        }
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   getCachedDNS(host)
   ذاكرة مؤقتة داخليًا (TTL ≈ 30 ثانية).
   ─────────────────────────────────────────────────────────────────── */
function getCachedDNS(host) {
    var now = new Date().getTime();
    if (DNS_CACHE[host]) {
        /* إذا مرّ أكثر من 30 ثانية، أزل القيد */
        if ((now - DNS_CACHE[host].t) > 30000) {
            delete DNS_CACHE[host];
        } else {
            return DNS_CACHE[host].ip;
        }
    }
    /* حلول DNS جديد */
    var resolved = dnsResolve(host);
    if (resolved) {
        DNS_CACHE[host] = { ip: resolved, t: now };
    }
    return resolved;
}

/* ───────────────────────────────────────────────────────────────────
   extractPort(url)
   يستخرج رقم البورت من الرابط.
   إذا لم يُذكر → يرجع 80 (HTTP) أو 443 (HTTPS).
   ─────────────────────────────────────────────────────────────────── */
function extractPort(url) {
    var h;
    if (url.toLowerCase().indexOf("https://") === 0) {
        h = url.substring(8);
        var slashPos443 = h.indexOf("/");
        var hostPart443 = (slashPos443 !== -1) ? h.substring(0, slashPos443) : h;
        var colonPos443 = hostPart443.indexOf(":");
        if (colonPos443 !== -1) {
            return parseInt(hostPart443.substring(colonPos443 + 1), 10);
        }
        return 443;
    }
    if (url.toLowerCase().indexOf("http://") === 0) {
        h = url.substring(7);
        var slashPos80 = h.indexOf("/");
        var hostPart80 = (slashPos80 !== -1) ? h.substring(0, slashPos80) : h;
        var colonPos80 = hostPart80.indexOf(":");
        if (colonPos80 !== -1) {
            return parseInt(hostPart80.substring(colonPos80 + 1), 10);
        }
        return 80;
    }
    return 80;
}

/* ───────────────────────────────────────────────────────────────────
   isPUBG(host)
   تتحقق: هل الـ Hostname يتبع نطاقات PUBG / Tencent؟
   ─────────────────────────────────────────────────────────────────── */
function isPUBG(host) {
    var i;
    for (i = 0; i < PUBG_DOMAINS.length; i = i + 1) {
        if (shExpMatch(host, "*." + PUBG_DOMAINS[i]) ||
            shExpMatch(host, PUBG_DOMAINS[i])) {
            return true;
        }
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isMatch(url, host, ip, port)
   كشف الاتصالات الخاصة بالماتش / القتال الفعلي.
   ─────────────────────────────────────────────────────────────────── */
function isMatch(url, host, ip, port) {
    if (ip === GAME_MATCH_SERVER && port === GAME_MATCH_PORT) {
        return true;
    }
    var h = host.toLowerCase();
    if (h.match(/match|battle|game|combat|realtime|sync|tick|room|ingame|gsvr|gameserver|gs|battlefield|arena/)) {
        return true;
    }
    if (port === 20001 || port === 20000) {
        return true;
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isLobby(url, host, ip, port)
   كشف الاتصالات الخاصة باللوبي / التصنيف / المصادقة.
   ─────────────────────────────────────────────────────────────────── */
function isLobby(url, host, ip, port) {
    if (ip === GAME_LOBBY_SERVER && port === GAME_LOBBY_PORT) {
        return true;
    }
    var h = host.toLowerCase();
    if (h.match(/lobby|matchmaking|queue|dispatch|gateway|region|join|recruit|login|auth|account|session|token/)) {
        return true;
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isCDN(host)
   كشف أنواع الاستضافة/CDN لتوفير bandwidth (DIRECT).
   ─────────────────────────────────────────────────────────────────── */
function isCDN(host) {
    /* أنماط CDN */
    var i;
    for (i = 0; i < CDN_HOST_PATTERNS.length; i = i + 1) {
        if (shExpMatch(host, CDN_HOST_PATTERNS[i])) {
            return true;
        }
    }
    /* كلمات دلالية في الاسم */
    if (host.match(/cdn|static|assets|media|cache|edge|download|patch|update/)) {
        return true;
    }
    /* نطاقات PUBG لإعادة التحميل */
    if (isPUBG(host) && host.match(/cdn|download|patch|update|static|assets/)) {
        return true;
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isSocialPlatform(host)
   كشف منصات التواصل الاجتماعي.
   ─────────────────────────────────────────────────────────────────── */
function isSocialPlatform(host) {
    var i;
    for (i = 0; i < SOCIAL_HOST_PATTERNS.length; i = i + 1) {
        if (shExpMatch(host, SOCIAL_HOST_PATTERNS[i])) {
            return true;
        }
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isAntiLeakTarget(host, ip)
   يكشف أهداف تسريب IP (STUN/TURN) وخدمات DNS الخارجية.
   ─────────────────────────────────────────────────────────────────── */
function isAntiLeakTarget(host, ip) {
    /* STUN / TURN — تسريب IP */
    if (host.match(/stun\./) || host.match(/turn\./) ||
        host.match(/stun\.l\.google\.com/) ||
        host.match(/stun\.services\.mozilla\.com/)) {
        return true;
    }
    /* DNS خارجي — محظور (استثناء الأردني فقط) */
    if (ip === "8.8.8.8" || ip === "8.8.4.4" ||
        ip === "1.1.1.1" || ip === "1.0.0.1" ||
        ip === "208.67.222.222" || ip === "208.67.220.220" ||
        ip === "2001:4860:4860::8888" || ip === "2001:4860:4860::8844" ||
        ip === "2606:4700:4700::1111" || ip === "2606:4700:4700::1001") {
        if (!isJordanianIP(ip)) {
            return true;
        }
    }
    return false;
}

/* ───────────────────────────────────────────────────────────────────
   isForeignDomain(host)
   كشف النطاقات ذات البادئات الجغرافية الأجنبية.
   ─────────────────────────────────────────────────────────────────── */
function isForeignDomain(host) {
    var h = host.toLowerCase();
    if (h.match(/(^|\.)eu\./) || h.match(/(^|\.)ru\./) ||
        h.match(/(^|\.)asia\./) || h.match(/(^|\.)na\./) ||
        h.match(/(^|\.)sa\./) || h.match(/(^|\.)kr\./) ||
        h.match(/(^|\.)jp\./) || h.match(/(^|\.)us\./) ||
        h.match(/(^|\.)euw\./) || h.match(/(^|\.)eune\./) ||
        h.match(/(^|\.)oce\./) || h.match(/(^|\.)lan\./) ||
        h.match(/(^|\.)las\./) || h.match(/(^|\.)br\./) ||
        h.match(/(^|\.)tr\./) || h.match(/(^|\.)pbe\./) ||
        h.match(/(^|\.)sea\./) || h.match(/(^|\.)tw\./) ||
        h.match(/(^|\.)hk\./) || h.match(/(^|\.)sg\./) ||
        h.match(/(^|\.)de\./) || h.match(/(^|\.)fr\./) ||
        h.match(/(^|\.)uk\./) || h.match(/(^|\.)nl\./)) {
        return true;
    }
    /* نطاقات بلدان أجنبية معروفة */
    if (h.match(/\.(ru|cn|kp|ir|sy|by|cu|ve|su)\b/)) {
        return true;
    }
    return false;
}

/* ═══════════════════════════════════════════════════════════════════
   ██  القفل الأردني الجلسي (Ultra Jordan Session Lock)
   ═══════════════════════════════════════════════════════════════════ */

/* ───────────────────────────────────────────────────────────────────
   lockSession(ip, host, port)
   يُنشئ القفل عند أول اكتشاف ماتش.
   ─────────────────────────────────────────────────────────────────── */
function lockSession(ip, host, port) {
    SESSION.matchIP   = ip;
    SESSION.matchNet  = ip.split(".")[0] + "." + ip.split(".")[1] + ".0.0";
    SESSION.matchHost = host;
    SESSION.matchPort = port;
    SESSION.locked    = true;
    SESSION.timestamp = new Date().getTime();
}

/* ───────────────────────────────────────────────────────────────────
   enforceJordanLock(ip, host, port)
   يفرض القفل بعد إنشائه:
   - يسمح فقط بالـ IP الأردني، أو المطابق للجلسة، أو ضمن نفس الـ /16.
   - أي انحراف → BLOCK فوري.
   ─────────────────────────────────────────────────────────────────── */
function enforceJordanLock(ip, host, port) {
    if (!SESSION.locked) {
        return null;
    }

    /* انتهاء صلاحية القفل: 30 دقيقة */
    var now = new Date().getTime();
    if ((now - SESSION.timestamp) > 1800000) {
        SESSION.locked    = false;
        SESSION.matchIP   = null;
        SESSION.matchNet  = null;
        SESSION.matchHost = null;
        SESSION.matchPort = null;
        SESSION.timestamp = 0;
        return null;
    }

    /* الـ IP ضمن النطاقات الأردنية — مسموح */
    if (isJordanianIP(ip)) {
        return null;
    }

    /* الـ IP مطابق لجلسة الماتش — مسموح عبر البروكسي */
    if (ip === SESSION.matchIP) {
        return PROXY_A;
    }

    /* الـ Hostname مطابق — مسموح عبر البروكسي */
    if (host === SESSION.matchHost) {
        return PROXY_A;
    }

    /* ضمن نفس الـ /16 الأردني — مسموح عبر البروكسي */
    if (isInNet(ip, SESSION.matchNet, "255.255.0.0")) {
        return PROXY_A;
    }

    /* انحراف عن الجلسة — حظر فوري */
    return BLOCK;
}

/* ═══════════════════════════════════════════════════════════════════
   ██  الدالة الرئيسية (MAIN — FindProxyForURL)
   ═══════════════════════════════════════════════════════════════════ */

function FindProxyForURL(url, host) {

    /* ── تنظيف المدخلات ── */
    var h    = host.toLowerCase();
    var u    = url.toLowerCase();
    var port = extractPort(u);

    /* ───────────────────────────────────────────────────────────────
       §0  الشبكات المحلية (localhost / LAN) → DIRECT
       ─────────────────────────────────────────────────────────────── */
    if (isPlainHostName(h) ||
        h === "localhost" ||
        h === "127.0.0.1" ||
        shExpMatch(h, "127.*") ||
        isInNet(h, "192.168.120.0", "255.255.255.0") ||
        isInNet(h, "10.0.0.0", "255.0.0.0") ||
        isInNet(h, "172.16.0.0", "255.240.0.0") ||
        isInNet(h, "169.254.0.0", "255.255.0.0") ||
        isInNet(h, "224.0.0.0", "240.0.0.0") ||
        isInNet(h, "::1", "ffff:ffff:ffff:ffff:ffff:ffff:ffff:ffff") ||
        shExpMatch(h, "fe80::*") ||
        isInNet(h, "fc00::", "fe00::") ||
        isInNet(h, "ff00::", "ff00::")) {
        return DIRECT;
    }

    /* ───────────────────────────────────────────────────────────────
       §1  القائمة الآمنة (Apple / Google / Captive Portal) → DIRECT
       ─────────────────────────────────────────────────────────────── */
    if (h === "captive.apple.com" ||
        h === "www.apple.com" ||
        h === "gs.apple.com" ||
        h === "apple.com" ||
        h === "clients1.google.com" ||
        h === "clients3.google.com" ||
        h === "connectivitycheck.gstatic.com" ||
        h === "www.gstatic.com" ||
        h === "www.msftconnecttest.com" ||
        h === "msftconnecttest.com" ||
        h === "www.msftncsi.com" ||
        h === "detectportal.firefox.com" ||
        h === "captive.vodafone.ie" ||
        h === "nmcheck.gnome.org" ||
        shExpMatch(h, "*.mzstatic.com") ||
        shExpMatch(h, "*.apple.com") ||
        shExpMatch(h, "*.icloud.com") ||
        shExpMatch(h, "*.googleapis.com")) {
        return DIRECT;
    }

    /* ───────────────────────────────────────────────────────────────
       §2  حماية Anti-Leak / STUN / DNS الأجنبي → BLOCK
       ─────────────────────────────────────────────────────────────── */

    /* تحليل DNS المبدئي */
    var ip = getCachedDNS(h);

    if (isAntiLeakTarget(h, ip)) {
        return BLOCK;
    }

    /* إذا تعذّر التحليل وليس نطاقاً أردنياً → BLOCK */
    if (!ip) {
        /* الأسماء المسطحة (بدون نقطة) قد تكون LAN */
        if (isPlainHostName(h)) {
            return DIRECT;
        }
        /* نطاقات أردنية غير محلولة → BLOCK (أمان) */
        if (h.match(/\.jo$/) || h.match(/\.gov\.jo$/)) {
            return BLOCK;
        }
        /* نطاقات أجنبية غير محلولة → BLOCK */
        if (h.match(/\.com$|\.net$|\.org$|\.io$|\.co$|\.me$|\.tv$/)) {
            return BLOCK;
        }
        return BLOCK;
    }

    /* ───────────────────────────────────────────────────────────────
       §3  Match Server المحدد (94.127.211.6:20001) → PROXY + LOCK
       ─────────────────────────────────────────────────────────────── */
    if (ip === GAME_MATCH_SERVER && port === GAME_MATCH_PORT) {
        lockSession(ip, h, port);
        return PROXY_A;
    }

    /* ───────────────────────────────────────────────────────────────
       §4  Lobby Server المحدد (109.237.193.187:80) → PROXY
       ─────────────────────────────────────────────────────────────── */
    if (ip === GAME_LOBBY_SERVER && port === GAME_LOBBY_PORT) {
        return PROXY_A;
    }

    /* ───────────────────────────────────────────────────────────────
       §5  النطاقات المعادية (Foreign Threat) → BLOCK
       ─────────────────────────────────────────────────────────────── */
    if (isForeignThreat(ip)) {
        return BLOCK;
    }

    /* ───────────────────────────────────────────────────────────────
       §6  النطاقات الأردنية (Jordan Sovereign IP)
       ─────────────────────────────────────────────────────────────── */
    if (isJordanianIP(ip)) {

        /* 6a. Match / Game traffic → PROXY + SESSION LOCK */
        if (isMatch(u, h, ip, port)) {
            lockSession(ip, h, port);
            return PROXY_A;
        }

        /* 6b. Lobby / Auth / Matchmaking → PROXY */
        if (isLobby(u, h, ip, port)) {
            return PROXY_A;
        }

        /* 6c. CDN / Static Assets → DIRECT (توفير bandwidth) */
        if (isCDN(h)) {
            return DIRECT;
        }

        /* 6d. Social / CDN domains → PROXY */
        if (isSocialPlatform(h) || isPUBG(h)) {
            return PROXY_A;
        }

        /* 6e. أي IP أردني آخر → DIRECT */
        return DIRECT;
    }

    /* ───────────────────────────────────────────────────────────────
       §7  IP أجنبي غير محظور صراحةً — فحص القفل الجلسي
       ─────────────────────────────────────────────────────────────── */
    if (SESSION.locked) {
        var lockResult = enforceJordanLock(ip, h, port);
        if (lockResult !== null) {
            return lockResult;
        }
    }

    /* ───────────────────────────────────────────────────────────────
       §8  نطاقات بأسماء أجنبية واضحة → BLOCK
       ─────────────────────────────────────────────────────────────── */
    if (isForeignDomain(h)) {
        return BLOCK;
    }

    /* ───────────────────────────────────────────────────────────────
       §9  Failover للوبي فقط (DIRECT إذا تعذّر البروكسي)
       ─────────────────────────────────────────────────────────────── */
    if (ip === GAME_LOBBY_SERVER) {
        return "PROXY_A_DIRECT";
        /* ملاحظة: بعض المتصفحات تدعم fallback تلقائي.
           إذا لم يدعم متصفحك، استخدم: return DIRECT; */
    }

    /* ───────────────────────────────────────────────────────────────
       §10  الافتراضي — حظر أي اتصال خارجي غير معروف
       ─────────────────────────────────────────────────────────────── */
    return BLOCK;
}
