function generatePerformanceReport() {
    if (!CFG.AUTO_REPORT_GENERATION) return null;
    return {
        version: CFG.VERSION,
        codename: CFG.CODENAME,
        session: SESSION.getReport(),
        dns: DNS_STATS,
        ping: {
            current: PING.current(),
            avg: PING.avg(),
            socialAvg: PING.socialAvg(),
            best: PING.best(),
            jitter: PING.jitter(),
            trend: PING.trend(),
            stability: PING.stability(),
            variance: PING.variance()
        },
        social: {
            friendDiscoveries: SESSION.friendDiscoveries,
            crewSearches: SESSION.crewSearches,
            lobbyJoins: SESSION.lobbyJoins,
            jordanPlayersFound: SESSION.jordanPlayersFound,
            socialAPIcalls: SESSION.socialAPIcalls,
            jordanPlayerRatio: SESSION.jordanRatio() + "%"
        },
        bandwidth: BANDWIDTH.getReport(),
        qos: QOS.queues,
        antiThrottle: {
            detected: ANTI_THROTTLE.detected,
            bypassActive: ANTI_THROTTLE.bypassActive,
            detectionCount: ANTI_THROTTLE.detectionCount
        },
        connection: CONNECTION.profile(),
        ml: {
            patterns: Object.keys(ML.patterns).length,
            socialPatterns: Object.keys(ML.socialPatterns).length,
            bandwidthPatterns: Object.keys(ML.bandwidthPatterns).length,
            learningDataPoints: ML.learningData.length
        },
        bestProxies: {
            all: getBestProxies(null, null, 5, false, false, false),
            social: getBestProxies(null, null, 3, true, false, false),
            lobby: getBestProxies(null, null, 3, true, true, false),
            game: getBestProxies(null, null, 3, false, false, true),
            quantum: getBestProxies(0, null, 3, false, false, false)
        }
    };
}


