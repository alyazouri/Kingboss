};


// ═══════════════════════════════════════════════════════════════════════
//  BANDWIDTH MAXIMIZER ENGINE v3
//  ⚡ أقصى استخدام للإنترنت لأقوى أداء
// ═══════════════════════════════════════════════════════════════════════

var BANDWIDTH = {
    // Current allocation state
    gameAllocation: CFG.BANDWIDTH_ALLOCATION_GAME,
    socialAllocation: CFG.BANDWIDTH_ALLOCATION_SOCIAL,
    cdnAllocation: CFG.BANDWIDTH_ALLOCATION_CDN,

    // Bandwidth tracking
    totalUsed: 0,
    gameUsed: 0,
    socialUsed: 0,
    cdnUsed: 0,
    peakUsage: 0,
    avgUsage: 0,
    samples: [],
    maxSamples: 50,

    // ISP bandwidth pools (Mbps)
    pools: {
        ORANGE: { total: 10000, used: 0, available: 10000 },
        ZAIN:   { total: 10000, used: 0, available: 10000 },
        UMNIAH: { total: 5000,  used: 0, available: 5000  },
        JT:     { total: 1000,  used: 0, available: 1000  }
    },

    // Maximize bandwidth for game traffic
    maximize: function(trafficType) {
        if (!CFG.BANDWIDTH_MAXIMIZER) return 100;

        if (trafficType === "GAME") {
            // Game gets maximum bandwidth
            var gameBoost = 100;
            if (this.socialUsed < 200) gameBoost += 20; // Extra if social is light
            return Math.min(100, gameBoost);
        }

        if (trafficType === "SOCIAL") {
            // Social gets priority during lobby/friend search
            return 100;
        }

        if (trafficType === "CDN") {
            // CDN uses remaining bandwidth
            return 30;
        }

        return 100;
    },

    // Adaptive bandwidth scaling based on game state
    adaptivScale: function(gameState, mode) {
        var m = MODES[mode];
        if (!m) return { game: 70, social: 20, cdn: 10 };

        if (gameState === "IN_GAME") {
            return { game: 80, social: 15, cdn: 5 };
        }

        if (gameState === "PRE_MATCH" || gameState === "SOCIAL") {
            return { game: 30, social: 65, cdn: 5 };
        }

        if (gameState === "AUTH") {
            return { game: 10, social: 85, cdn: 5 };
        }

        if (gameState === "DOWNLOAD") {
            return { game: 5, social: 5, cdn: 90 };
        }

        return { game: 70, social: 20, cdn: 10 };
    },

    // Record bandwidth usage
    record: function(bytes, type) {
        this.totalUsed += bytes;
        if (type === "GAME") this.gameUsed += bytes;
        if (type === "SOCIAL") this.socialUsed += bytes;
        if (type === "CDN") this.cdnUsed += bytes;

        if (bytes > this.peakUsage) this.peakUsage = bytes;

        if (this.samples.length >= this.maxSamples) this.samples.shift();
        this.samples.push({ bytes: bytes, type: type, t: now() });

        if (this.samples.length > 0) {
            var sum = 0;
            for (var i = 0; i < this.samples.length; i++) sum += this.samples[i].bytes;
            this.avgUsage = Math.round(sum / this.samples.length);
        }
    },

    // Get best ISP for bandwidth
    getBestISP: function(required) {
        var best = null, bestAvail = 0;
        for (var isp in this.pools) {
            var pool = this.pools[isp];
            if (pool.available >= required && pool.available > bestAvail) {
                bestAvail = pool.available;
                best = isp;
            }
        }
        return best;
    },

    // Check if ISP has capacity
    hasCapacity: function(carrier, required) {
        var pool = this.pools[carrier];
        return pool && pool.available >= (required || 0);
    },

    // Multi-ISP load balance for maximum throughput
    getLoadBalancedCarriers: function() {
        var carriers = [];
        for (var isp in this.pools) {
            if (this.pools[isp].available > 100) {
                carriers.push({
                    carrier: isp,
                    available: this.pools[isp].available,
                    ratio: this.pools[isp].available / this.pools[isp].total
                });
            }
        }
        carriers.sort(function(a, b) { return b.available - a.available; });
        return carriers;
    },

    getReport: function() {
        return {
            totalUsed: this.totalUsed,
            gameUsed: this.gameUsed,
            socialUsed: this.socialUsed,
            cdnUsed: this.cdnUsed,
            peakUsage: this.peakUsage,
            avgUsage: this.avgUsage,
            pools: this.pools
        };
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  QoS ENGINE — جودة الخدمة ومنح الأولوية لحزم اللعبة
// ═══════════════════════════════════════════════════════════════════════

var QOS = {
    queues: {
        HIGHEST:  { priority: 0, maxBw: 100, currentBw: 0, packets: 0 },
        HIGH:     { priority: 1, maxBw: 85,  currentBw: 0, packets: 0 },
        MEDIUM:   { priority: 2, maxBw: 60,  currentBw: 0, packets: 0 },
        LOW:      { priority: 3, maxBw: 30,  currentBw: 0, packets: 0 },
        MINIMAL:  { priority: 4, maxBw: 10,  currentBw: 0, packets: 0 }
    },

    // Map traffic type to QoS queue
    classify: function(mode, trafficType) {
        var m = MODES[mode];
        if (!m) return "MEDIUM";

        if (trafficType === "GAME_UDP" || trafficType === "VOICE") return "HIGHEST";
        if (m.socialPriority) return "HIGH";
        if (m.priority >= 9) return "HIGH";
        if (m.priority >= 7) return "MEDIUM";
        if (trafficType === "CDN") return "MINIMAL";
        return "LOW";
    },

    // Get port priority boost
    getPortBoost: function(port) {
        // UDP game ports
        if (port >= 10000 && port <= 20000) return 30;
        if (port >= 7000 && port <= 8000) return 25;
        // HTTPS (encrypted game traffic)
        if (port === 443) return 20;
        // HTTP
        if (port === 80 || port === 8080) return 15;
        return 0;
    },

    // Calculate effective bandwidth allocation
    getEffectiveBW: function(queueType, mode) {
        var queue = this.queues[queueType];
        if (!queue) return 50;

        var base = queue.maxBw;
        var m = MODES[mode];

        // Boost for game + social modes
        if (m && m.socialPriority && queueType === "HIGH") base += 15;
        if (m && m.gameState === "IN_GAME" && queueType === "HIGHEST") base += 10;

        return Math.min(100, base);
    },

    recordPacket: function(queueType, size) {
        if (this.queues[queueType]) {
            this.queues[queueType].packets++;
            this.queues[queueType].currentBw += size;
        }
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  ANTI-THROTTLE ENGINE — تجاوز حجب مزودي الإنترنت
// ═══════════════════════════════════════════════════════════════════════

var ANTI_THROTTLE = {
    detected: false,
    bypassActive: false,
    detectionCount: 0,
    lastDetection: 0,
    portRotationIndex: 0,

    // Port rotation for anti-throttle
    portList: [443, 8080, 80, 3128, 8443, 10000, 10001, 20005],

    // Detect ISP throttling
    detect: function() {
        if (!CFG.THROTTLE_DETECTION) return false;

        var currentPing = PING.avg(3);
        var trend = PING.trend();
        var variance = PING.variance();

        // Signs of throttling: high ping + degrading + high variance
        if (currentPing > CFG.MAX_ACCEPTABLE_PING * 2 &&
            trend === "DEGRADING" &&
            variance > 15) {
            this.detectionCount++;
            this.lastDetection = now();

            if (this.detectionCount >= 3) {
                this.detected = true;
                return true;
            }
        } else {
            if (now() - this.lastDetection > 60000) {
                this.detectionCount = Math.max(0, this.detectionCount - 1);
                this.detected = false;
            }
        }
        return false;
    },

    // Get bypass port
    getBypassPort: function(proxy) {
        if (!this.detected || !CFG.PORT_ROTATION) {
            return proxy.port;
        }

        // Try alt ports
        if (proxy.altPorts && proxy.altPorts.length > 0) {
            this.portRotationIndex = (this.portRotationIndex + 1) % proxy.altPorts.length;
            return proxy.altPorts[this.portRotationIndex];
        }

        // Rotate from port list
        this.portRotationIndex = (this.portRotationIndex + 1) % this.portList.length;
        return this.portList[this.portRotationIndex];
    },

    // Activate bypass
    activateBypass: function() {
        this.bypassActive = true;
        // Force sticky session clear to use new ports
        for (var mode in STICKY) {
            stickyClear(mode);
        }
    },

    reset: function() {
        this.detected = false;
        this.bypassActive = false;
        this.detectionCount = 0;
    }
};


