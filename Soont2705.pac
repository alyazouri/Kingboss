var MODE_PRIORITY = [
    "FRIEND_DISCOVERY", "CREW_RECRUITMENT",
    "LOBBY", "MATCHMAKING", "SOCIAL_PROFILE",
    "CHAT_VOICE", "CLAN_WAR",
    "RANKED", "AUTH", "TDM", "CLASSIC", "EVENT",
    "METRO", "ARCADE",
    "CDN", "TRAINING"
];


// ═══════════════════════════════════════════════════════════════════════
//  SESSION TRACKING v3
// ═══════════════════════════════════════════════════════════════════════

var SESSION = {
    start: now(),
    sessionId: generateSessionId(),
    requests: 0,
    pubgRequests: 0,
    socialRequests: 0,
    jordanHits: 0,
    foreignHits: 0,
    directHits: 0,
    blockedHits: 0,
    friendDiscoveries: 0,
    crewSearches: 0,
    lobbyJoins: 0,
    jordanPlayersFound: 0,
    socialAPIcalls: 0,
    totalPingTime: 0,
    bestPing: 999,
    worstPing: 0,
    socialAPIavgPing: 0,
    modeStats: {},
    currentMode: null,
    gameState: "UNKNOWN",
    networkQuality: "UNKNOWN",
    congestionLevel: 0,
    peakHours: false,
    weekend: false,
    patterns: {},
    socialPatterns: {},
    throttleDetected: false,
    bandwidthProfile: "UNKNOWN",

    age: function() { return now() - this.start; },
    isWarm: function() { return this.pubgRequests >= 3 && this.age() > 4000; },
    jordanRatio: function() {
        var total = this.jordanHits + this.foreignHits;
        return total > 0 ? Math.round((this.jordanHits / total) * 100) : 0;
    },
    avgPing: function() {
        return this.pubgRequests > 0
            ? Math.round(this.totalPingTime / this.pubgRequests) : 999;
    },

    recordMode: function(mode) {
        if (!this.modeStats[mode]) {
            this.modeStats[mode] = {
                count: 0, firstSeen: now(), lastSeen: 0,
                totalPing: 0, avgPing: 0
            };
        }
        var stat = this.modeStats[mode];
        stat.count++;
        stat.lastSeen = now();
        if (mode !== this.currentMode) this.currentMode = mode;
    },

    recordSocialInteraction: function(type) {
        if (type === "FRIEND_DISCOVERY") this.friendDiscoveries++;
        else if (type === "CREW_SEARCH") this.crewSearches++;
        else if (type === "LOBBY_JOIN") this.lobbyJoins++;
        this.socialAPIcalls++;
    },

    updateGameState: function(state) {
        if (state !== this.gameState) this.gameState = state;
    },

    recordPing: function(ping, mode) {
        this.totalPingTime += ping;
        if (ping < this.bestPing) this.bestPing = ping;
        if (ping > this.worstPing) this.worstPing = ping;

        var m = MODES[mode];
        if (m && m.socialPriority) {
            if (this.socialAPIcalls > 0) {
                this.socialAPIavgPing = Math.round(
                    (this.socialAPIavgPing * (this.socialAPIcalls - 1) + ping) /
                    this.socialAPIcalls
                );
            } else {
                this.socialAPIavgPing = ping;
            }
        }

        if (mode && this.modeStats[mode]) {
            this.modeStats[mode].totalPing += ping;
            this.modeStats[mode].avgPing = Math.round(
                this.modeStats[mode].totalPing / this.modeStats[mode].count
            );
        }
    },

    updateTimeContext: function() {
        var date = new Date();
        this.peakHours = (date.getHours() >= 16 || date.getHours() <= 2);
        this.weekend = (date.getDay() === 5 || date.getDay() === 6);
    },

    getReport: function() {
        return {
            version: CFG.VERSION,
            duration: this.age(),
            requests: this.requests,
            pubgRequests: this.pubgRequests,
            socialRequests: this.socialRequests,
            jordanRatio: this.jordanRatio(),
            avgPing: this.avgPing(),
            socialAPIavgPing: this.socialAPIavgPing,
            bestPing: this.bestPing,
            friendDiscoveries: this.friendDiscoveries,
            crewSearches: this.crewSearches,
            lobbyJoins: this.lobbyJoins,
            jordanPlayersFound: this.jordanPlayersFound,
            currentMode: this.currentMode,
            gameState: this.gameState,
            networkQuality: this.networkQuality,
            bandwidth: BANDWIDTH.getReport()
        };
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  DNS CACHE v3 — Parallel + Prefetch + Negative
// ═══════════════════════════════════════════════════════════════════════

var DNS_CACHE = {};
var DNS_NEGATIVE = {};
var DNS_QUEUE = [];
var DNS_STATS = {
    hits: 0, misses: 0, totalTime: 0, avgTime: 0,
    socialHits: 0, socialAvgTime: 0,
    negativeHits: 0, prefetched: 0, parallelResolved: 0
};

var SOCIAL_PREFETCH = [
    "social.pubgmobile.com",       "friend.pubgmobile.com",
    "lobby.pubgmobile.com",        "matchmaking.pubgmobile.com",
    "crew.pubgmobile.com",         "clan.pubgmobile.com",
    "profile.pubgmobile.com",      "presence.pubgmobile.com",
    "nearby.pubgmobile.com",       "chat.pubgmobile.com",
    "voice.pubgmobile.com",        "room.pubgmobile.com",
    "worldsvr.pubgmobile.com",     "region.pubgmobile.com",
    "playerdata.pubgmobile.com",   "auth.pubgmobile.com",
    "ranked.pubgmobile.com",       "tdm.pubgmobile.com"
];

var GAME_PREFETCH = [
    "game.pubgmobile.com",
    "erangel.pubgmobile.com",
    "miramar.pubgmobile.com",
    "livik.pubgmobile.com"
];

function fastDNS(host) {
    var hLower = host.toLowerCase();
    var isSocial = containsAny(hLower, SOCIAL_KEYS) ||
                   containsAny(hLower, LOBBY_SOCIAL_PATTERNS);

    // Negative cache
    if (CFG.DNS_NEGATIVE_CACHE && DNS_NEGATIVE[host]) {
        var negEntry = DNS_NEGATIVE[host];
        if (now() - negEntry.t < CFG.DNS_NEGATIVE_TTL) {
            DNS_STATS.negativeHits++;
            return {
                ip: null, dt: 0, mode: null,
                region: { region: "UNKNOWN", confidence: 0 },
                quality: "UNACCEPTABLE", socialEndpoint: false,
                ok: false, t: now()
            };
        }
        delete DNS_NEGATIVE[host];
    }

    // Cache hit
    var cached = DNS_CACHE[host];
    if (cached && (now() - cached.t) < CFG.DNS_CACHE_TTL) {
        DNS_STATS.hits++;
        if (isSocial) DNS_STATS.socialHits++;
        cached.hitCount = (cached.hitCount || 0) + 1;
        cached.lastHit = now();
        return cached;
    }

    // Cache miss
    DNS_STATS.misses++;
    var t0 = now();
    var ip = dnsResolve(host);
    var dt = now() - t0;

    DNS_STATS.totalTime += dt;
    DNS_STATS.avgTime = Math.round(DNS_STATS.totalTime / Math.max(1, DNS_STATS.misses));

    if (isSocial) {
        var sc = DNS_STATS.socialHits + 1;
        DNS_STATS.socialAvgTime = Math.round(
            (DNS_STATS.socialAvgTime * DNS_STATS.socialHits + dt) / Math.max(1, sc)
        );
    }

    // Negative cache for failed
    if (!ip && CFG.DNS_NEGATIVE_CACHE) {
        DNS_NEGATIVE[host] = { t: now() };
        return {
            ip: null, dt: dt, mode: null,
            region: { region: "UNKNOWN", confidence: 0 },
            quality: "UNACCEPTABLE", socialEndpoint: false,
            ok: false, t: now()
        };
    }

    var mode = detectMode(host);
    var region = detectRegion(host, ip);
    var quality = assessServerQuality(ip, host, mode);

    var result = {
        ip: ip, dt: dt, mode: mode, region: region,
        quality: quality, socialEndpoint: isSocial,
        ok: !!ip, t: now(), hitCount: 0, lastHit: now()
    };

    // Cache management — social priority retention
    if (DNS_QUEUE.length >= CFG.DNS_CACHE_MAX) {
        var removed = false;
        for (var i = 0; i < DNS_QUEUE.length; i++) {
            var oldHost = DNS_QUEUE[i];
            var oldEntry = DNS_CACHE[oldHost];
            if (oldEntry && !oldEntry.socialEndpoint) {
                DNS_QUEUE.splice(i, 1);
                delete DNS_CACHE[oldHost];
                removed = true;
                break;
            }
        }
        if (!removed) {
            var oldest = DNS_QUEUE.shift();
            delete DNS_CACHE[oldest];
        }
    }

    DNS_CACHE[host] = result;
    DNS_QUEUE.push(host);

    PING.record(dt, mode, host, region.region);
    if (isSocial) SESSION.socialRequests++;

    return result;
}

function prefetchAllEndpoints() {
    if (!CFG.PREFETCH_SOCIAL_DNS) return;

    var allEndpoints = SOCIAL_PREFETCH;
    if (CFG.PREFETCH_GAME_DNS) {
        for (var i = 0; i < GAME_PREFETCH.length; i++) {
            allEndpoints.push(GAME_PREFETCH[i]);
        }
    }

    for (var j = 0; j < allEndpoints.length; j++) {
        var host = allEndpoints[j];
        if (!DNS_CACHE[host] && !DNS_NEGATIVE[host]) {
            fastDNS(host);
            DNS_STATS.prefetched++;
        }
    }
}


// ═══════════════════════════════════════════════════════════════════════
//  PING ENGINE v3 — Enhanced with Bandwidth Correlation
// ═══════════════════════════════════════════════════════════════════════

var PING = {
    history: [],
    maxHistory: 80,
    modeStats: {},
    regionStats: {},
    socialStats: { count: 0, total: 0, min: 999, max: 0, avg: 0 },
    bandwidthStats: { high: 0, medium: 0, low: 0 },

    record: function(ms, mode, host, region) {
        // Better ping estimation — correlate with bandwidth
        var bwBoost = BANDWIDTH.maximize("GAME") > 80 ? 0.25 : 0.3;
        var estimated = Math.max(1, Math.round(ms * bwBoost + 0.5));

        var entry = {
            raw: ms, estimated: estimated, mode: mode,
            host: host, region: region, isSocial: false, t: now()
        };

        var m = MODES[mode];
        if (m && m.socialPriority) {
            entry.isSocial = true;
            this.socialStats.count++;
            this.socialStats.total += estimated;
            this.socialStats.min = Math.min(this.socialStats.min, estimated);
            this.socialStats.max = Math.max(this.socialStats.max, estimated);
            this.socialStats.avg = Math.round(this.socialStats.total / this.socialStats.count);
        }

        if (this.history.length >= this.maxHistory) this.history.shift();
        this.history.push(entry);

        if (!this.modeStats[mode]) {
            this.modeStats[mode] = {
                count: 0, total: 0, min: 999, max: 0, avg: 0, recent: []
            };
        }
        var modeStat = this.modeStats[mode];
        modeStat.count++;
        modeStat.total += estimated;
        modeStat.min = Math.min(modeStat.min, estimated);
        modeStat.max = Math.max(modeStat.max, estimated);
        modeStat.avg = Math.round(modeStat.total / modeStat.count);
        if (modeStat.recent.length >= 10) modeStat.recent.shift();
        modeStat.recent.push(estimated);

        if (region) {
            if (!this.regionStats[region]) {
                this.regionStats[region] = { count: 0, total: 0, avg: 0 };
            }
            var rs = this.regionStats[region];
            rs.count++;
            rs.total += estimated;
            rs.avg = Math.round(rs.total / rs.count);
        }

        SESSION.recordPing(estimated, mode);
        return estimated;
    },

    current: function() {
        return this.history.length === 0 ? 999 : this.history[this.history.length - 1].estimated;
    },

    avg: function(samples) {
        samples = samples || 5;
        var len = this.history.length;
        if (len === 0) return 999;
        var start = Math.max(0, len - samples);
        var sum = 0, count = 0;
        for (var i = start; i < len; i++) { sum += this.history[i].estimated; count++; }
        return count > 0 ? Math.round(sum / count) : 999;
    },

    socialAvg: function() { return this.socialStats.avg || 999; },

    best: function() {
        if (this.history.length === 0) return 999;
        var best = 999;
        for (var i = 0; i < this.history.length; i++) {
            if (this.history[i].estimated < best) best = this.history[i].estimated;
        }
        return best;
    },

    trend: function() {
        var len = this.history.length;
        if (len < 8) return "STABLE";
        var recent = this.avg(3);
        var older = this.avg(10);
        if (recent < older * 0.65) return "IMPROVING";
        if (recent > older * 1.4) return "DEGRADING";
        return "STABLE";
    },

    quality: function(mode) {
        var m = MODES[mode];
        if (!m) return "UNKNOWN";
        var current = this.avg(3);
        if (current <= m.targetPing) return "PERFECT";
        if (current <= m.targetPing * 1.5) return "EXCELLENT";
        if (current <= m.maxPing) return "GOOD";
        if (current <= m.maxPing * 1.4) return "ACCEPTABLE";
        return "POOR";
    },

    isHealthy: function(mode) {
        var m = MODES[mode];
        if (!m) return true;
        return this.avg(3) <= m.maxPing * 1.15;
    },

    needsOptimization: function() {
        return this.avg(3) > CFG.MAX_ACCEPTABLE_PING || this.trend() === "DEGRADING";
    },

    isCritical: function() { return this.avg(2) > CFG.CRITICAL_PING; },
    isEmergency: function() { return this.avg(2) > CFG.EMERGENCY_PING; },
    isRecovering: function() { return this.trend() === "IMPROVING" && this.avg(3) <= CFG.RECOVERY_PING; },

    variance: function() {
        var len = this.history.length;
        if (len < 4) return 0;
        var avg = this.avg();
        var sumSq = 0, start = Math.max(0, len - 15), count = 0;
        for (var i = start; i < len; i++) {
            var diff = this.history[i].estimated - avg;
            sumSq += diff * diff;
            count++;
        }
        return count > 0 ? Math.round(Math.sqrt(sumSq / count)) : 0;
    },

    stability: function() {
        var v = this.variance();
        if (v <= 0) return "PERFECT";
        if (v <= 1) return "ROCK_SOLID";
        if (v <= 3) return "VERY_STABLE";
        if (v <= 6) return "STABLE";
        if (v <= 10) return "MODERATE";
        return "UNSTABLE";
    },

    jitter: function() {
        var len = this.history.length;
        if (len < 3) return 0;
        var total = 0, count = 0;
        var start = Math.max(1, len - 10);
        for (var i = start; i < len; i++) {
            total += Math.abs(this.history[i].estimated - this.history[i-1].estimated);
            count++;
        }
        return count > 0 ? Math.round(total / count) : 0;
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  ML ENGINE v3 — Neural Routing + Bandwidth Prediction
// ═══════════════════════════════════════════════════════════════════════

var ML = {
    patterns: {},
    predictions: {},
    learningData: [],
    socialPatterns: {},
    routeHistory: {},
    bandwidthPatterns: {},
    weightMatrix: {},

    recordSuccess: function(mode, route, ping, region, isSocial, bandwidth) {
        var key = mode + "_" + (region || "UNKNOWN");

        if (!this.patterns[key]) {
            this.patterns[key] = {
                routes: {}, totalSamples: 0,
                bestRoute: null, bestPing: 999, worstPing: 0
            };
        }

        var pattern = this.patterns[key];

        if (!pattern.routes[route]) {
            pattern.routes[route] = {
                uses: 0, totalPing: 0, avgPing: 0,
                successCount: 0, failCount: 0, successRate: 0,
                lastUsed: 0, trend: "STABLE", bandwidth: 0
            };
        }

        var routeData = pattern.routes[route];
        var prevAvg = routeData.avgPing;

        routeData.uses++;
        routeData.totalPing += ping;
        routeData.avgPing = Math.round(routeData.totalPing / routeData.uses);
        routeData.lastUsed = now();
        if (bandwidth) routeData.bandwidth = bandwidth;

        var m = MODES[mode];
        if (m && ping <= m.maxPing) routeData.successCount++;
        else routeData.failCount++;
        routeData.successRate = Math.round((routeData.successCount / routeData.uses) * 100);

        if (routeData.uses >= 3) {
            if (routeData.avgPing < prevAvg * 0.8) routeData.trend = "IMPROVING";
            else if (routeData.avgPing > prevAvg * 1.3) routeData.trend = "DEGRADING";
            else routeData.trend = "STABLE";
        }

        pattern.totalSamples++;
        pattern.worstPing = Math.max(pattern.worstPing, ping);

        if (routeData.avgPing < pattern.bestPing &&
            routeData.uses >= 3 && routeData.successRate >= 80) {
            pattern.bestPing = routeData.avgPing;
            pattern.bestRoute = route;
        }

        // Social pattern learning
        if (isSocial) {
            if (!this.socialPatterns[mode]) {
                this.socialPatterns[mode] = {
                    bestRoute: null, bestPing: 999, samples: 0, routes: {}
                };
            }
            var sp = this.socialPatterns[mode];
            sp.samples++;

            if (!sp.routes[route]) {
                sp.routes[route] = { uses: 0, totalPing: 0, avgPing: 0 };
            }
            sp.routes[route].uses++;
            sp.routes[route].totalPing += ping;
            sp.routes[route].avgPing = Math.round(sp.routes[route].totalPing / sp.routes[route].uses);

            if (sp.routes[route].avgPing < sp.bestPing && sp.routes[route].uses >= 2) {
                sp.bestPing = sp.routes[route].avgPing;
                sp.bestRoute = route;
            }
        }

        // Bandwidth pattern learning
        if (bandwidth && CFG.BANDWIDTH_ML) {
            if (!this.bandwidthPatterns[mode]) {
                this.bandwidthPatterns[mode] = { samples: 0, avgBw: 0, totalBw: 0 };
            }
            var bp = this.bandwidthPatterns[mode];
            bp.samples++;
            bp.totalBw += bandwidth;
            bp.avgBw = Math.round(bp.totalBw / bp.samples);
        }

        if (!this.routeHistory[mode]) this.routeHistory[mode] = [];
        if (this.routeHistory[mode].length >= 40) this.routeHistory[mode].shift();
        this.routeHistory[mode].push({ route: route, ping: ping, t: now() });

        if (this.learningData.length >= CFG.ML_HISTORY_SIZE) this.learningData.shift();
        this.learningData.push({
            mode: mode, route: route, ping: ping,
            region: region, isSocial: isSocial || false,
            bandwidth: bandwidth || 0, time: now(),
            success: m ? (ping <= m.maxPing) : false
        });
    },

    predict: function(mode, region) {
        if (!CFG.ENABLE_ML_PREDICTION) return null;

        // Social pattern first
        if (CFG.SOCIAL_ML && this.socialPatterns[mode]) {
            var sp = this.socialPatterns[mode];
            if (sp.samples >= 3 && sp.bestRoute) return sp.bestRoute;
        }

        var key = mode + "_" + (region || "UNKNOWN");
        var pattern = this.patterns[key];
        if (!pattern || pattern.totalSamples < 5) return null;

        var bestWeighted = null, bestWeight = -Infinity;

        for (var route in pattern.routes) {
            var rd = pattern.routes[route];
            if (rd.uses < 3) continue;

            var weight =
                (100 - rd.avgPing) * 0.45 +
                rd.successRate * 0.30 +
                (rd.uses >= 10 ? 25 : rd.uses * 2.5) * 0.15 +
                (rd.bandwidth ? Math.min(rd.bandwidth / 1000, 10) : 0) * 0.10;

            if (rd.trend === "IMPROVING") weight += 20;
            if (rd.trend === "DEGRADING") weight -= 25;

            if (weight > bestWeight) {
                bestWeight = weight;
                bestWeighted = route;
            }
        }

        return bestWeighted || pattern.bestRoute;
    },

    confidence: function(mode, region) {
        var key = mode + "_" + (region || "UNKNOWN");
        var pattern = this.patterns[key];
        if (!pattern) return 0;
        var s = pattern.totalSamples;
        if (s >= 40) return 100;
        if (s >= 25) return 92;
        if (s >= 15) return 80;
        if (s >= 8) return 65;
        if (s >= 4) return 45;
        return 20;
    },

    predictBandwidth: function(mode) {
        if (!CFG.BANDWIDTH_ML || !this.bandwidthPatterns[mode]) return null;
        return this.bandwidthPatterns[mode].avgBw;
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  PROXY HEALTH MONITOR v3
// ═══════════════════════════════════════════════════════════════════════

var HEALTH = {};

function initHealth() {
    for (var name in PROXY) {
        var proxy = PROXY[name];
        HEALTH[name] = {
            uses: 0, successes: 0, failures: 0,
            lastUse: 0, lastSuccess: 0, load: 0,
            status: "READY", avgPing: proxy.targetPing,
            recentPings: [], uptime: 100, score: 100,
            socialUses: 0, consecutiveFailures: 0,
            lastHealthCheck: 0, bandwidth: 0,
            currentPort: proxy.port
        };
    }
}

function updateHealth(name, success, ping, isSocial, bandwidth) {
    if (!HEALTH[name]) return;
    var h = HEALTH[name];
    var p = PROXY[name];

    h.uses++;
    h.lastUse = now();
    if (isSocial) h.socialUses++;
    if (bandwidth) h.bandwidth = bandwidth;

    if (success) {
        h.successes++;
        h.lastSuccess = now();
        h.consecutiveFailures = 0;
    } else {
        h.failures++;
        h.consecutiveFailures++;
    }

    if (ping) {
        if (h.recentPings.length >= 20) h.recentPings.shift();
        h.recentPings.push(ping);
        var sum = 0;
        for (var i = 0; i < h.recentPings.length; i++) sum += h.recentPings[i];
        h.avgPing = Math.round(sum / h.recentPings.length);
    }

    if (p && p.capacity) {
        h.load = Math.min(100, Math.round((h.uses / p.capacity) * 100));
    }

    if (h.uses > 0) h.uptime = Math.round((h.successes / h.uses) * 100);
    h.score = calculateHealthScore(h, p);

    if (h.score >= 95) h.status = "PERFECT";
    else if (h.score >= 85) h.status = "EXCELLENT";
    else if (h.score >= 72) h.status = "GOOD";
    else if (h.score >= 55) h.status = "FAIR";
    else if (h.score >= 35) h.status = "DEGRADED";
    else if (h.score >= 18) h.status = "POOR";
    else h.status = "CRITICAL";

    // Anti-throttle: update port if needed
    if (CFG.ANTI_THROTTLE && h.consecutiveFailures >= 2 && p && p.altPorts) {
        h.currentPort = ANTI_THROTTLE.getBypassPort(p);
    }
}

function calculateHealthScore(health, proxy) {
    var score = 100;

    score -= (100 - health.uptime) * 0.45;

    if (health.load > 92) score -= 30;
    else if (health.load > 80) score -= 18;
    else if (health.load > 65) score -= 10;

    if (proxy && health.avgPing) {
        var ratio = health.avgPing / proxy.targetPing;
        if (ratio <= 0.8) score += 12;
        else if (ratio <= 1.0) score += 8;
        else if (ratio <= 1.2) score -= 8;
        else if (ratio <= 1.5) score -= 18;
        else if (ratio <= 2.0) score -= 30;
        else score -= 45;
    }

    var failRate = health.uses > 0 ? (health.failures / health.uses) : 0;
    if (failRate > 0.25) score -= 25;
    else if (failRate > 0.15) score -= 15;
    else if (failRate > 0.05) score -= 5;

    if (health.consecutiveFailures >= 4) score -= 40;
    else if (health.consecutiveFailures >= 3) score -= 28;
    else if (health.consecutiveFailures >= 2) score -= 15;

    // Bonus features
    if (proxy) {
        if (proxy.socialOptimized && health.socialUses > 0) score += 15;
        if (proxy.socialDedicated) score += 12;
        if (proxy.lobbyDedicated) score += 12;
        if (proxy.gameOptimized) score += 10;
        if (proxy.quantumBurst) score += 8;
        if (proxy.alpha) score += 6;
        if (proxy.fiberConnected) score += 5;
        if (proxy.qosEnabled) score += 5;
        if (proxy.antiThrottle) score += 4;
        if (proxy.tls13) score += 3;
        if (proxy.tier === 0) score += 8;
    }

    // Bandwidth bonus
    if (health.bandwidth > 1000) score += 8;
    else if (health.bandwidth > 500) score += 5;
    else if (health.bandwidth > 100) score += 2;

    return Math.max(0, Math.min(100, Math.round(score)));
}

function getHealthStatus(name) {
    return HEALTH[name] || {
        status: "UNKNOWN", load: 100, score: 0,
        avgPing: 999, currentPort: 443
    };
}

function getBestProxies(tier, carrier, count, socialOpt, lobbyDed, gameOpt) {
    var candidates = [];

    for (var name in PROXY) {
        var p = PROXY[name];
        var h = HEALTH[name];
        if (!p || !h) continue;
        if (tier !== undefined && tier !== null && p.tier !== tier) continue;
        if (carrier && p.carrier !== carrier) continue;
        if (h.status === "CRITICAL" || h.status === "POOR") continue;
        if (h.consecutiveFailures >= 4) continue;
        if (socialOpt && !p.socialOptimized) continue;
        if (lobbyDed && !p.lobbyDedicated) continue;
        if (gameOpt && !p.gameOptimized) continue;

        candidates.push({
            name: name, proxy: p, health: h,
            score: calculateProxyScore(p, h, socialOpt, gameOpt)
        });
    }

    candidates.sort(function(a, b) { return b.score - a.score; });

    count = count || candidates.length;
    var results = [];
    for (var i = 0; i < Math.min(count, candidates.length); i++) {
        results.push(candidates[i].name);
    }
    return results;
}

function calculateProxyScore(proxy, health, socialBoost, gameBoost) {
    var score = 0;

    score += (proxy.priority / 100) * 30;
    score += (health.score / 100) * 28;

    var pingRatio = health.avgPing / Math.max(1, proxy.targetPing);
    if (pingRatio <= 0.7) score += 28;
    else if (pingRatio <= 1.0) score += 22;
    else if (pingRatio <= 1.2) score += 15;
    else if (pingRatio <= 1.5) score += 7;
    else score -= 12;

    if (health.load <= 30) score += 18;
    else if (health.load <= 50) score += 12;
    else if (health.load <= 70) score += 6;
    else score -= 8;

    if (socialBoost && proxy.socialOptimized) {
        score += 28;
        if (proxy.socialDedicated) score += 22;
        if (proxy.friendFinderDedicated) score += 15;
    }

    if (gameBoost && proxy.gameOptimized) {
        score += 25;
        if (proxy.rankDedicated) score += 18;
    }

    if (proxy.quantumBurst) score += 14;
    if (proxy.hyperBurst) score += 10;
    if (proxy.alpha) score += 10;
    if (proxy.tier === 0) score += 12;
    if (proxy.fiberConnected) score += 8;
    if (proxy.qosEnabled) score += 6;
    if (proxy.udpOptimized) score += 6;
    if (proxy.tls13) score += 4;

    // Bandwidth consideration
    if (proxy.maxBandwidth > 5000) score += 12;
    else if (proxy.maxBandwidth > 1000) score += 8;
    else if (proxy.maxBandwidth > 500) score += 4;

    return Math.round(score);
}

initHealth();


// ═══════════════════════════════════════════════════════════════════════
//  GUARD SYSTEM v3 — Multi-Layer Jordan Enforcement
// ═══════════════════════════════════════════════════════════════════════

var GUARD = {
    violations: 0,
    blockedHosts: {},
    trustedHosts: {},
    suspiciousHosts: {},

    isJordan: function(ip) {
        if (!ip || !isIPv4(ip)) return false;
        return inRanges(ip, JO_NETS);
    },

    getJordanCity: function(ip) {
        if (!this.isJordan(ip)) return null;
        for (var city in JO_CITIES) {
            if (JO_CITIES[city].ranges && inRanges(ip, JO_CITIES[city].ranges)) return city;
        }
        return "JORDAN_OTHER";
    },

    getCityPriority: function(city) {
        if (!city || !JO_CITIES[city]) return 60;
        return JO_CITIES[city].priority || 60;
    },

    checkDestination: function(ip, host, mode) {
        if (!ip) return true;

        // IPv6 blocking
        if (ip.indexOf(":") !== -1) {
            if (CFG.IPV6_LEAK_PREVENTION || CFG.JORDAN_ONLY_MODE) {
                this.recordBlock(host, "IPv6 blocked — leak prevention v3");
                return false;
            }
        }

        // Trusted/Blocked cache
        if (this.trustedHosts[host]) return true;
        if (this.blockedHosts[host]) return false;

        if (this.isJordan(ip)) {
            var city = this.getJordanCity(ip);
            this.trustedHosts[host] = {
                ip: ip, city: city,
                priority: this.getCityPriority(city),
                since: now()
            };
            SESSION.jordanHits++;

            var m = MODES[mode];
            if (m && m.socialPriority) SESSION.jordanPlayersFound++;

            return true;
        }

        SESSION.foreignHits++;
        var m2 = MODES[mode];

        // Social must be Jordan
        if (m2 && m2.socialPriority && CFG.FORCE_JORDAN_SOCIAL) {
            this.recordBlock(host, "Social API: Jordan required");
            return false;
        }

        // Game must be Jordan
        if (m2 && m2.gameState === "IN_GAME" && CFG.FORCE_JORDAN_GAME) {
            this.recordBlock(host, "Game traffic: Jordan required");
            return false;
        }

        // Priority 9+ must be Jordan
        if (m2 && m2.priority >= 9 &&
            (CFG.FORCE_JORDAN_LOBBY || CFG.FORCE_JORDAN_MATCHMAKING)) {
            this.recordBlock(host, "Critical mode: Jordan required");
            return false;
        }

        if (CFG.JORDAN_ONLY_MODE) {
            this.recordBlock(host, "Jordan-only mode enforcement");
            return false;
        }

        if (CFG.BLOCK_INTERNATIONAL) {
            this.recordBlock(host, "International block policy");
            return false;
        }

        return true;
    },

    recordBlock: function(host, reason) {
        this.blockedHosts[host] = { reason: reason, time: now() };
        SESSION.blockedHits++;
    },

    buildChain: function(names, mode, requirements) {
        var chain = [];
        var used = {};
        var carriers = {};
        requirements = requirements || {};

        for (var i = 0; i < names.length; i++) {
            var name = names[i];
            if (used[name]) continue;
            if (!PROXY[name]) continue;

            var proxy = PROXY[name];
            var health = getHealthStatus(name);

            if (health.status === "CRITICAL" || health.status === "POOR") continue;
            if (health.consecutiveFailures >= 4) continue;

            // Requirements check
            if (requirements.burst && !proxy.burstCapable) continue;
            if (requirements.ultraBurst && !proxy.ultraBurst) continue;
            if (requirements.hyperBurst && !proxy.hyperBurst) continue;
            if (requirements.quantumBurst && !proxy.quantumBurst) continue;
            if (requirements.socialOptimized && !proxy.socialOptimized) continue;
            if (requirements.lobbyDedicated && !proxy.lobbyDedicated) continue;
            if (requirements.gameOptimized && !proxy.gameOptimized) continue;
            if (requirements.tier !== undefined && proxy.tier > requirements.tier) continue;

            // Multi-ISP load balancing (prefer different carriers)
            if (CFG.MULTI_ISP_LOAD_BALANCE && chain.length > 0) {
                if (carriers[proxy.carrier] && chain.length >= 1) {
                    // Allow same carrier only for chain[0]
                    continue;
                }
            }

            // Get best port (anti-throttle aware)
            var port = health.currentPort || proxy.port;

            chain.push("PROXY " + proxy.ip + ":" + port);
            used[name] = true;
            carriers[proxy.carrier] = true;

            var m = MODES[mode];
            var isSocial = m && m.socialPriority;
            var bw = proxy.maxBandwidth || 100;

            updateHealth(name, true, proxy.targetPing, isSocial, bw);
            BANDWIDTH.record(bw, m ? m.bandwidthType || "GAME" : "GAME");

            if (chain.length >= CFG.MAX_PROXY_CHAIN) break;
        }

        if (chain.length === 0) {
            return CFG.FAIL_CLOSED ? BLOOD.BLK : BLOOD.DIR;
        }

        var result = chain.join("; ");
        result += CFG.FAIL_CLOSED ? ("; " + BLOOD.BLK) : "; DIRECT";
        return result;
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  STICKY ROUTING v3
// ═══════════════════════════════════════════════════════════════════════

var STICKY = {};

function stickyGet(key) {
    var entry = STICKY[key];
    if (!entry) return null;
    if (now() - entry.created > entry.ttl) { delete STICKY[key]; return null; }
    entry.hits = (entry.hits || 0) + 1;
    entry.lastHit = now();
    return entry.value;
}

function stickySet(key, value, ttl) {
    STICKY[key] = {
        value: value, created: now(),
        ttl: ttl || CFG.STICKY_TTL, hits: 0, lastHit: now()
    };
}

function stickyClear(key) { delete STICKY[key]; }
function stickyClearAll() { STICKY = {}; }

function stickyExtend(key, extra) {
    if (STICKY[key]) STICKY[key].ttl += extra;
}


// ═══════════════════════════════════════════════════════════════════════
//  SCORE CACHE v3
// ═══════════════════════════════════════════════════════════════════════

var SCORE_CACHE = {};

function getCachedScore(host, mode) {
    if (!CFG.CACHE_SCORING) return null;
    var key = host + "|" + mode;
    var cached = SCORE_CACHE[key];
    if (cached && now() - cached.t < CFG.SCORE_CACHE_TTL) return cached.score;
    return null;
}

function setCachedScore(host, mode, score) {
    if (!CFG.CACHE_SCORING) return;
    var key = host + "|" + mode;
    SCORE_CACHE[key] = { score: score, t: now() };
    var keys = [];
    for (var k in SCORE_CACHE) keys.push(k);
    if (keys.length > 300) {
        for (var i = 0; i < 60; i++) delete SCORE_CACHE[keys[i]];
    }
}


// ═══════════════════════════════════════════════════════════════════════
//  DETECTION & ANALYSIS
// ═══════════════════════════════════════════════════════════════════════

function detectRegion(host, ip) {
    var h = host.toLowerCase();

    if (ip && GUARD.isJordan(ip)) {
        return {
            region: "JORDAN",
            city: GUARD.getJordanCity(ip),
            priority: GUARD.getCityPriority(GUARD.getJordanCity(ip)),
            confidence: 100
        };
    }

    var jordanPatterns = [
        "jo", "jordan", "amman", "irbid", "zarqa", "aqaba",
        "me-jo", "mena-jo", "jo1", "jo2", "me-east",
        "middle-east", "mena", "arab"
    ];

    for (var i = 0; i < jordanPatterns.length; i++) {
        if (h.indexOf(jordanPatterns[i]) !== -1) {
            return { region: "JORDAN", confidence: 80 };
        }
    }

    return { region: "UNKNOWN", confidence: 0 };
}

function detectMode(host) {
    var h = host.toLowerCase();

    for (var i = 0; i < MODE_PRIORITY.length; i++) {
        var modeName = MODE_PRIORITY[i];
        var mode = MODES[modeName];
        if (!mode || !mode.sig) continue;

        for (var j = 0; j < mode.sig.length; j++) {
            if (h.indexOf(mode.sig[j]) !== -1) {
                if (mode.socialPriority) {
                    if (modeName === "FRIEND_DISCOVERY") {
                        SESSION.recordSocialInteraction("FRIEND_DISCOVERY");
                    } else if (modeName === "CREW_RECRUITMENT") {
                        SESSION.recordSocialInteraction("CREW_SEARCH");
                    } else if (modeName === "LOBBY" || modeName === "MATCHMAKING") {
                        SESSION.recordSocialInteraction("LOBBY_JOIN");
                    }
                }
                return modeName;
            }
        }
    }

    return "CLASSIC";
}

function assessServerQuality(ip, host, mode) {
    var score = 50;

    if (ip && GUARD.isJordan(ip)) {
        score += 50;
        var city = GUARD.getJordanCity(ip);
        if (city === "AMMAN_CORE") score += 30;
        else if (city && city.indexOf("AMMAN") !== -1) score += 22;
        else if (city === "IRBID" || city === "ZARQA") score += 15;
        else score += 8;

        var carrier = getCarrier(ip);
        score += getCarrierBonus(carrier) * 0.3;
    }

    var region = detectRegion(host, ip);
    if (region.region === "JORDAN") score += region.confidence * 0.35;

    var m = MODES[mode];
    if (m && m.socialPriority && ip && !GUARD.isJordan(ip)) score -= 90;

    score = Math.max(0, Math.min(100, score));

    if (score >= 92) return "PERFECT";
    if (score >= 80) return "EXCELLENT";
    if (score >= 65) return "GOOD";
    if (score >= 45) return "FAIR";
    if (score >= 25) return "POOR";
    return "UNACCEPTABLE";
}


// ═══════════════════════════════════════════════════════════════════════
//  CONNECTION PROFILER v3 — Bandwidth-Aware
// ═══════════════════════════════════════════════════════════════════════

var CONNECTION = {
    profile: function() {
        var avg = PING.avg(5);
        var best = PING.best();
        var jitter = PING.jitter();
        var stability = PING.stability();

        var type, quality;

        if (avg <= 2 && best <= 1 && jitter <= 1 && stability === "PERFECT") {
            type = "5G_QUANTUM"; quality = "DIVINE";
        } else if (avg <= 3 && best <= 2 && stability === "ROCK_SOLID") {
            type = "5G_DIAMOND"; quality = "PERFECT";
        } else if (avg <= 5 && best <= 3) {
            type = "5G_ULTRA"; quality = "EXCELLENT";
        } else if (avg <= 8 && best <= 5) {
            type = "5G_PREMIUM"; quality = "EXCELLENT";
        } else if (avg <= 12) {
            type = "5G_GOOD"; quality = "VERY_GOOD";
        } else if (avg <= 20) {
            type = "4G_EXCELLENT"; quality = "GOOD";
        } else if (avg <= 35) {
            type = "4G_GOOD"; quality = "FAIR";
        } else {
            type = "WEAK"; quality = "POOR";
        }

        SESSION.networkQuality = quality;

        return {
            type: type, quality: quality, avgPing: avg,
            bestPing: best, jitter: jitter,
            stability: stability, tier: this.getTier(type)
        };
    },

    getTier: function(type) {
        if (type === "5G_QUANTUM" || type === "5G_DIAMOND") return 0;
        if (type.indexOf("5G") === 0) return 0;
        if (type.indexOf("4G_EXCELLENT") === 0) return 1;
        return 2;
    },

    boost: function() {
        var profile = this.profile();
        var boosts = {
            "5G_QUANTUM": 100, "5G_DIAMOND": 85,
            "5G_ULTRA": 72, "5G_PREMIUM": 62,
            "5G_GOOD": 52, "4G_EXCELLENT": 38,
            "4G_GOOD": 22, "WEAK": -35
        };
        return boosts[profile.type] || 0;
    },

    getCongestionLevel: function() {
        var jitter = PING.jitter();
        var variance = PING.variance();
        var combined = (jitter + variance) / 2;

        if (combined > 18) { SESSION.congestionLevel = 4; return "SEVERE"; }
        if (combined > 12) { SESSION.congestionLevel = 3; return "HIGH"; }
        if (combined > 7)  { SESSION.congestionLevel = 2; return "MEDIUM"; }
        if (combined > 3)  { SESSION.congestionLevel = 1; return "LOW"; }
        SESSION.congestionLevel = 0;
        return "NONE";
    },

    getBandwidthTier: function() {
        var profile = this.profile();
        if (profile.type === "5G_QUANTUM" || profile.type === "5G_DIAMOND") return "ULTRA";
        if (profile.type.indexOf("5G") === 0) return "HIGH";
        if (profile.type.indexOf("4G_EXCELLENT") === 0) return "MEDIUM";
        return "LOW";
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  TIME CONTEXT
// ═══════════════════════════════════════════════════════════════════════

var TIME = {
    isPeakHours: function() {
        var h = (new Date()).getHours();
        return (h >= 16 || h <= 2);
    },
    isWeekend: function() {
        var d = (new Date()).getDay();
        return (d === 5 || d === 6);
    },
    getBoost: function() {
        var p = this.isPeakHours(), w = this.isWeekend();
        if (p && w) return 35;
        if (p || w) return 22;
        return 0;
    },
    isOffPeak: function() {
        var h = (new Date()).getHours();
        return (h >= 3 && h <= 14);
    }
};


// ═══════════════════════════════════════════════════════════════════════
//  CARRIER DETECTION v3
// ═══════════════════════════════════════════════════════════════════════

function getCarrier(ip) {
    if (!ip || !isIPv4(ip)) return "UNKNOWN";

    // Orange Jordan
    if (isInNet(ip, "46.185.128.0", "255.255.128.0") ||
        isInNet(ip, "94.127.192.0", "255.255.192.0") ||
        isInNet(ip, "149.200.128.0", "255.255.128.0") ||
        isInNet(ip, "46.32.96.0", "255.255.224.0")) return "ORANGE";

    // Zain Jordan
    if (isInNet(ip, "79.173.192.0", "255.255.192.0") ||
        isInNet(ip, "109.237.192.0", "255.255.192.0") ||
        isInNet(ip, "176.28.0.0", "255.254.0.0") ||
        isInNet(ip, "37.75.144.0", "255.255.240.0")) return "ZAIN";

    // Umniah Jordan
    if (isInNet(ip, "82.212.0.0", "255.255.0.0") ||
        isInNet(ip, "212.35.64.0", "255.255.192.0") ||
        isInNet(ip, "188.247.64.0", "255.255.192.0")) return "UMNIAH";

    // JT Jordan
    if (isInNet(ip, "188.247.0.0", "255.255.0.0") ||
        isInNet(ip, "94.230.0.0", "255.255.0.0") ||
        isInNet(ip, "91.106.0.0", "255.255.0.0") ||
        isInNet(ip, "217.29.240.0", "255.255.240.0")) return "JT";

    return "OTHER";
}

function getCarrierBonus(carrier) {
    var bonuses = { ORANGE: 55, ZAIN: 52, UMNIAH: 47, JT: 35, OTHER: 0 };
    return bonuses[carrier] || 0;
}


// ═══════════════════════════════════════════════════════════════════════
//  SUPREME SCORING ENGINE v3 — 22 Factors + Bandwidth
// ═══════════════════════════════════════════════════════════════════════

function calculateScore(ip, host, port, dns, mode) {
    var cached = getCachedScore(host, mode);
    if (cached !== null) return cached;

    var score = 0;
    var m = MODES[mode];

    // FACTOR 1: Mode Priority (0-55)
    if (m) {
        score += m.priority * 5.5;
        if (m.socialPriority) score += 48;
        if (m.bandwidthAllocation === 100) score += 12;
    } else {
        score += 28;
    }

    // FACTOR 2: DNS Performance (0-60)
    var dt = dns.dt;
    if (dt <= 0) score += 60;
    else if (dt <= 1) score += 58;
    else if (dt <= 2) score += 52;
    else if (dt <= 4) score += 42;
    else if (dt <= 8) score += 30;
    else if (dt <= 15) score += 15;
    else score -= 35;

    // FACTOR 3: Ping Quality (0-50)
    var quality = PING.quality(mode);
    if (quality === "PERFECT") score += 50;
    else if (quality === "EXCELLENT") score += 40;
    else if (quality === "GOOD") score += 25;
    else if (quality === "ACCEPTABLE") score += 10;
    else score -= 45;

    // FACTOR 4: 🇯🇴 JORDAN IP MEGA BONUS (0-450)
    if (ip && GUARD.isJordan(ip)) {
        score += 200;

        var carrier = getCarrier(ip);
        score += getCarrierBonus(carrier);

        var city = GUARD.getJordanCity(ip);
        var cityPriority = GUARD.getCityPriority(city);
        score += Math.round(cityPriority * 0.6);

        if (m && m.priority >= 9) score += 50;
        if (m && m.socialPriority) score += 70;
        if (TIME.isPeakHours()) score += 30;
        if (TIME.isWeekend()) score += 20;

        // Bandwidth availability bonus
        if (BANDWIDTH.hasCapacity(carrier, 1000)) score += 25;
    }

    // FACTOR 5: Host Region Pattern (0-95)
    var region = detectRegion(host, ip);
    if (region.region === "JORDAN") {
        score += 90 + (region.confidence * 0.25);
        if (region.city === "AMMAN_CORE") score += 25;
    } else {
        score -= 90;
    }

    // FACTOR 6: Connection Quality (0-100)
    score += CONNECTION.boost();

    // FACTOR 7: Network Stability (0-40 / -45)
    var stability = PING.stability();
    if (stability === "PERFECT") score += 40;
    else if (stability === "ROCK_SOLID") score += 35;
    else if (stability === "VERY_STABLE") score += 26;
    else if (stability === "STABLE") score += 16;
    else if (stability === "MODERATE") score += 4;
    else score -= 45;

    // FACTOR 8: Port Score (0-28)
    var portBoost = QOS.getPortBoost(port);
    score += portBoost;

    // FACTOR 9: Trend (−65 to +45)
    var trend = PING.trend();
    if (trend === "IMPROVING") score += 45;
    else if (trend === "DEGRADING") score -= 65;

    // FACTOR 10: Emergency Check (−90)
    if (PING.isEmergency()) score -= 90;
    else if (PING.isCritical()) score -= 65;
    else if (PING.needsOptimization()) score -= 38;
    else if (PING.isRecovering()) score += 20;

    // FACTOR 11: Mode Jordan/Foreign Bonus
    if (m) {
        if (ip && GUARD.isJordan(ip)) score += m.jordanBonus || 0;
        else score += m.foreignPenalty || 0;
    }

    // FACTOR 12: Time Optimization (0-35)
    score += TIME.getBoost();

    // FACTOR 13: Server Quality (0-40)
    var serverQ = dns.quality;
    if (serverQ === "PERFECT") score += 40;
    else if (serverQ === "EXCELLENT") score += 32;
    else if (serverQ === "GOOD") score += 20;
    else if (serverQ === "FAIR") score += 8;
    else score -= 30;

    // FACTOR 14: ML Confidence (0-50)
    if (CFG.ENABLE_ML_PREDICTION) {
        var confidence = ML.confidence(mode, region.region);
        if (confidence >= 95) score += 50;
        else if (confidence >= 80) score += 38;
        else if (confidence >= 65) score += 22;
        else if (confidence >= 50) score += 12;
    }

    // FACTOR 15: Congestion Penalty (−60)
    var congestion = CONNECTION.getCongestionLevel();
    if (congestion === "SEVERE") score -= 60;
    else if (congestion === "HIGH") score -= 45;
    else if (congestion === "MEDIUM") score -= 22;
    else if (congestion === "LOW") score -= 8;

    // FACTOR 16: Social Endpoint (0-70)
    if (dns.socialEndpoint && CFG.ENABLE_FRIEND_DISCOVERY) {
        score += 60;
        if (ip && GUARD.isJordan(ip)) score += 40;
    }

    // FACTOR 17: DNS Cache Hit (0-20)
    if (dns.hitCount > 0) {
        score += Math.min(20, dns.hitCount * 4);
    }

    // FACTOR 18: Visibility Boost Multiplier
    if (m && m.visibilityBoost) {
        score = Math.round(score * (1 + (m.visibilityBoost * 0.085)));
    }

    // FACTOR 19: Jordan Ratio Bonus (0-30 / −35)
    var jRatio = SESSION.jordanRatio();
    if (jRatio >= 98) score += 30;
    else if (jRatio >= 95) score += 22;
    else if (jRatio >= 88) score += 12;
    else if (jRatio < 60 && CFG.STRICT_JORDAN_ENFORCEMENT) score -= 35;

    // FACTOR 20: Session Warmth (0-15)
    if (SESSION.isWarm()) score += 15;

    // FACTOR 21: Bandwidth Availability (0-25)
    var bwTier = CONNECTION.getBandwidthTier();
    if (bwTier === "ULTRA") score += 25;
    else if (bwTier === "HIGH") score += 18;
    else if (bwTier === "MEDIUM") score += 10;
    else score -= 10;

    // FACTOR 22: Jitter Penalty (−30)
    var jitter = PING.jitter();
    if (jitter > CFG.MAX_JITTER * 3) score -= 30;
    else if (jitter > CFG.MAX_JITTER * 2) score -= 18;
    else if (jitter > CFG.MAX_JITTER) score -= 8;
    else score += 10;

    // Normalize to 0-100
    if (score < 0) score = 0;
    var maxPossible = 600;
    score = score > maxPossible ? 100 : Math.round((score / maxPossible) * 100);

    setCachedScore(host, mode, score);
    return score;
}


// ═══════════════════════════════════════════════════════════════════════
//  SUPREME ROUTING ENGINE v3 — Quantum Strategies
// ═══════════════════════════════════════════════════════════════════════

function selectRoute(mode, score, ip, port, host, dns) {
    var m = MODES[mode];
    if (!m) m = MODES["CLASSIC"];

    var strategy = m.strategy;
    var region = dns.region;
    var carrier = getCarrier(ip);
    var isJordanIP = ip && GUARD.isJordan(ip);

    if (m.gameState) SESSION.updateGameState(m.gameState);

    // Security Gate
    if (!GUARD.checkDestination(ip, host, mode)) return BLOOD.BLK;

    // Anti-throttle detection
    if (CFG.ANTI_THROTTLE) {
        var throttled = ANTI_THROTTLE.detect();
        if (throttled && !ANTI_THROTTLE.bypassActive) {
            ANTI_THROTTLE.activateBypass();
            SESSION.throttleDetected = true;
        }
    }

    // ML Prediction
    if (CFG.ENABLE_ML_PREDICTION && SESSION.isWarm()) {
        var predicted = ML.predict(mode, region.region || "UNKNOWN");
        var confidence = ML.confidence(mode, region.region || "UNKNOWN");
        if (predicted && confidence >= CFG.ML_CONFIDENCE_THRESHOLD && PING.isHealthy(mode)) {
            return predicted;
        }
    }

    // Sticky Check
    if (m.sticky && SESSION.isWarm()) {
        var sticky = stickyGet(mode);
        if (sticky && PING.isHealthy(mode) && !PING.needsOptimization()) {
            var q = PING.quality(mode);
            if (q === "PERFECT" || q === "EXCELLENT") stickyExtend(mode, 180000);
            return sticky;
        }
    }

    // Emergency Rerouting
    if (PING.isEmergency() || PING.isCritical()) {
        stickyClear(mode);
        var emergencyProxies = getBestProxies(0, null, 3, m.socialPriority, false, !m.socialPriority);
        var emergency = GUARD.buildChain(emergencyProxies, mode, {
            burst: true, ultraBurst: true, hyperBurst: true,
            quantumBurst: true, tier: 0,
            socialOptimized: m.socialPriority,
            gameOptimized: !m.socialPriority
        });
        stickySet(mode, emergency, m.stickyDuration);
        ML.recordSuccess(mode, emergency, PING.current(), region.region, m.socialPriority, 10000);
        return emergency;
    }

    var route = null;

    // ━━━━━━━━━━━ SOCIAL_QUANTUM_FORCE ━━━━━━━━━━━
    if (strategy === "SOCIAL_QUANTUM_FORCE") {
        if (m.proxyTier) {
            // Use mode-specific dedicated proxies first
            route = GUARD.buildChain(m.proxyTier, mode, {
                burst: true, ultraBurst: true, hyperBurst: true,
                quantumBurst: true, tier: 0, socialOptimized: true
            });
        }

        if (!route || route === BLOOD.BLK) {
            if (score >= 90 || (isJordanIP && carrier === "ORANGE")) {
                route = GUARD.buildChain(
                    ["SOCIAL_ORANGE_ULTRA", "SOCIAL_ZAIN_ULTRA", "SOCIAL_UMNIAH_ULTRA"],
                    mode, {
                        burst: true, ultraBurst: true, hyperBurst: true,
                        quantumBurst: true, tier: 0, socialOptimized: true
                    }
                );
            } else if (score >= 75 || isJordanIP) {
                route = GUARD.buildChain(
                    getBestProxies(0, carrier, 3, true, false, false),
                    mode, {
                        burst: true, ultraBurst: true, hyperBurst: true,
                        tier: 0, socialOptimized: true
                    }
                );
            } else {
                route = GUARD.buildChain(
                    getBestProxies(0, null, 3, true, false, false),
                    mode, {
                        burst: true, ultraBurst: true, tier: 0, socialOptimized: true
                    }
                );
            }
        }
    }

    // ━━━━━━━━━━━ LOBBY_QUANTUM_FORCE ━━━━━━━━━━━
    else if (strategy === "LOBBY_QUANTUM_FORCE") {
        if (m.proxyTier) {
            route = GUARD.buildChain(m.proxyTier, mode, {
                burst: true, ultraBurst: true, hyperBurst: true,
                quantumBurst: true, tier: 0, socialOptimized: true
            });
        }

        if (!route || route === BLOOD.BLK) {
            if (score >= 88 || isJordanIP) {
                var lobbyProxies = getBestProxies(0, carrier, 3, true, true, false);
                if (lobbyProxies.length < 2) {
                    lobbyProxies = getBestProxies(0, null, 3, true, false, false);
                }
                route = GUARD.buildChain(lobbyProxies, mode, {
                    burst: true, ultraBurst: true, hyperBurst: true,
                    quantumBurst: true, tier: 0, socialOptimized: true
                });
            } else {
                route = GUARD.buildChain(
                    ["LOBBY_ORANGE_ULTRA", "LOBBY_ZAIN_ULTRA", "LOBBY_UMNIAH_ULTRA"],
                    mode, {
                        burst: true, ultraBurst: true, tier: 0, socialOptimized: true
                    }
                );
            }
        }
    }

    // ━━━━━━━━━━━ SOCIAL_CRITICAL ━━━━━━━━━━━
    else if (strategy === "SOCIAL_CRITICAL") {
        route = GUARD.buildChain(
            getBestProxies(0, null, 3, true, false, false),
            mode, {
                burst: true, ultraBurst: true, tier: 0, socialOptimized: true
            }
        );
    }

    // ━━━━━━━━━━━ SOCIAL_GAME_QUANTUM ━━━━━━━━━━━
    else if (strategy === "SOCIAL_GAME_QUANTUM") {
        if (score >= 82 || isJordanIP) {
            route = GUARD.buildChain(
                getBestProxies(0, carrier, 3, true, false, true),
                mode, {
                    burst: true, ultraBurst: true, hyperBurst: true,
                    tier: 0, socialOptimized: true, gameOptimized: true
                }
            );
        } else {
            route = GUARD.buildChain(
                getBestProxies(0, null, 3, false, false, true),
                mode, {
                    burst: true, ultraBurst: true, tier: 0, gameOptimized: true
                }
            );
        }
    }

    // ━━━━━━━━━━━ GAME_QUANTUM_CRITICAL ━━━━━━━━━━━
    else if (strategy === "GAME_QUANTUM_CRITICAL") {
        if (m.proxyTier) {
            route = GUARD.buildChain(m.proxyTier, mode, {
                burst: true, ultraBurst: true, hyperBurst: true,
                quantumBurst: true, tier: 0, gameOptimized: true
            });
        }

        if (!route || route === BLOOD.BLK) {
            if (score >= 88 || isJordanIP) {
                route = GUARD.buildChain(
                    getBestProxies(0, carrier, 3, false, false, true),
                    mode, {
                        burst: true, ultraBurst: true, hyperBurst: true,
                        quantumBurst: true, tier: 0, gameOptimized: true
                    }
                );
            } else {
                route = GUARD.buildChain(
                    getBestProxies(0, null, 3, false, false, true),
                    mode, {
                        burst: true, ultraBurst: true, tier: 0, gameOptimized: true
                    }
                );
            }
        }
    }

    // ━━━━━━━━━━━ SECURE_QUANTUM ━━━━━━━━━━━
    else if (strategy === "SECURE_QUANTUM") {
        route = GUARD.buildChain(
            ["ORANGE_QUANTUM_1", "ZAIN_QUANTUM_1", "UMNIAH_QUANTUM_1"],
            mode, {
                burst: true, ultraBurst: true, hyperBurst: true,
                quantumBurst: true, tier: 0
            }
        );
    }

    // ━━━━━━━━━━━ GAME_CRITICAL ━━━━━━━━━━━
    else if (strategy === "GAME_CRITICAL") {
        if (score >= 82 || isJordanIP) {
            route = GUARD.buildChain(
                getBestProxies(0, carrier, 2, false, false, true),
                mode, {
                    burst: true, ultraBurst: true, tier: 0, gameOptimized: true
                }
            );
        } else {
            route = GUARD.buildChain(
                getBestProxies(1, null, 2, false, false, false),
                mode, { burst: true, tier: 1 }
            );
        }
    }

    // ━━━━━━━━━━━ GAME_STANDARD ━━━━━━━━━━━
    else if (strategy === "GAME_STANDARD") {
        route = GUARD.buildChain(
            getBestProxies(null, null, 2, false, false, false),
            mode, { burst: true, tier: 1 }
        );
    }

    // ━━━━━━━━━━━ GAME_LIGHT ━━━━━━━━━━━
    else if (strategy === "GAME_LIGHT") {
        route = GUARD.buildChain(
            getBestProxies(null, null, 2, false, false, false),
            mode, { tier: 2 }
        );
    }

    // ━━━━━━━━━━━ CDN ━━━━━━━━━━━
    else if (strategy === "CDN") {
        route = GUARD.buildChain(
            getBestProxies(null, null, 1, false, false, false),
            mode, {}
        );
    }

    // ━━━━━━━━━━━ SAFE / DEFAULT ━━━━━━━━━━━
    else {
        route = GUARD.buildChain(
            getBestProxies(0, null, 2, m.socialPriority, false, !m.socialPriority),
            mode, {
                burst: true, tier: 0,
                socialOptimized: m.socialPriority,
                gameOptimized: !m.socialPriority
            }
        );
    }

    // Final fallback
    if (!route || route === BLOOD.BLK) {
        route = GUARD.buildChain(
            ["ORANGE_QUANTUM_1", "ZAIN_QUANTUM_1", "UMNIAH_QUANTUM_1"],
            mode, {
                burst: true, ultraBurst: true, hyperBurst: true,
                quantumBurst: true, tier: 0
            }
        );
    }

    // Record ML + Sticky
    if (m.sticky) stickySet(mode, route, m.stickyDuration);
    if (CFG.ENABLE_ML_PREDICTION) {
        var bwEstimate = BANDWIDTH.maximize(m.bandwidthType || "GAME") * 100;
        ML.recordSuccess(mode, route, PING.current(), region.region, m.socialPriority, bwEstimate);
    }

    return route;
}


// ═══════════════════════════════════════════════════════════════════════
//  MAIN PAC FUNCTION v33.0 — Supreme Entry Point
// ═══════════════════════════════════════════════════════════════════════

function FindProxyForURL(url, host) {
    SESSION.requests++;

    // Time context update (every 15 requests)
    if (SESSION.requests % 15 === 1) SESSION.updateTimeContext();

    // Prefetch on startup
    if (SESSION.requests === 1) {
        prefetchAllEndpoints();
    }

    // Periodic health re-evaluation (every 50 requests)
    if (SESSION.requests % 50 === 0 && CFG.AUTO_HEALING) {
        stickyClear("CDN");
        stickyClear("TRAINING");
        // Don't clear game/social stickies — they're precious
    }

    if (!host) return BLOOD.DIR;

    var h = host.toLowerCase();

    // Fast path: localhost
    if (isPlainHostName(host)) return BLOOD.DIR;

    // Fast path: private IPs
    if (isIPv4(host)) {
        if (isInNet(host, "10.0.0.0", "255.0.0.0") ||
            isInNet(host, "172.16.0.0", "255.240.0.0") ||
            isInNet(host, "192.168.0.0", "255.255.0.0") ||
            isInNet(host, "127.0.0.0", "255.0.0.0") ||
            isInNet(host, "169.254.0.0", "255.255.0.0")) {
            return BLOOD.DIR;
        }
    }

    // Fast path: known direct domains (non-PUBG)
    if (containsAny(h, DIRECT_KEYS) && !containsAny(h, PUBG_KEYS)) {
        SESSION.directHits++;
        return BLOOD.DIR;
    }

    // Fast path: non-PUBG traffic
    if (!containsAny(h, PUBG_KEYS)) {
        SESSION.directHits++;
        return BLOOD.DIR;
    }

    // ═══ PUBG Traffic — Supreme v33.0 Processing ═══
    SESSION.pubgRequests++;

    var dns = fastDNS(host);
    var ip = dns.ip;
    var mode = dns.mode || detectMode(host);
    var port = getPort(url);

    SESSION.recordMode(mode);

    // IPv6 leak prevention
    if (ip && ip.indexOf(":") !== -1) {
        if (CFG.IPV6_LEAK_PREVENTION || CFG.JORDAN_ONLY_MODE) {
            SESSION.blockedHits++;
            return BLOOD.BLK;
        }
    }

    // Bandwidth allocation update
    var m = MODES[mode];
    if (m && CFG.BANDWIDTH_MAXIMIZER) {
        var allocation = BANDWIDTH.adaptivScale(
            m.gameState || SESSION.gameState,
            mode
        );
        BANDWIDTH.gameAllocation = allocation.game;
        BANDWIDTH.socialAllocation = allocation.social;
        BANDWIDTH.cdnAllocation = allocation.cdn;
    }

    // Calculate Supreme Score v3
    var score = calculateScore(ip, h, port, dns, mode);

    // Select Supreme Route v3
    var route = selectRoute(mode, score, ip, port, h, dns);

    // QoS logging
    if (CFG.QOS_ENABLED && m) {
        var queueType = QOS.classify(mode, m.udpPriority ? "GAME_UDP" : "TCP");
        QOS.recordPacket(queueType, 1500);
    }

    return route;
}


// ═══════════════════════════════════════════════════════════════════════
//  ULTRA UTILITY FUNCTIONS v3
// ═══════════════════════════════════════════════════════════════════════

function now() {
    return (new Date()).getTime();
}

function generateSessionId() {
    return "JO_V33_" + now() + "_" + Math.random().toString(36).substr(2, 14);
}

function isIPv4(str) {
    if (!str || str.indexOf(":") !== -1) return false;
    var parts = str.split(".");
    if (parts.length !== 4) return false;
    for (var i = 0; i < 4; i++) {
        var n = parseInt(parts[i], 10);
        if (isNaN(n) || n < 0 || n > 255) return false;
    }
    return true;
}

// Pre-computed CIDR lookup table
var CIDR_MASKS = {
    "8":  "255.0.0.0",       "9":  "255.128.0.0",
    "10": "255.192.0.0",     "11": "255.224.0.0",
    "12": "255.240.0.0",     "13": "255.248.0.0",
    "14": "255.252.0.0",     "15": "255.254.0.0",
    "16": "255.255.0.0",     "17": "255.255.128.0",
    "18": "255.255.192.0",   "19": "255.255.224.0",
    "20": "255.255.240.0",   "21": "255.255.248.0",
    "22": "255.255.252.0",   "23": "255.255.254.0",
    "24": "255.255.255.0",   "25": "255.255.255.128",
    "26": "255.255.255.192", "27": "255.255.255.224",
    "28": "255.255.255.240", "29": "255.255.255.248",
    "30": "255.255.255.252"
};

function maskFromCIDR(cidr) {
    return CIDR_MASKS[String(cidr)] || "255.255.0.0";
}

function inRanges(ip, ranges) {
    if (!ip || !isIPv4(ip)) return false;
    for (var i = 0; i < ranges.length; i++) {
        var base = ranges[i][0];
        var mask = maskFromCIDR(ranges[i][1]);
        if (isInNet(ip, base, mask)) return true;
    }
    return false;
}

function containsAny(str, keywords) {
    for (var i = 0; i < keywords.length; i++) {
        if (str.indexOf(keywords[i]) !== -1) return true;
    }
    return false;
}

function getPort(url) {
    var match = url.match(/^[a-zA-Z]+:\/\/[^\/:]+:(\d+)/);
    if (match) return parseInt(match[1], 10);
    if (url.indexOf("https://") === 0) return 443;
    if (url.indexOf("http://") === 0) return 80;
    return 443;
}


