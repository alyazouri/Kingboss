// ═══════════════════════════════════════════════════════════════════════
//  CORE FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════

function now() { return Date.now(); }

function _hash(s) {
    var h = 5381;
    for (var i = 0; i < s.length; i++) {
        h = ((h << 5) + h) + s.charCodeAt(i);
        h = h & h;
    }
    return Math.abs(h);
}

// ═══════════════════════════════════════════════════════════════════════
//  🔍 IP VERIFICATION — هل الـ IP أردني؟
// ═══════════════════════════════════════════════════════════════════════

function isJordanIP(ip) {
    if (!ip || ip.indexOf(":") !== -1) return false;
    for (var i = 0; i < JO_NETS.length; i++) {
        if (isInNet(ip, JO_NETS[i], JO_NETS[i]<!--citation:1-->)) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════════════
//  🚫 هل الـ IP من دولة محجوبة؟ (الفلتر الأساسي)
// ═══════════════════════════════════════════════════════════════════════

function isBlockedCountryIP(ip) {
    if (!ip || ip.indexOf(":") !== -1) return false;

    for (var country in BLOCKED_COUNTRY_NETS) {
        var nets = BLOCKED_COUNTRY_NETS[country];
        for (var i = 0; i < nets.length; i++) {
            if (isInNet(ip, nets[i], nets[i]<!--citation:1-->)) {
                return { blocked: true, country: country };
            }
        }
    }
    return { blocked: false, country: null };
}

// ═══════════════════════════════════════════════════════════════════════
//  🚫 هل الهوست سيرفر أجنبي؟
// ═══════════════════════════════════════════════════════════════════════

function isForeignServerHost(host) {
    var h = host.toLowerCase();
    for (var i = 0; i < SIGNATURES.FOREIGN_SERVERS.length; i++) {
        if (h.indexOf(SIGNATURES.FOREIGN_SERVERS[i]) !== -1) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════════════
//  ✅ هل الهوست سيرفر أردني؟
// ═══════════════════════════════════════════════════════════════════════

function isJordanServerHost(host) {
    var h = host.toLowerCase();
    for (var i = 0; i < SIGNATURES.JORDAN_SERVERS.length; i++) {
        if (h.indexOf(SIGNATURES.JORDAN_SERVERS[i]) !== -1) return true;
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════════════
//  📋 تصنيف نوع الطلب
// ═══════════════════════════════════════════════════════════════════════

function classifyRequest(host) {
    var h = host.toLowerCase();

    // الأولوية: ماتش ميكنج > صوت > سوشال > لعبة > CDN
    for (var i = 0; i < SIGNATURES.MATCHMAKING.length; i++)
        if (h.indexOf(SIGNATURES.MATCHMAKING[i]) !== -1) return "MATCHMAKING";
    for (var i = 0; i < SIGNATURES.VOICE.length; i++)
        if (h.indexOf(SIGNATURES.VOICE[i]) !== -1) return "VOICE";
    for (var i = 0; i < SIGNATURES.SOCIAL.length; i++)
        if (h.indexOf(SIGNATURES.SOCIAL[i]) !== -1) return "SOCIAL";
    for (var i = 0; i < SIGNATURES.GAME.length; i++)
        if (h.indexOf(SIGNATURES.GAME[i]) !== -1) return "GAME";
    for (var i = 0; i < SIGNATURES.CDN.length; i++)
        if (h.indexOf(SIGNATURES.CDN[i]) !== -1) return "CDN";

    return "UNKNOWN";
}

// ═══════════════════════════════════════════════════════════════════════
//  🔎 كشف الناقل (Orange/Zain/Umniah)
// ═══════════════════════════════════════════════════════════════════════

function detectCarrier() {
    try {
        var ip = myIpAddress();
        if (isInNet(ip,"46.185.0.0","255.255.0.0") || isInNet(ip,"94.127.0.0","255.255.0.0") ||
            isInNet(ip,"149.200.0.0","255.255.0.0") || isInNet(ip,"5.45.128.0","255.255.192.0") ||
            isInNet(ip,"185.117.68.0","255.255.252.0")) return "ORANGE";
        if (isInNet(ip,"79.173.0.0","255.255.0.0") || isInNet(ip,"109.237.0.0","255.255.0.0") ||
            isInNet(ip,"176.28.0.0","255.254.0.0") || isInNet(ip,"185.70.64.0","255.255.252.0") ||
            isInNet(ip,"37.44.0.0","255.255.0.0")) return "ZAIN";
        if (isInNet(ip,"82.212.0.0","255.255.0.0") || isInNet(ip,"212.35.0.0","255.255.0.0") ||
            isInNet(ip,"188.247.0.0","255.255.0.0") || isInNet(ip,"185.86.216.0","255.255.252.0")) return "UMNIAH";
    } catch(e) {}
    return "ANY";
}

// ═══════════════════════════════════════════════════════════════════════
//  🎯 اختيار أفضل بروكسي حسب النوع والناقل
// ═══════════════════════════════════════════════════════════════════════

function selectBestProxy(mode, carrier) {
    var candidates = [];

    for (var name in PROXY_POOL) {
        var p = PROXY_POOL[name];

        // فلتر الناقل
        if (carrier !== "ANY" && p.carrier !== carrier) continue;

        // فلتر الدور
        if (p.role !== "ALL" && p.role !== mode) continue;

        // حساب النقاط
        var score = 1000;
        score -= p.ping * 100;          // بنق أقل = أفضل
        score += p.reliability * 5;     // موثوقية أعلى = أفضل
        score += (2 - p.tier) * 200;    // تير أقل = أفضل
        if (p.gov === "AMMAN") score += 150;  // عمّان = مكافأة

        candidates.push({ name: name, proxy: p, score: score });
    }

    // ترتيب حسب النقاط
    candidates.sort(function(a, b) { return b.score - a.score; });

    return candidates;
}

// ═══════════════════════════════════════════════════════════════════════
//  🔗 بناء سلسلة البروكسي النهائية
// ═══════════════════════════════════════════════════════════════════════

function buildChain(candidates, maxCount, strict) {
    var parts = [];
    var count = Math.min(maxCount || 2, candidates.length);

    for (var i = 0; i < count; i++) {
        parts.push("PROXY " + candidates[i].proxy.ip + ":" + candidates[i].proxy.port);
    }

    if (parts.length === 0) {
        return strict ? "PROXY 0.0.0.0:1" : "DIRECT";
    }

    var chain = parts.join("; ");

    // في الوضع الصارم: لا تذهب DIRECT أبداً (حجب مطلق)
    if (strict) {
        chain += "; PROXY 0.0.0.0:1";
    } else {
        chain += "; DIRECT";
    }

    return chain;
}

// ═══════════════════════════════════════════════════════════════════════
//  📦 نظام التخزين المؤقت (Sticky Cache)
// ═══════════════════════════════════════════════════════════════════════

function getCached(key) {
    var entry = SESSION.stickyCache[key];
    if (!entry) return null;
    if (now() - entry.time > CFG.STICKY_TTL) {
        delete SESSION.stickyCache[key];
        return null;
    }
    return entry.route;
}

function setCache(key, route) {
    SESSION.stickyCache[key] = { route: route, time: now() };
    // تنظيف الذاكرة
    var keys = Object.keys(SESSION.stickyCache);
    if (keys.length > 300) {
        keys.sort(function(a,b) {
            return SESSION.stickyCache[a].time - SESSION.stickyCache[b].time;
        });
        for (var i = 0; i < 50; i++) delete SESSION.stickyCache[keys[i]];
    }
}

// ═══════════════════════════════════════════════════════════════════════
//  🧠 AI/ML — تعلم أفضل المسارات
// ═══════════════════════════════════════════════════════════════════════

var ML = {
    record: function(mode, route, carrier) {
        var key = mode + "_" + carrier;
        if (!SESSION.mlData[key]) SESSION.mlData[key] = { routes: {}, best: null };
        var d = SESSION.mlData[key];
        if (!d.routes[route]) d.routes[route] = { count: 0 };
        d.routes[route].count++;
        // أكثر مسار استخداماً بدون مشاكل = الأفضل
        if (!d.best || d.routes[route].count > (d.routes[d.best] || {count:0}).count) {
            d.best = route;
        }
    },
    predict: function(mode, carrier) {
        var key = mode + "_" + carrier;
        var d = SESSION.mlData[key];
        if (d && d.best && d.routes[d.best] && d.routes[d.best].count >= 5) {
            return d.best;
        }
        return null;
    }
};

// ═══════════════════════════════════════════════════════════════════════
//  ╔═══════════════════════════════════════════════════════════════╗
//  ║  🎯🎯🎯 الدالة الرئيسية — FindProxyForURL 🎯🎯🎯          ║
//  ║  هنا يحدث كل شيء — الفلترة والتوجيه والحجب               ║
//  ╚═══════════════════════════════════════════════════════════════╝
// ═══════════════════════════════════════════════════════════════════════

function FindProxyForURL(url, host) {
    SESSION.requests++;
    if (!host) return "DIRECT";
    var h = host.toLowerCase();

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 1: مرور مباشر — شبكات محلية وتطبيقات عامة
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    if (isPlainHostName(host)) return "DIRECT";
    if (shExpMatch(h, "*.local") || h === "localhost") return "DIRECT";
    if (isInNet(host, "10.0.0.0", "255.0.0.0")) return "DIRECT";
    if (isInNet(host, "192.168.0.0", "255.255.0.0")) return "DIRECT";
    if (isInNet(host, "172.16.0.0", "255.240.0.0")) return "DIRECT";
    if (isInNet(host, "127.0.0.0", "255.0.0.0")) return "DIRECT";

    // تطبيقات عامة — DIRECT
    for (var i = 0; i < SIGNATURES.DIRECT.length; i++) {
        if (h.indexOf(SIGNATURES.DIRECT[i]) !== -1) return "DIRECT";
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 2: تصنيف الطلب
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    var mode = classifyRequest(host);
    if (mode === "UNKNOWN") return "DIRECT"; // ليس طلب PUBG

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 3: 🚫🚫🚫 حجب السيرفرات الأجنبية فوراً 🚫🚫🚫
    //  ← هذه هي الطبقة الأهم لضمان لاعبين أردنيين فقط
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    // 3A: حجب بناءً على اسم الهوست
    if (isForeignServerHost(h)) {
        SESSION.foreignBlocked++;
        return "PROXY 0.0.0.0:1"; // ← ثقب أسود = اللعبة تعيد المحاولة وتجد سيرفر أقرب (أردن)
    }

    // 3B: حل DNS والتحقق الجغرافي
    var ip = null;
    try { ip = dnsResolve(host); } catch(e) {}

    if (ip) {
        // هل الـ IP من دولة محجوبة؟
        var blockCheck = isBlockedCountryIP(ip);
        if (blockCheck.blocked) {
            SESSION.foreignBlocked++;
            SESSION.menaBlocked++;

            // 🆕 بدل الحجب المطلق، نُجبر المرور عبر بروكسي أردني
            // هذا يجعل اللعبة "تظن" أنك قريب من سيرفر أردني
            if (mode === "MATCHMAKING" || mode === "GAME") {
                if (SESSION.carrier === "UNKNOWN") SESSION.carrier = detectCarrier();
                var rescue = selectBestProxy("MATCHMAKING", SESSION.carrier);
                if (rescue.length > 0) {
                    var rescueRoute = "PROXY " + rescue.proxy.ip + ":" + rescue.proxy.port + "; PROXY 0.0.0.0:1";
                    return rescueRoute;
                }
            }
            return "PROXY 0.0.0.0:1"; // حجب مطلق
        }

        // هل الـ IP ليس أردنياً وليس من دولة معروفة؟ → حجب أيضاً
        if (!isJordanIP(ip) && (mode === "MATCHMAKING" || mode === "GAME" || mode === "VOICE")) {
            SESSION.foreignBlocked++;
            // محاولة إنقاذ عبر بروكسي أردني
            if (SESSION.carrier === "UNKNOWN") SESSION.carrier = detectCarrier();
            var fallback = selectBestProxy(mode, SESSION.carrier);
            if (fallback.length > 0) {
                return "PROXY " + fallback.proxy.ip + ":" + fallback.proxy.port + "; PROXY 0.0.0.0:1";
            }
            return "PROXY 0.0.0.0:1";
        }

        // ✅ IP أردني = نسمح ونسجل
        if (isJordanIP(ip)) {
            SESSION.jordanHits++;
        }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 4: كشف الناقل (أول مرة فقط)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    if (SESSION.carrier === "UNKNOWN") {
        SESSION.carrier = detectCarrier();
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 5: فحص الذاكرة المؤقتة
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    var cacheKey = mode + "_" + SESSION.carrier + "_" + h;
    var cached = getCached(cacheKey);
    if (cached) return cached;

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 6: AI Prediction
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    if (CFG.ML_ENABLED && SESSION.requests > 20) {
        var predicted = ML.predict(mode, SESSION.carrier);
        if (predicted) {
            setCache(cacheKey, predicted);
            return predicted;
        }
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 7: 🎯 التوجيه حسب نوع الطلب
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    var route;
    var candidates;

    switch(mode) {

        // ━━━ الماتش ميكنج — الأهم! يحدد من يكون في لوبيك ━━━
        case "MATCHMAKING":
            SESSION.matchRequests++;
            candidates = selectBestProxy("MATCHMAKING", SESSION.carrier);
            // سلسلة قصيرة (1 بروكسي) = أقل بنق = أفضل لوبي
            route = buildChain(candidates, 1, true); // strict = true = لا DIRECT أبداً
            break;

        // ━━━ الصوت — مسار مخصص فائق السرعة ━━━
        case "VOICE":
            SESSION.voiceRequests++;
            candidates = selectBestProxy("VOICE", SESSION.carrier);
            route = buildChain(candidates, 1, true);
            break;

        // ━━━ السوشال — لاكتشاف أصدقاء أردنيين ━━━
        case "SOCIAL":
            SESSION.socialRequests++;
            candidates = selectBestProxy("SOCIAL", SESSION.carrier);
            route = buildChain(candidates, 2, true);
            break;

        // ━━━ اللعبة العامة ━━━
        case "GAME":
            SESSION.gameRequests++;
            candidates = selectBestProxy("GAME", SESSION.carrier);
            route = buildChain(candidates, 2, true);
            break;

        // ━━━ CDN — أقل أولوية ━━━
        case "CDN":
            candidates = selectBestProxy("GAME", SESSION.carrier);
            route = buildChain(candidates, 1, false); // يسمح بـ DIRECT
            break;

        default:
            return "DIRECT";
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  الطبقة 8: تخزين + تسجيل + تعلم
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

    setCache(cacheKey, route);
    ML.record(mode, route, SESSION.carrier);

    return route;
}

// ═══════════════════════════════════════════════════════════════════════
//  📊 إحصائيات الجلسة — للمراقبة
// ═══════════════════════════════════════════════════════════════════════

function getStats() {
    var jr = SESSION.requests > 0 ? Math.round((SESSION.jordanHits / SESSION.requests) * 100) : 0;
    return {
        version: CFG.VERSION,
        session: SESSION.id,
        uptime: Math.round((now() - SESSION.start) / 60000) + " min",
        totalRequests: SESSION.requests,
        gameRequests: SESSION.gameRequests,
        matchRequests: SESSION.matchRequests,
        socialRequests: SESSION.socialRequests,
        voiceRequests: SESSION.voiceRequests,
        jordanHits: SESSION.jordanHits,
        jordanRatio: jr + "%",
        foreignBlocked: SESSION.foreignBlocked,
        menaBlocked: SESSION.menaBlocked,
        carrier: SESSION.carrier,
        ghostOps: SESSION.ghostOps,
        cacheSize: Object.keys(SESSION.stickyCache).length,
        mlPatterns: Object.keys(SESSION.mlData).length,
        status: jr >= 95 ? "🟢 JORDAN PURE" :
                jr >= 80 ? "🟡 MOSTLY JORDAN" :
                jr >= 50 ? "🟠 MIXED" : "🔴 NEEDS TUNING"
    };
}

