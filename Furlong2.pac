// ═══════════════════════════════════════════════════════════════════════
//  QUANTUM ROUTING ENGINE v3
// ═══════════════════════════════════════════════════════════════════════

function selectRoute(mode, score, ip, port, host, dns) {
    var m = MODES[mode] || MODES.CLASSIC;
    var emotion = EMOTION.detect(mode, PING.current(), PING.trend());
    var emotionStrategy = EMOTION.getStrategy(emotion);
    
    // ⚛️ Quantum Entanglement
    if (CFG.QUANTUM_ENTANGLEMENT && m.priority >= 9) {
        var routes = [
            "PROXY " + PROXY.QT_ORANGE.ip + ":" + PROXY.QT_ORANGE.port,
            "PROXY " + PROXY.QT_ZAIN.ip + ":" + PROXY.QT_ZAIN.port
        ];
        
        var spId = QUANTUM.superpose(routes);
        var bestRoute = QUANTUM.collapse(spId, function(r) {
            return score;
        });
        
        if (bestRoute) return bestRoute + "; DIRECT [QUANTUM]";
    }
    
    // 🔬 Quantum Tunnel
    if (CFG.QUANTUM_TUNNEL && m.socialPriority) {
        var tunnelId = QUANTUM_TUNNEL.create([
            PROXY.QT_SOCIAL.ip + ":" + PROXY.QT_SOCIAL.port,
            PROXY.QT_ORANGE.ip + ":" + PROXY.QT_ORANGE.port,
            PROXY.QT_ZAIN.ip + ":" + PROXY.QT_ZAIN.port
        ]);
        
        var tunnelRoute = QUANTUM_TUNNEL.route(tunnelId, "SOCIAL");
        return "PROXY " + tunnelRoute + "; DIRECT [TUNNEL]";
    }
    
    // ❤️ Emotion-based routing
    if (emotionStrategy.aggressive) {
        return GUARD.buildChain(
            getBestProxies(0, null, 3, m.socialPriority),
            mode,
            { burst: true, ultraBurst: true, tier: 0 }
        ) + " [EMOTION:" + emotion + "]";
    }
    
    // Default quantum social
    if (m.socialPriority) {
        return "PROXY " + PROXY.QT_SOCIAL.ip + ":" + PROXY.QT_SOCIAL.port + 
               "; DIRECT [SOCIAL_Q]";
    }
    
    return GUARD.buildChain(
        getBestProxies(0, null, 2, false),
        mode,
        { tier: 0 }
    );
}


// ═══════════════════════════════════════════════════════════════════════
//  MAIN FUNCTION — QUANTUM ENTRY
// ═══════════════════════════════════════════════════════════════════════

function FindProxyForURL(url, host) {
    SESSION.requests++;
    
    if (!host) return BLOOD.DIR;
    
    var h = host.toLowerCase();
    
    // Local
    if (isPlainHostName(host) || isInNet(host, "192.168.0.0", "255.255.0.0")) {
        return BLOOD.DIR;
    }
    
    // Non-PUBG
    if (!containsAny(h, PUBG_KEYS)) return BLOOD.DIR;
    
    // 🔥 Pre-warm prediction
    if (CFG.PREDICTIVE_WARM) {
        var predicted = PREDICTOR.predict(detectMode(h));
        if (predicted) PREDICTOR.warm(predicted);
    }
    
    // 💎 Quantum DNS
    var dnsResult = CFG.DNS_SHARDING ? 
        QUANTUM_DNS.resolveParallel(host) : 
        { ip: dnsResolve(host), dt: 0 };
    
    var ip = dnsResult.ip;
    var mode = detectMode(h);
    
    // 🧬 DNA Analysis
    if (CFG.NEURAL_DNA && ip) {
        var dna = DNA.generate(ip, host, mode);
        var cluster = DNA.cluster(dna);
        
        // Dark pool injection
        if (CFG.DARK_POOL && mode === "MATCHMAKING") {
            DARK_POOL.inject(5);
        }
        
        // Social virus spread
        if (CFG.VIRUS_SPREAD && m.socialPriority) {
            VIRUS.infect("SELF_" + now(), "ORIGIN");
            VIRUS.spread("SELF_" + now());
        }
    }
    
    // 👻 Apply cloak
    if (CFG.CLOAK_ENABLED) {
        var cloak = CLOAK.get();
        var mask = CLOAK.mask();
    }
    
    var port = url.indexOf("https") === 0 ? 443 : 80;
    var score = calculateScore(ip, h, port, { dt: dnsResult.dt, ip: ip }, mode);
    
    return selectRoute(mode, score, ip, port, host, { ip: ip });
}


// ═══════════════════════════════════════════════════════════════════════
//  UTILITY FUNCTIONS (Enhanced)
// ═══════════════════════════════════════════════════════════════════════

function now() { return (new Date()).getTime(); }

function isIPv4(s) { 
    return /^(\d{1,3}\.){3}\d{1,3}$/.test(s); 
}

function containsAny(str, keywords) {
    str = str.toLowerCase();
    for (var i = 0; i < keywords.length; i++) {
        if (str.indexOf(keywords[i]) !== -1) return true;
    }
    return false;
}

function inRanges(ip, ranges) {
    if (!ip || !isIPv4(ip)) return false;
    for (var i = 0; i < ranges.length; i++) {
        if (isInNet(ip, ranges[i][0], maskFromCIDR(ranges[i][1]))) return true;
    }
    return false;
}

function maskFromCIDR(cidr) {
    var masks = { "8":"255.0.0.0","16":"255.255.0.0","17":"255.255.128.0",
        "18":"255.255.192.0","19":"255.255.224.0","20":"255.255.240.0",
        "21":"255.255.248.0","22":"255.255.252.0" };
    return masks[cidr] || "255.255.0.0";
}


